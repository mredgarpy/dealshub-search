{% comment %} Customer Addresses Page {% endcomment %}
<div class="customer-page section">
  <div class="container">
    <div class="customer-page__header">
      <h1 class="customer-page__title">My Addresses</h1>
    </div>

    <div class="account-layout">
      {%- render 'account-nav', active: 'addresses' -%}

      <div>
        <!-- Add new address -->
        <div class="account-card" style="margin-bottom:24px;">
          <div class="account-card__title">Add New Address</div>
          {%- form 'customer_address', customer.new_address -%}
            {%- if form.errors -%}
              <div style="background:rgba(231,76,60,.08);border:1px solid var(--color-danger);border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:.875rem;color:var(--color-danger);">{{ form.errors | default_errors }}</div>
            {%- endif -%}
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:0;">
              <div class="form-group"><label class="form-label">First Name</label><input type="text" name="address[first_name]" class="form-input" value="{{ form.first_name }}" autocomplete="given-name"></div>
              <div class="form-group"><label class="form-label">Last Name</label><input type="text" name="address[last_name]" class="form-input" value="{{ form.last_name }}" autocomplete="family-name"></div>
              <div class="form-group" style="grid-column:1/-1;"><label class="form-label">Address</label><input type="text" name="address[address1]" class="form-input" value="{{ form.address1 }}" autocomplete="address-line1" placeholder="123 Main St"></div>
              <div class="form-group" style="grid-column:1/-1;"><label class="form-label">Apt / Suite (optional)</label><input type="text" name="address[address2]" class="form-input" value="{{ form.address2 }}" autocomplete="address-line2"></div>
              <div class="form-group"><label class="form-label">City</label><input type="text" name="address[city]" class="form-input" value="{{ form.city }}" autocomplete="address-level2"></div>
              <div class="form-group"><label class="form-label">ZIP / Postal Code</label><input type="text" name="address[zip]" class="form-input" value="{{ form.zip }}" autocomplete="postal-code"></div>
              <div class="form-group">
                <label class="form-label">Country</label>
                <select name="address[country]" class="form-input" autocomplete="country" id="AddressCountryNew">
                  {{ all_country_option_tags }}
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">State / Province</label>
                <select name="address[province]" class="form-input" id="AddressProvinceNew">
                  <option value="">Select Province</option>
                </select>
              </div>
              <div class="form-group" style="grid-column:1/-1;"><label class="form-label">Phone (optional)</label><input type="tel" name="address[phone]" class="form-input" value="{{ form.phone }}" autocomplete="tel"></div>
            </div>
            <label style="display:flex;align-items:center;gap:10px;font-size:.875rem;cursor:pointer;margin-bottom:20px;">
              <input type="checkbox" name="address[default]" id="address_default_address_new" style="accent-color:var(--color-primary);">
              <span>Set as default address</span>
            </label>
            <button type="submit" class="btn btn--primary">Save Address</button>
          {%- endform -%}
        </div>

        <!-- Existing addresses -->
        {%- if customer.addresses.size > 0 -%}
        <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:16px;">Saved Addresses</h2>
        <div class="grid grid--2">
          {%- for address in customer.addresses -%}
          <div class="account-card">
            {%- if address.default -%}
              <span class="badge badge--deal" style="margin-bottom:10px;display:inline-flex;">Default</span>
            {%- endif -%}
            <address style="font-style:normal;font-size:.875rem;line-height:1.7;margin-bottom:14px;">
              <strong>{{ address.name }}</strong><br>
              {%- if address.company != blank -%}{{ address.company }}<br>{%- endif -%}
              {{ address.address1 }}<br>
              {%- if address.address2 != blank -%}{{ address.address2 }}<br>{%- endif -%}
              {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
              {{ address.country }}<br>
              {%- if address.phone != blank -%}{{ address.phone }}{%- endif -%}
            </address>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <a href="#" onclick="editAddress('{{ address.id }}')" class="btn btn--ghost btn--sm">Edit</a>
              {%- form 'customer_address', address -%}
                <input type="hidden" name="_method" value="delete">
                <button type="submit" class="btn btn--ghost btn--sm" style="color:var(--color-danger);" onclick="return confirm('Delete this address?')">Delete</button>
              {%- endform -%}
              {%- unless address.default -%}
              {%- form 'customer_address', address -%}
                <input type="hidden" name="_method" value="put">
                <input type="hidden" name="address[default]" value="true">
                <button type="submit" class="btn btn--ghost btn--sm">Set Default</button>
              {%- endform -%}
              {%- endunless -%}
            </div>
          </div>
          {%- endfor -%}
        </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</div>
