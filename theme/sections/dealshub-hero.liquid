{% comment %}
  DealsHub — Hero Banner Section
{% endcomment %}

<div class="dh-hero" style="background: {{ section.settings.bg_color | default: 'linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%)' }};">
  <div class="dh-hero__inner page-width">
    <div class="dh-hero__content">
      <span class="dh-hero__badge">{{ section.settings.badge | default: '🔥 Miami\'s #1 Marketplace' }}</span>
      <h1 class="dh-hero__title">{{ section.settings.heading | default: 'StyleHub Miami' }}</h1>
      <p class="dh-hero__sub">{{ section.settings.subheading | default: 'Discover incredible deals on fashion, beauty, electronics & more — shipped to your door.' }}</p>
      <form class="dh-hero__search" action="/pages/search" method="get">
        <div class="dh-hero__search-wrap">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="search" name="q" placeholder="{{ section.settings.search_placeholder | default: 'What are you looking for today?' }}" class="dh-hero__search-input">
          <button type="submit" class="dh-hero__search-btn">Search</button>
        </div>
      </form>
      <div class="dh-hero__tags">
        {% assign tags = section.settings.trending_tags | default: 'Sneakers, Perfumes, iPhone Cases, Skincare, Dresses' | split: ', ' %}
        <span class="dh-hero__tags-label">Trending:</span>
        {% for tag in tags %}
          <a href="/pages/search?q={{ tag | url_encode }}" class="dh-hero__tag">{{ tag }}</a>
        {% endfor %}
      </div>
    </div>
  </div>

  <!-- Trust Strip -->
  <div class="dh-hero__sources page-width">
    <div class="dh-hero__source-strip">
      <div class="dh-hero__source-logos">
        <span class="dh-hero__logo">🇺🇸 USA & Int'l Shipping</span>
        <span class="dh-hero__logo">🔒 Secure Checkout</span>
        <span class="dh-hero__logo">↩️ Easy Returns</span>
        <span class="dh-hero__logo">⚡ Fast Delivery</span>
      </div>
    </div>
  </div>
</div>

<style>
  .dh-hero {
    position: relative;
    overflow: hidden;
    padding: 60px 0 32px;
  }
  .dh-hero__inner {
    text-align: center;
  }
  .dh-hero__badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 20px;
    color: #ffc107;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 16px;
  }
  .dh-hero__title {
    font-size: 48px;
    font-weight: 800;
    color: #fff;
    margin: 0 0 12px;
    letter-spacing: -1px;
  }
  .dh-hero__sub {
    font-size: 18px;
    color: rgba(255,255,255,.75);
    margin: 0 auto 28px;
    max-width: 560px;
    line-height: 1.5;
  }
  .dh-hero__search-wrap {
    display: flex;
    max-width: 600px;
    margin: 0 auto;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0,0,0,.2);
  }
  .dh-hero__search-wrap svg {
    margin: 14px 0 14px 16px;
    flex-shrink: 0;
  }
  .dh-hero__search-input {
    flex: 1;
    border: none;
    padding: 14px 12px;
    font-size: 16px;
    outline: none;
  }
  .dh-hero__search-btn {
    padding: 14px 32px;
    background: #ff4757;
    color: #fff;
    border: none;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background .2s;
  }
  .dh-hero__search-btn:hover { background: #ff6b6b; }
  .dh-hero__tags {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .dh-hero__tags-label {
    font-size: 12px;
    color: rgba(255,255,255,.5);
  }
  .dh-hero__tag {
    padding: 4px 12px;
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 16px;
    color: rgba(255,255,255,.8);
    font-size: 12px;
    text-decoration: none;
    transition: all .2s;
  }
  .dh-hero__tag:hover {
    background: rgba(255,255,255,.2);
    color: #fff;
  }
  .dh-hero__sources {
    margin-top: 32px;
  }
  .dh-hero__source-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .dh-hero__source-label {
    font-size: 12px;
    color: rgba(255,255,255,.4);
  }
  .dh-hero__source-logos {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .dh-hero__logo {
    font-size: 13px;
    font-weight: 700;
    color: rgba(255,255,255,.5);
    letter-spacing: .5px;
  }

  @media (max-width: 768px) {
    .dh-hero { padding: 36px 0 24px; }
    .dh-hero__title { font-size: 32px; }
    .dh-hero__sub { font-size: 15px; }
    .dh-hero__search-btn { padding: 14px 20px; }
  }
</style>

{% schema %}
{
  "name": "DealsHub Hero",
  "tag": "section",
  "class": "dealshub-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge Text",
      "default": "🔥 Miami's #1 Marketplace"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "StyleHub Miami"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Find the best deals from Amazon, SHEIN, Sephora, Macy's and AliExpress in one place."
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder",
      "default": "What are you looking for today?"
    },
    {
      "type": "text",
      "id": "trending_tags",
      "label": "Trending Tags (comma separated)",
      "default": "Sneakers, Perfumes, iPhone Cases, Skincare, Dresses"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Background Gradient"
    }
  ],
  "presets": [
    {
      "name": "DealsHub Hero"
    }
  ]
}
{% endschema %}
