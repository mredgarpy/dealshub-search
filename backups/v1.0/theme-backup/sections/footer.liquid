      <div class="dh-footer-newsletter">
        <p style="margin:0;color:#ddd;font-weight:500;">Get exclusive deals</p>
        <form class="nl-form" id="dh-footer-newsletter" action="#" method="post">
          <input type="email" placeholder="Your email..." required aria-label="Email for newsletter">
          <button type="submit">OK</button>
        </form>
      </div>
    </div>
    <div>
      <h4>Categories</h4>
      <a href="/pages/search-results?q=fashion">Fashion</a>
      <a href="/pages/search-results?q=beauty">Beauty</a>
      <a href="/pages/search-results?q=electronics">Electronics</a>
      <a href="/pages/search-results?q=home+decor">Home</a>
      <a href="/pages/search-results?q=sports">Sports</a>
      <a href="/pages/search-results?q=flash+deals">Flash Deals</a>
    </div>
    <div>
      <h4>My Account</h4>
      <a href="/pages/my-account#orders">My Orders</a>
      <a href="/pages/my-account#wishlist">Wishlist</a>
      <a href="/pages/my-account#addresses">My Addresses</a>
      <a href="/pages/my-account#settings">Account Settings</a>
