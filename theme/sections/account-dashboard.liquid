  {%- comment -%} === SETTINGS === {%- endcomment -%}
  <div class="sh-content-section" data-sh-section="settings">
    <div class="sh-welcome">
      <div>
        <h1>Account settings</h1>
        <div class="sh-welcome-sub">Manage your profile and preferences</div>
      </div>
    </div>

    {%- comment -%} Profile info — read-only view with inline edit toggle {%- endcomment -%}
    <div class="sh-section" id="sh-profile-view">
      <div class="sh-section-head">
        <div class="sh-section-title">Profile information</div>
        <button class="sh-section-action" id="sh-profile-edit-btn" style="background:none;border:none;font-family:inherit;cursor:pointer;color:var(--red);font-weight:600;font-size:13px">Edit profile &rarr;</button>
      </div>
      <div class="sh-section-body">
        <div class="sh-set-grid">
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Full name</div><div class="sh-set-val">{{ cust_name }}</div></div></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Email address</div><div class="sh-set-val">{{ cust_email }}</div></div></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Phone number</div><div class="sh-set-val">{%- if cust_default_address and cust_default_address.phone != blank -%}{{ cust_default_address.phone }}{%- else -%}Not set{%- endif -%}</div></div></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Password</div><div class="sh-set-val">Managed by Shopify accounts</div></div></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Total orders</div><div class="sh-set-val">{{ cust_order_count }} orders</div></div><button class="sh-set-edit" data-sh-nav="orders" style="background:none;border:none;font-family:inherit;cursor:pointer">View</button></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Total spent</div><div class="sh-set-val">{{ customer.total_spent | money }}</div></div><span class="sh-set-edit" style="opacity:0.5">-</span></div>
        </div>
      </div>
    </div>

    {%- comment -%} Profile edit form — uses Shopify native customer form (no API token needed) {%- endcomment -%}
    <div class="sh-section" id="sh-profile-form" style="display:none">
      <div class="sh-section-head">
        <div class="sh-section-title">Edit profile</div>
        <button class="sh-section-action" id="sh-profile-cancel-btn" style="background:none;border:none;font-family:inherit;cursor:pointer;color:#666;font-weight:600;font-size:13px">Cancel</button>
      </div>
      <div class="sh-section-body">
        {% form 'customer', customer %}
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;max-width:500px">
            <div>
              <label for="sh-cust-first" style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">First name</label>
              <input type="text" id="sh-cust-first" name="customer[first_name]" value="{{ customer.first_name }}" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:8px;font-size:14px;font-family:inherit">
            </div>
            <div>
              <label for="sh-cust-last" style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Last name</label>
              <input type="text" id="sh-cust-last" name="customer[last_name]" value="{{ customer.last_name }}" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:8px;font-size:14px;font-family:inherit">
            </div>
          </div>
          <div style="margin-top:14px;max-width:500px">
            <label for="sh-cust-email" style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Email address</label>
            <input type="email" id="sh-cust-email" name="customer[email]" value="{{ customer.email }}" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:8px;font-size:14px;font-family:inherit" disabled>
            <span style="font-size:11px;color:#999;margin-top:4px;display:block">Email cannot be changed here</span>
          </div>
          <div style="margin-top:18px;display:flex;gap:10px">
            <button type="submit" style="padding:10px 28px;background:var(--red,#e53e3e);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit">Save changes</button>
            <button type="button" id="sh-profile-cancel-btn2" style="padding:10px 20px;background:#f5f5f5;color:#333;border:1px solid #ddd;border-radius:8px;font-size:14px;cursor:pointer;font-family:inherit">Cancel</button>
          </div>
        {% endform %}
      </div>
    </div>

    {%- comment -%} Account stats (always visible) {%- endcomment -%}
    <div class="sh-section">
      <div class="sh-section-head">
        <div class="sh-section-title">Account overview</div>
      </div>
      <div class="sh-section-body">
        <div class="sh-set-grid">
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Member since</div><div class="sh-set-val">{{ customer.created_at | date: "%B %Y" }}</div></div></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Default address</div><div class="sh-set-val">{%- if cust_default_address -%}{{ cust_default_address.city }}, {{ cust_default_address.province_code }} {{ cust_default_address.zip }}{%- else -%}Not set{%- endif -%}</div></div><button class="sh-set-edit" data-sh-nav="addresses" style="background:none;border:none;font-family:inherit;cursor:pointer">Manage</button></div>
        </div>
      </div>
    </div>
  </div>

</div><!-- end main -->
</div><!-- end page -->
</div><!-- end sh-acct -->

<script>
(function() {
  'use strict';

  /* Navigation */
  var navItems = document.querySelectorAll('[data-sh-nav]');
  var sections = document.querySelectorAll('[data-sh-section]');
  var sidebar = document.querySelector('[data-sh-sidebar]');
  var overlay = document.querySelector('[data-sh-overlay]');
  var mobileToggle = document.querySelector('[data-sh-mobile-toggle]');

  function showSection(name) {
    sections.forEach(function(s) { s.classList.remove('active'); });
    navItems.forEach(function(n) { n.classList.remove('active'); });
    var target = document.querySelector('[data-sh-section="' + name + '"]');
    if (target) target.classList.add('active');
    navItems.forEach(function(n) {
      if (n.getAttribute('data-sh-nav') === name) n.classList.add('active');
    });
    closeSidebar();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  navItems.forEach(function(item) {
    item.addEventListener('click', function(e) {
      e.preventDefault();
      showSection(this.getAttribute('data-sh-nav'));
    });
  });

  /* Mobile sidebar */
  function closeSidebar() {
    if (sidebar) sidebar.classList.remove('open');
    if (overlay) overlay.classList.remove('open');
  }

  if (mobileToggle) {
    mobileToggle.addEventListener('click', function() {
      sidebar.classList.toggle('open');
      overlay.classList.toggle('open');
    });
  }
  if (overlay) overlay.addEventListener('click', closeSidebar);

  /* Copy coupon code */
  document.querySelectorAll('[data-sh-copy]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var code = this.getAttribute('data-sh-copy');
      if (navigator.clipboard) {
        navigator.clipboard.writeText(code);
        this.textContent = 'Copied!';
        var self = this;
        setTimeout(function() { self.textContent = 'Copy code'; }, 2000);
      }
    });
  });

  /* Dismiss alert */
  document.querySelectorAll('[data-sh-dismiss]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      this.closest('.sh-alert').style.display = 'none';
    });
  });

  /* Wishlist count from localStorage */
  try {
    var wl = JSON.parse(localStorage.getItem('sh_wishlist') || '[]');
    var countEls = document.querySelectorAll('[data-sh-wishlist-count]');
    countEls.forEach(function(el) { el.textContent = wl.length; });
  } catch(e) {}

  /* Profile edit/cancel toggle */
  var profileView = document.getElementById('sh-profile-view');
  var profileForm = document.getElementById('sh-profile-form');
  var profileEditBtn = document.getElementById('sh-profile-edit-btn');
  var profileCancelBtn = document.getElementById('sh-profile-cancel-btn');
  var profileCancelBtn2 = document.getElementById('sh-profile-cancel-btn2');

  function showProfileEdit() {
    if (profileView) profileView.style.display = 'none';
    if (profileForm) profileForm.style.display = 'block';
  }
  function hideProfileEdit() {
    if (profileForm) profileForm.style.display = 'none';
    if (profileView) profileView.style.display = 'block';
  }

  if (profileEditBtn) profileEditBtn.addEventListener('click', showProfileEdit);
  if (profileCancelBtn) profileCancelBtn.addEventListener('click', hideProfileEdit);
  if (profileCancelBtn2) profileCancelBtn2.addEventListener('click', hideProfileEdit);

  /* Address add form toggle */
  var addrFormWrap = document.getElementById('sh-addr-form-wrap');
  function showAddrForm() { if (addrFormWrap) addrFormWrap.style.display = 'block'; }
  function hideAddrForm() { if (addrFormWrap) addrFormWrap.style.display = 'none'; }

  var addrAddBtn = document.getElementById('sh-addr-add-btn');
  var addrAddBtn2 = document.getElementById('sh-addr-add-btn2');
  var addrCancelBtn = document.getElementById('sh-addr-cancel-btn');
  var addrCancelBtn2 = document.getElementById('sh-addr-cancel-btn2');

  if (addrAddBtn) addrAddBtn.addEventListener('click', showAddrForm);
  if (addrAddBtn2) addrAddBtn2.addEventListener('click', showAddrForm);
  if (addrCancelBtn) addrCancelBtn.addEventListener('click', hideAddrForm);
  if (addrCancelBtn2) addrCancelBtn2.addEventListener('click', hideAddrForm);

  /* Hash navigation on load */
  if (window.location.hash) {
    var hashSection = window.location.hash.replace('#', '');
    var validSections = ['dashboard','orders','addresses','coupons','messages','recently-viewed','settings'];
    if (validSections.indexOf(hashSection) !== -1) {
      showSection(hashSection);
    }
  }
})();
</script>

