{% comment %}
  DealsHub — Unified Product Detail Page
  Renders product from any source (Amazon, AliExpress, Sephora, Macy's, SHEIN)
  Uses /api/product/:id?store=SOURCE for live data
  Uses /api/prepare-cart for sync-on-demand checkout
{% endcomment %}

<style>
  .dh-pdp{max-width:1200px;margin:0 auto;padding:24px 16px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#1a1a1a}
  .dh-loading{text-align:center;padding:80px 20px;color:#666}
  .dh-loading .spinner{width:40px;height:40px;border:3px solid #eee;border-top-color:#ff6b35;border-radius:50%;animation:dhspin .8s linear infinite;margin:0 auto 16px}
  @keyframes dhspin{to{transform:rotate(360deg)}}
  .dh-error{text-align:center;padding:60px 20px}
  .dh-error h2{font-size:20px;margin-bottom:8px}
  .dh-error p{color:#666;margin-bottom:20px}
  .dh-error a{color:#ff6b35;text-decoration:none;font-weight:600}
  .dh-breadcrumb{font-size:13px;color:#888;margin-bottom:16px}
  .dh-breadcrumb a{color:#ff6b35;text-decoration:none}
  .dh-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px}
  @media(max-width:768px){.dh-grid{grid-template-columns:1fr;gap:20px}}

  /* Gallery */
  .dh-gallery{position:relative}
  .dh-main-img{width:100%;aspect-ratio:1;object-fit:contain;border-radius:12px;background:#f8f8f8;border:1px solid #eee;cursor:zoom-in}
  .dh-thumbs{display:flex;gap:8px;margin-top:12px;overflow-x:auto;padding-bottom:4px}
  .dh-thumb{width:64px;height:64px;object-fit:cover;border-radius:8px;border:2px solid transparent;cursor:pointer;background:#f8f8f8;flex-shrink:0;transition:border-color .2s}
  .dh-thumb:hover,.dh-thumb.active{border-color:#ff6b35}
  .dh-badge-tag{position:absolute;top:12px;left:12px;background:#ff6b35;color:#fff;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600}
  .dh-discount-tag{position:absolute;top:12px;right:12px;background:#e53935;color:#fff;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:700}

  /* Info */
  .dh-info{display:flex;flex-direction:column;gap:12px}
  .dh-brand{font-size:13px;color:#666;text-transform:uppercase;letter-spacing:.5px;font-weight:600}
  .dh-title{font-size:22px;font-weight:700;line-height:1.3;margin:0}
  .dh-rating{display:flex;align-items:center;gap:8px;font-size:14px}
  .dh-stars{color:#f59e0b;letter-spacing:2px}
  .dh-rating-num{font-weight:600}
  .dh-rating-count{color:#888}
  .dh-prices{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin:4px 0}
  .dh-price{font-size:30px;font-weight:800;color:#ff6b35}
  .dh-orig-price{font-size:16px;color:#999;text-decoration:line-through}
  .dh-savings{background:#fff3e0;color:#e65100;padding:2px 8px;border-radius:4px;font-size:12px;font-weight:600}
  .dh-availability{font-size:13px;font-weight:500}
  .dh-availability.in-stock{color:#4caf50}
  .dh-availability.out-of-stock{color:#e53935}

  /* Variants */
  .dh-variant-group{margin:8px 0}
  .dh-variant-label{font-size:14px;font-weight:600;color:#333;margin-bottom:8px}
  .dh-variant-options{display:flex;flex-wrap:wrap;gap:8px}
  .dh-variant-btn{padding:8px 16px;border:2px solid #e0e0e0;border-radius:8px;background:#fff;cursor:pointer;font-size:13px;color:#333;transition:all .2s}
  .dh-variant-btn:hover{border-color:#ff6b35}
  .dh-variant-btn.selected{border-color:#ff6b35;background:#fff8f5;color:#ff6b35;font-weight:600}
  .dh-variant-btn img{width:24px;height:24px;border-radius:4px;margin-right:6px;vertical-align:middle}

  /* Trust strip */
  .dh-trust{display:flex;gap:16px;flex-wrap:wrap;padding:12px 0;border-top:1px solid #eee;border-bottom:1px solid #eee;font-size:12px;color:#555}
  .dh-trust-item{display:flex;align-items:center;gap:4px}

  /* Actions */
  .dh-actions{display:flex;gap:12px;margin-top:8px;
  .dh-btn{flex:1;padding:16px;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;transition:all .2s;text-transform:uppercase;letter-spacing:.5px}
  .dh-btn-primary{background:#ff6b35;color:#fff}
  .dh-btn-primary:hover{background:#e55a2b}
  .dh-btn-secondary{background:#fff;color:#ff6b35;border:2px solid #ff6b35}
  .dh-btn-secondary:hover{Background:#fff8f5}
  .dh-btn-secondary:hover{background:#fff8f5}
  .dh-btn:disabled{opacity: .5;cursor:not-allowed}
  .dh-btn .btn-spin{display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:dhspin .6s linear infinite;vertical-align:middle;margin-right:8px}

  /* Shipping/Return info */
  .dh-info-cards{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:8px 0}
  @MeBIaT 168px){.dh-info-cards{grid-template-columns:1fr}}
  
  @Amedia(max-width:768px){.dh-info-cards{grid-template-columns:1fr}}
  .dh-info-card{background:#f8f9fa;border-radius:8px;padding:12px;font-size:13px}
  .dh-info-card strong{display:block;font-size:12px;color:#888;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}

  /* Tabs */
  .dh-tabs{margin-top:40px;border-top:1px solid #eee;padding-top:20px}
  .dh-tab-nav{display:flex;gap:0;border-bottom:2px solid #eee;margin-bottom:20px;overflow-x:auto}
  .dh-tab-btn{padding:12px 24px;border:none;background:none;font-size:14px;font-weight:600;color:#888;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;white-space:nowrap;transition:all .2s}
  .dh-tab-btn:hover{color:#333}
  .dh-tab-btn.active{color:#ff6b35;border-bottom-color:#ff6b35}
  .dh-tab-panel{display:none;font-size:15px;line-height:1.7;color:#444}
  .dh-tab-panel.active{display:block}
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
