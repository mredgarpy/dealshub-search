        <button class="sh-section-action" data-sh-nav="settings" style="background:none;border:none;font-family:inherit;cursor:pointer;color:var(--red);font-weight:600;font-size:13px">Edit profile &rarr;</button>
      </div>
      <div class="sh-section-body">
        <div class="sh-set-grid">
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Full name</div><div class="sh-set-val">{{ cust_name }}</div></div><button class="sh-set-edit" data-sh-nav="settings" style="background:none;border:none;font-family:inherit;cursor:pointer">Edit</button></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Email address</div><div class="sh-set-val">{{ cust_email }}</div></div><span class="sh-set-edit" style="opacity:0.5">-</span></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Phone number</div><div class="sh-set-val">{%- if cust_default_address and cust_default_address.phone != blank -%}{{ cust_default_address.phone }}{%- else -%}Not set{%- endif -%}</div></div><button class="sh-set-edit" data-sh-nav="settings" style="background:none;border:none;font-family:inherit;cursor:pointer">Edit</button></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Password</div><div class="sh-set-val">Managed by Shopify</div></div><span class="sh-set-edit" style="opacity:0.5">-</span></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Orders</div><div class="sh-set-val">{{ cust_order_count }} total orders</div></div><button class="sh-set-edit" data-sh-nav="orders" style="background:none;border:none;font-family:inherit;cursor:pointer">View</button></div>
          <div class="sh-set-item"><div class="sh-set-left"><div class="sh-set-key">Language</div><div class="sh-set-val">English (US)</div></div><span class="sh-set-edit" style="opacity:0.5">Default</span></div>
        </div>
      </div>
    </div>

  </div><!-- end dashboard -->

  {%- comment -%} === ORDERS SECTION === {%- endcomment -%}
  <div class="sh-content-section" data-sh-section="orders">
    <div class="sh-welcome">
      <div>
        <h1>My orders</h1>
        <div class="sh-welcome-sub">View and manage your order history</div>
      </div>
    </div>

    {%- if cust_order_count == 0 -%}
      <div class="sh-section">
        <div class="sh-section-body">
          <div class="sh-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--navy)" stroke-width="1.5" width="48" height="48"><path d="M20 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            <h3>No orders yet</h3>
            <p>Start shopping to see your orders here.</p>
            <a href="/" class="sh-empty-btn">Start shopping &rarr;</a>
          </div>
        </div>
      </div>
    {%- else -%}
      <div class="sh-section">
        <div class="sh-section-head">
          <div class="sh-section-title">All orders <span class="sh-count">{{ cust_order_count }}</span></div>
        </div>
        <div class="sh-section-body">
          {%- for order in cust_orders -%}
            <div class="sh-order-card">
              <div class="sh-oc-top">
                <div>
                  <span class="sh-oc-id">{{ order.name }}</span> &middot; {{ order.created_at | date: '%b %d, %Y' }}
                </div>
              </div>
              <div class="sh-oc-items">
                {%- for item in order.line_items -%}
                  <div style="display:flex;gap:12px;align-items:center;{%- unless forloop.first -%}margin-top:8px{%- endunless -%}">
                    <div class="sh-oc-img">
                      {%- if item.image -%}
                        <img src="{{ item.image | image_url: width: 128 }}" alt="{{ item.title | escape }}" loading="lazy">
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1" width="24" height="24"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                      {%- endif -%}
                    </div>
                    <div class="sh-oc-info">
                      <div class="sh-oc-name">{{ item.title }}</div>
                      {%- if item.variant_title != blank -%}
                        <div class="sh-oc-variant">{{ item.variant_title }}</div>
                      {%- endif -%}
                      <div class="sh-oc-price-row">
                        <span class="sh-oc-price">{{ item.final_price | money }}</span>
                        <span class="sh-oc-qty">&times; {{ item.quantity }}</span>
                      </div>
                    </div>
                  </div>
                {%- endfor -%}
              </div>

              {%- assign ff_status = order.fulfillment_status -%}
              {%- if ff_status == "fulfilled" or ff_status == "partial" -%}
                <div class="sh-oc-track">
                  <div class="sh-track">
                    <div class="sh-track-node">
                      <div class="sh-track-dot done"></div>
                      <div class="sh-track-line done"></div>
                      <div class="sh-track-label active">Confirmed<br><span class="sh-track-date">{{ order.created_at | date: '%b %d' }}</span></div>
                    </div>
                    <div class="sh-track-node">
                      <div class="sh-track-dot done"></div>
                      <div class="sh-track-line {% if ff_status == 'fulfilled' %}done{% endif %}"></div>
                      <div class="sh-track-label active">Shipped</div>
                    </div>
                    <div class="sh-track-node">
                      <div class="sh-track-dot {% if ff_status == 'fulfilled' %}done{% else %}now{% endif %}"></div>
                      <div class="sh-track-line"></div>
                      <div class="sh-track-label {% if ff_status == 'fulfilled' %}active{% endif %}">In transit</div>
                    </div>
                    <div class="sh-track-node">
                      <div class="sh-track-dot"></div>
                      <div class="sh-track-label">Delivered</div>
                    </div>
                  </div>
                </div>
              {%- endif -%}

              <div class="sh-oc-bottom">
                {%- if order.cancelled_at != blank -%}
                  <span class="sh-oc-status sh-st-cancelled">Cancelled</span>
                {%- elsif ff_status == "fulfilled" -%}
                  <span class="sh-oc-status sh-st-shipped">Shipped</span>
                {%- elsif ff_status == "partial" -%}
                  <span class="sh-oc-status sh-st-processing">Partially fulfilled</span>
                {%- else -%}
                  <span class="sh-oc-status sh-st-processing">Processing</span>
                {%- endif -%}
                <div class="sh-oc-actions">
                  <a href="{{ order.customer_url }}" class="sh-oc-btn sh-oc-btn-outline" target="_blank" rel="noopener">View details</a>
                  {%- if ff_status == "fulfilled" -%}
                    <a href="/pages/tracking" class="sh-oc-btn sh-oc-btn-primary">Track package</a>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} === ADDRESSES === {%- endcomment -%}
  <div class="sh-content-section" data-sh-section="addresses">
    <div class="sh-welcome">
      <div>
        <h1>My addresses</h1>
        <div class="sh-welcome-sub">Manage your shipping and billing addresses</div>
      </div>
    </div>
    <div class="sh-section">
      <div class="sh-section-head">
        <div class="sh-section-title">Saved addresses <span class="sh-count">{{ cust_addresses.size }}</span></div>
        <button class="sh-section-action" id="sh-addr-add-btn" style="background:none;border:none;font-family:inherit;cursor:pointer;color:var(--red);font-weight:600;font-size:12px">Add new &rarr;</button>
      </div>
      <div class="sh-section-body">
        {%- if cust_addresses.size == 0 -%}
          <div class="sh-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--navy)" stroke-width="1.5" width="48" height="48"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <h3>No addresses saved</h3>
            <p>Add your shipping address to speed up checkout.</p>
            <button class="sh-empty-btn" id="sh-addr-add-btn2" style="cursor:pointer;font-family:inherit">Add address &rarr;</button>
          </div>
        {%- else -%}
          <div class="sh-addr-row" style="flex-wrap:wrap">
            {%- for address in cust_addresses -%}
              <div class="sh-addr-item{% if address == cust_default_address %} default{% endif %}" style="min-width:220px">
                {%- if address == cust_default_address -%}
                  <span class="sh-addr-default-badge">Default</span>
                {%- endif -%}
                <div class="sh-addr-type">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {%- if address.company != blank -%}{{ address.company }}{%- else -%}Address {{ forloop.index }}{%- endif -%}
                </div>
                <div class="sh-addr-text">
                  {{ address.first_name }} {{ address.last_name }}<br>
                  {{ address.address1 }}{%- if address.address2 != blank -%}, {{ address.address2 }}{%- endif -%}<br>
                  {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
                  {{ address.country }}<br>
                  {%- if address.phone != blank -%}{{ address.phone }}{%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Inline Add Address Form {%- endcomment -%}
    <div class="sh-section" id="sh-addr-form-wrap" style="display:none">
      <div class="sh-section-head">
        <div class="sh-section-title">Add new address</div>
        <button id="sh-addr-cancel-btn" style="background:none;border:none;font-family:inherit;cursor:pointer;color:#666;font-weight:600;font-size:13px">Cancel</button>
      </div>
      <div class="sh-section-body">
        {% form 'customer_address', customer.new_address %}
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div>
              <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px">First name</label>
              <input type="text" name="address[first_name]" autocomplete="given-name" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;font-family:inherit">
            </div>
            <div>
              <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px">Last name</label>
              <input type="text" name="address[last_name]" autocomplete="family-name" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;font-family:inherit">
            </div>
          </div>
          <div style="margin-top:12px">
            <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px">Company (optional)</label>
            <input type="text" name="address[company]" autocomplete="organization" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;font-family:inherit">
          </div>
          <div style="margin-top:12px">
            <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px">Address</label>
            <input type="text" name="address[address1]" autocomplete="address-line1" required style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;font-family:inherit">
          </div>
          <div style="margin-top:12px">
            <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px">Apartment, suite, etc. (optional)</label>
            <input type="text" name="address[address2]" autocomplete="address-line2" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;font-family:inherit">
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-top:12px">
            <div>
              <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px">City</label>
              <input type="text" name="address[city]" autocomplete="address-level2" required style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;font-family:inherit">
            </div>
            <div>
              <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px">State / Province</label>
              <input type="text" name="address[province]" autocomplete="address-level1" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;font-family:inherit">
            </div>
            <div>
              <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px">ZIP / Postal code</label>
              <input type="text" name="address[zip]" autocomplete="postal-code" required style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;font-family:inherit">
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px">
            <div>
              <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px">Country</label>
              <select name="address[country]" autocomplete="country-name" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;font-family:inherit;background:#fff">
                <option value="United States" selected>United States</option>
                <option value="Canada">Canada</option>
              </select>
            </div>
            <div>
              <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px">Phone (optional)</label>
              <input type="tel" name="address[phone]" autocomplete="tel" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;font-family:inherit">
            </div>
          </div>
          <div style="margin-top:12px">
            <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#555;cursor:pointer">
              <input type="checkbox" name="address[default]" value="1"> Set as default address
            </label>
          </div>
          <div style="display:flex;gap:10px;margin-top:20px">
            <button type="submit" style="padding:10px 24px;background:var(--red);color:#fff;border:none;border-radius:8px;font-size:14px;cursor:pointer;font-family:inherit;font-weight:600">Save address</button>
            <button type="button" id="sh-addr-cancel-btn2" style="padding:10px 20px;background:#f5f5f5;color:#333;border:1px solid #ddd;border-radius:8px;font-size:14px;cursor:pointer;font-family:inherit">Cancel</button>
          </div>
        {% endform %}
      </div>
    </div>
  </div>

  {%- comment -%} === COUPONS === {%- endcomment -%}
  <div class="sh-content-section" data-sh-section="coupons">
    <div class="sh-welcome">
      <div>
