{% comment %}StyleHub Best Sellers Page v1.0 — Sprint 5{% endcomment %}
<div id="dealshub-bestsellers" style="max-width:1280px;margin:0 auto;padding:0 20px 60px">
  <!-- Hero -->
  <div style="background:linear-gradient(135deg,#f59e0b 0%,#d97706 100%);border-radius:16px;padding:40px 32px;color:#fff;text-align:center;margin-bottom:32px">
    <h1 style="font-size:32px;font-weight:800;margin:0 0 8px">\ud83c\udfc6 Best Sellers</h1>
    <p style="font-size:16px;opacity:.9;margin:0">The most popular products customers are buying right now</p>
  </div>
  <!-- Category Tabs -->
  <div id="dh-bs-tabs" style="display:flex;gap:8px;overflow-x:auto;padding-bottom:12px;margin-bottom:24px;-webkit-overflow-scrolling:touch"></div>
  <!-- Skeleton -->
  <div id="dh-bs-skeleton">
    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:16px" class="dh-bs-skel-grid">
      {% for j in (1..10) %}<div style="background:#f0f0f0;border-radius:12px;aspect-ratio:0.75;animation:dhpulse 1.5s infinite"></div>{% endfor %}
    </div>
  </div>
  <!-- Dynamic content -->
  <div id="dh-bs-content"></div>
</div>
<style>
@keyframes dhpulse{0%,100%{opacity:1}50%{opacity:.5}}
@media(max-width:768px){.dh-bs-skel-grid{grid-template-columns:repeat(2,1fr)!important}}
</style>
<script src="{{ 'dealshub-bestsellers-page.js' | asset_url }}" defer></script>
{% schema %}{"name":"StyleHub Best Sellers","tag":"section","settings":[],"presets":[{"name":"StyleHub Best Sellers"}]}{% endschema %}
