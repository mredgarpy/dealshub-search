<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="preconnect" href="https://dealshub-search.onrender.com" crossorigin>
  <link rel="dns-prefetch" href="https://dealshub-search.onrender.com">

  {%- comment -%} SEO Title — unique per template {%- endcomment -%}
  {%- if template == 'index' -%}
    <title>StyleHub Miami | Best Deals on Fashion, Beauty & Electronics | Free Shipping</title>
  {%- elsif template contains 'product' -%}
    <title>{{ product.title | escape }} | ${{ product.price | money_without_currency }} | StyleHub Miami</title>
  {%- elsif template contains 'collection' -%}
    <title>{{ collection.title | escape }} | Shop at StyleHub Miami</title>
  {%- elsif template contains 'article' -%}
    <title>{{ article.title | escape }} | StyleHub Miami Blog</title>
  {%- else -%}
    <title>{{ page_title | escape }}{% unless page_title contains 'StyleHub' %} | StyleHub Miami{% endunless %}</title>
  {%- endif -%}

  {%- comment -%} SEO Meta Tags {%- endcomment -%}
  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- elsif template == 'index' -%}
    <meta name="description" content="Shop millions of products at the best prices. Fashion, beauty, electronics, shoes & more from Amazon, AliExpress & trusted sellers. Free shipping on $35+. Secure checkout. Fast delivery to all 50 US states.">
  {%- else -%}
    <meta name="description" content="StyleHub Miami — Shop the best deals on fashion, beauty, electronics & more. Free shipping on $35+. Secure checkout. 24/7 support.">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} Open Graph Tags {%- endcomment -%}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
  <meta property="og:title" content="{{ page_title | escape }}">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- else -%}
    <meta property="og:description" content="Shop the best deals on fashion, beauty, electronics &amp; more at StyleHub Miami.">
  {%- endif -%}
  <meta property="og:url" content="{{ canonical_url }}">
  {%- if page_image -%}
    <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
  {%- endif -%}

  {%- comment -%} Twitter Card {%- endcomment -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape }}">
  {%- if page_description -%}
    <meta name="twitter:description" content="{{ page_description | escape }}">
  {%- endif -%}

  {{ content_for_header }}
  <style>
    :root{--dh-red:#e53e3e;--dh-dark:#1a1a2e;--dh-bg:#f8f8f8;--dh-card:#fff}
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--dh-bg);color:#333;line-height:1.6}
    a{text-decoration:none;color:inherit}
    img{max-width:100%;height:auto}
    @keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
    .dh-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px}
    @media(max-width:768px){.dh-grid{grid-template-columns:repeat(2,1fr);gap:10px}}
    @media(max-width:480px){.dh-grid{grid-template-columns:repeat(2,1fr);gap:8px}.dh-api-card h3{font-size:11px!important}}
  </style>
  {{ 'stylehub-api.js' | asset_url | script_tag }}

  {%- comment -%} JSON-LD Structured Data — Home {%- endcomment -%}
  {%- if template == 'index' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "StyleHub Miami",
    "url": "https://stylehubmiami.com",
    "description": "Shop millions of products at the best prices. Fashion, beauty, electronics and more from Amazon, AliExpress and trusted sellers.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://stylehubmiami.com/pages/search-results?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "StyleHub Miami",
    "url": "https://stylehubmiami.com",
    "logo": "{{ 'logo.png' | asset_url }}",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "email": "support@stylehubmiami.com",
      "url": "https://stylehubmiami.com/pages/contact-us",
      "availableLanguage": "English"
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Miami",
      "addressRegion": "FL",
      "addressCountry": "US"
    }
  }
  </script>
  {%- endif -%}

  {%- comment -%} JSON-LD Structured Data — Shopify Products {%- endcomment -%}
  {%- if template contains 'product' and product -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "image": [{{ product.featured_image | image_url: width: 1200 | json }}],
    "description": {{ product.description | strip_html | truncate: 300 | default: product.title | json }},
    "sku": {{ product.selected_or_first_available_variant.sku | default: product.id | json }},
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | default: "StyleHub" | json }}
    },
    "offers": {
      "@type": "Offer",
      "url": "{{ canonical_url }}",
      "priceCurrency": "{{ cart.currency.iso_code | default: 'USD' }}",
      "price": "{{ product.selected_or_first_available_variant.price | money_without_currency | remove: ',' }}",
      "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "seller": {
        "@type": "Organization",
        "name": "StyleHub Miami"
      }
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stylehubmiami.com/" },
      {%- if product.collections.size > 0 -%}
      { "@type": "ListItem", "position": 2, "name": {{ product.collections.first.title | json }}, "item": "{{ shop.url }}/collections/{{ product.collections.first.handle }}" },
      { "@type": "ListItem", "position": 3, "name": {{ product.title | truncate: 50 | json }} }
      {%- else -%}
      { "@type": "ListItem", "position": 2, "name": {{ product.title | truncate: 50 | json }} }
      {%- endif -%}
    ]
  }
  </script>
  {%- endif -%}

  {%- comment -%} Google Search Console — Edgar: replace XXXXX with your verification code {%- endcomment -%}
  <!-- <meta name="google-site-verification" content="XXXXX"> -->

  {%- comment -%} StyleHub Plus — Server-side detection via customer tags {%- endcomment -%}
  {%- assign is_plus = false -%}
  {%- if customer -%}
    {%- for tag in customer.tags -%}
      {%- if tag == 'plus' -%}
        {%- assign is_plus = true -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
  <script>
    window.STYLEHUB_PLUS = {{ is_plus | json }};
    window.STYLEHUB_CUSTOMER = {{ customer.id | default: 'null' }};
    window.STYLEHUB_CUSTOMER_EMAIL = {{ customer.email | default: 'null' | json }};
    {% if is_plus %}
      try { localStorage.setItem('stylehub_plus', 'true'); } catch(e) {}
    {% elsif customer %}
      try { localStorage.removeItem('stylehub_plus'); } catch(e) {}
    {% endif %}
  </script>
</head>
<body>
  {% section 'header' %}
  <main>{{ content_for_layout }}</main>
  {% section 'dealshub-trust-section' %}
  {% section 'dealshub-footer' %}
  <script src="{{ 'dealshub-analytics.js' | asset_url }}" defer></script>
  {% render 'cookie-consent' %}
</body>
</html>
