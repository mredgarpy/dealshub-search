# DealsHub Search Backend — Environment Variables
# Copy this file to .env for local development
# In Railway: add these via the Variables panel (never commit real values)

# ── RapidAPI ──────────────────────────────────────────────────────────
# Get your key at https://rapidapi.com → My Apps → Application → Security
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: override the default API hosts if you use different RapidAPI products
# SHEIN_API_HOST=shein-scraper-api.p.rapidapi.com
# AMAZON_API_HOST=real-time-amazon-data.p.rapidapi.com
# SEPHORA_API_HOST=sephora12.p.rapidapi.com
# MACYS_API_HOST=macys-products.p.rapidapi.com

# ── Shopify ───────────────────────────────────────────────────────────
SHOPIFY_STORE=stylehubmiami.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token_here

# ── Pricing ───────────────────────────────────────────────────────────
# Markup percentage added on top of source price
MARKUP_PERCENT=12

# ── Server ────────────────────────────────────────────────────────────
PORT=3001
