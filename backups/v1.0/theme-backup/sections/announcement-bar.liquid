{% if settings.announcement_show %}
<div class="announcement-bar" id="announcement-bar"
  style="--announcement-bg: {{ settings.announcement_bg }}; --announcement-color: {{ settings.announcement_text_color }};"
  data-speed="{{ settings.announcement_speed | default: 4000 }}">
  <div class="announcement-bar__slider">
    {% assign messages = '' | split: '' %}
    {% if settings.announcement_text_1 != blank %}
      {% assign messages = messages | push: settings.announcement_text_1 %}
    {% endif %}
    {% if settings.announcement_text_2 != blank %}
      {% assign messages = messages | push: settings.announcement_text_2 %}
    {% endif %}
    {% if settings.announcement_text_3 != blank %}
      {% assign messages = messages | push: settings.announcement_text_3 %}
    {% endif %}

    {% for msg in messages %}
      <div class="announcement-bar__item{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}">
        {{ msg }}
      </div>
    {% endfor %}
  </div>

  <button class="announcement-bar__close" id="announcement-close" aria-label="Close announcement">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
  </button>
</div>

<script>
(function() {
  const bar = document.getElementById('announcement-bar');
  if (!bar) return;

  // Close button
  const closeBtn = document.getElementById('announcement-close');
  if (closeBtn) {
    closeBtn.addEventListener('click', () => {
      bar.style.display = 'none';
      sessionStorage.setItem('announcementClosed', '1');
    });
  }

  // Check if already closed this session
  if (sessionStorage.getItem('announcementClosed')) {
    bar.style.display = 'none';
    return;
  }

  // Rotate messages
  const items = bar.querySelectorAll('.announcement-bar__item');
  if (items.length <= 1) return;

  let current = 0;
  const speed = parseInt(bar.dataset.speed) || 4000;

  setInterval(() => {
    items[current].classList.remove('is-active');
    items[current].classList.add('is-leaving');
    setTimeout(() => items[current].classList.remove('is-leaving'), 400);

    current = (current + 1) % items.length;
    items[current].classList.add('is-active');
  }, speed);
})();
</script>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [],
  "presets": [{ "name": "Announcement Bar" }]
}
{% endschema %}
