<style>
.dh-footer {
  background: #111;
  color: #ccc;
  padding: 48px 0 0;
  font-size: 0.88rem;
}
.dh-footer-grid {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
}
.dh-footer h4 {
  color: #fff;
  font-size: 1rem;
  font-weight: 700;
  margin: 0 0 16px;
}
.dh-footer a {
  color: #bbb;
  text-decoration: none;
  display: block;
  padding: 4px 0;
  transition: color 0.2s;
}
.dh-footer a:hover {
  color: #E53E3E;
}
.dh-footer-bottom {
  max-width: 1200px;
  margin: 36px auto 0;
  padding: 20px;
  border-top: 1px solid #333;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
}
.dh-footer-bottom p {
  margin: 0;
  font-size: 0.8rem;
  color: #777;
}
.dh-footer-social {
  display: flex;
  gap: 12px;
}
.dh-footer-social a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: #222;
  border-radius: 50%;
  color: #ccc;
  font-size: 1rem;
  transition: all 0.2s;
}
.dh-footer-social a:hover {
  background: #E53E3E;
  color: #fff;
}
.dh-footer-newsletter {
  margin-top: 12px;
}
.dh-footer-newsletter .nl-form {
  display: flex;
  margin-top: 8px;
}
.dh-footer-newsletter input {
  flex: 1;
  padding: 8px 12px;
  border: 1px solid #333;
  border-right: none;
  border-radius: 6px 0 0 6px;
  background: #1a1a1a;
  color: #fff;
  font-size: 0.85rem;
  outline: none;
}
.dh-footer-newsletter button {
  padding: 8px 16px;
  background: #E53E3E;
  color: #fff;
  border: none;
  border-radius: 0 6px 6px 0;
  font-weight: 600;
  cursor: pointer;
  font-size: 0.85rem;
}
@media (max-width: 768px) {
  .dh-footer-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .dh-footer-bottom {
    flex-direction: column;
    text-align: center;
  }
}
</style>

<footer class="dh-footer">
  <div class="dh-footer-grid">
