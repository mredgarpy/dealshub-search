      <a href="/pages/contact-us">Contact Us</a>
      <a href="/pages/faq">FAQ</a>
      <!-- Social links: add real URLs when available -->
      <!-- <div class="dh-footer-social" style="margin-top:16px;">
        <a href="https://instagram.com/stylehubmiami" title="Instagram">IG</a>
        <a href="https://tiktok.com/@stylehubmiami" title="TikTok">TT</a>
