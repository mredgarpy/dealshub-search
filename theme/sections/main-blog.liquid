{% comment %}
  StyleHub Miami — Blog Listing Page
  Displays all articles in a clean grid layout.
{% endcomment %}

<div class="sh-blog">
  <style>
    .sh-blog{max-width:1200px;margin:0 auto;padding:40px 24px 60px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif}
    .sh-blog__header{margin-bottom:32px}
    .sh-blog__breadcrumb{font-size:13px;color:#888;margin-bottom:12px}
    .sh-blog__breadcrumb a{color:#e53e3e;text-decoration:none}
    .sh-blog__breadcrumb a:hover{text-decoration:underline}
    .sh-blog__title{font-size:32px;font-weight:800;color:#1a1a2e;margin:0 0 8px}
    .sh-blog__subtitle{font-size:16px;color:#888;margin:0}
    .sh-blog__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:24px}
    .sh-blog-card{background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.06);transition:transform .2s,box-shadow .2s;text-decoration:none;color:inherit;display:flex;flex-direction:column}
    .sh-blog-card:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.1)}
    .sh-blog-card__image{width:100%;aspect-ratio:16/9;object-fit:cover;background:#f0f0f0}
    .sh-blog-card__image--placeholder{display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1a1a2e,#2d2d52);color:#fff;font-size:28px;font-weight:800;letter-spacing:.05em}
    .sh-blog-card__body{padding:20px;flex:1;display:flex;flex-direction:column}
    .sh-blog-card__tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px}
    .sh-blog-card__tag{background:#f0f0f0;color:#666;padding:3px 10px;border-radius:16px;font-size:11px;text-transform:uppercase;letter-spacing:.03em}
    .sh-blog-card__title{font-size:20px;font-weight:700;color:#1a1a2e;line-height:1.3;margin:0 0 8px}
    .sh-blog-card__excerpt{font-size:14px;color:#666;line-height:1.6;margin:0 0 16px;flex:1}
    .sh-blog-card__meta{font-size:13px;color:#999;display:flex;gap:12px;align-items:center}
    .sh-blog-card__author{font-weight:600;color:#555}
    .sh-blog__pagination{margin-top:40px;display:flex;justify-content:center;gap:8px}
    .sh-blog__pagination a,.sh-blog__pagination span{padding:8px 16px;border-radius:6px;font-size:14px;font-weight:600;text-decoration:none}
    .sh-blog__pagination a{background:#f0f0f0;color:#333;transition:background .2s}
    .sh-blog__pagination a:hover{background:#e53e3e;color:#fff}
    .sh-blog__pagination span.current{background:#e53e3e;color:#fff}
    .sh-blog__empty{text-align:center;padding:60px 24px;color:#888;font-size:16px}
    @media(max-width:600px){
      .sh-blog{padding:24px 16px 40px}
      .sh-blog__title{font-size:24px}
      .sh-blog__grid{grid-template-columns:1fr;gap:16px}
    }
  </style>

  <div class="sh-blog__header">
    <nav class="sh-blog__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> &rsaquo; <span>{{ blog.title }}</span>
    </nav>
    <h1 class="sh-blog__title">{{ blog.title }}</h1>
    <p class="sh-blog__subtitle">Tips, trends, and guides to help you shop smarter.</p>
  </div>

  {%- paginate blog.articles by 12 -%}
    {%- if blog.articles.size > 0 -%}
      <div class="sh-blog__grid">
        {%- for article in blog.articles -%}
          <a href="{{ article.url }}" class="sh-blog-card">
            {%- if article.image -%}
              <img class="sh-blog-card__image" src="{{ article.image | image_url: width: 720 }}" alt="{{ article.image.alt | default: article.title | escape }}" loading="lazy">
            {%- else -%}
              <div class="sh-blog-card__image sh-blog-card__image--placeholder">SH</div>
            {%- endif -%}
            <div class="sh-blog-card__body">
              {%- if article.tags.size > 0 -%}
                <div class="sh-blog-card__tags">
                  {%- for tag in article.tags limit: 3 -%}
                    <span class="sh-blog-card__tag">{{ tag }}</span>
                  {%- endfor -%}
                </div>
              {%- endif -%}
              <h2 class="sh-blog-card__title">{{ article.title }}</h2>
              <p class="sh-blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
              <div class="sh-blog-card__meta">
                {%- if article.author -%}
                  <span class="sh-blog-card__author">{{ article.author }}</span>
                {%- endif -%}
                <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time>
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="sh-blog__pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}">&laquo; Prev</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {%- else -%}
              <span class="current">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}">Next &raquo;</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="sh-blog__empty">
        <p>No articles yet. Check back soon for tips, trends, and guides!</p>
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Blog Listing",
  "tag": "section",
  "class": "sh-blog-section",
  "settings": []
}
{% endschema %}
