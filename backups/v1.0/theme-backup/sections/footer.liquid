  </div>
  <div class="dh-footer-bottom">
    <p>© {{ 'now' | date: '%Y' }} STYLEHUB MIAMI. All rights reserved.</p>
    <p>Powered by Shopify • Miami, FL</p>
  </div>
</footer>

<script>
(function(){
  var form = document.getElementById('dh-footer-newsletter');
  if(!form) return;
  form.addEventListener('submit', function(e){
    e.preventDefault();
    var input = form.querySelector('input[type="email"]');
    var btn   = form.querySelector('button');
    var email = (input.value || '').trim();
    if(!email) return;
    btn.disabled = true;
    btn.textContent = '...';
    fetch('https://dealshub-search.onrender.com/api/newsletter-subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email })
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      btn.textContent = '\u2713';
      btn.style.background = '#22c55e';
      input.value = '';
      input.placeholder = (data && data.message) ? data.message : 'Subscribed!';
    })
    .catch(function(){
      btn.textContent = '\u2717';
      btn.style.background = '#ef4444';
      setTimeout(function(){ btn.textContent = 'OK'; btn.style.background = '#E53E3E'; btn.disabled = false; }, 2500);
    })
    .finally(function(){
      setTimeout(function(){
        btn.textContent = 'OK';
        btn.style.background = '#E53E3E';
        btn.disabled = false;
        input.placeholder = 'Your email...';
      }, 3000);
    });
  });
})();
</script>

