<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; background: #1a1a2e; color: #fff; min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 24px; }
    .pw-card { max-width: 480px; }
    .pw-logo { font-size: 2rem; font-weight: 900; margin-bottom: 16px; background: linear-gradient(135deg, #FF6B35, #FFD700); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    h1 { font-size: 1.6rem; margin-bottom: 12px; }
    p { color: rgba(255,255,255,.65); margin-bottom: 28px; font-size: .95rem; line-height: 1.6; }
    .pw-form { display: flex; gap: 0; border-radius: 40px; overflow: hidden; border: 1.5px solid rgba(255,255,255,.2); margin-bottom: 16px; }
    .pw-input { flex: 1; background: none; border: none; outline: none; padding: 13px 20px; color: #fff; font-size: .9rem; }
    .pw-input::placeholder { color: rgba(255,255,255,.4); }
    .pw-btn { background: #FF6B35; border: none; padding: 13px 24px; color: #fff; font-weight: 700; cursor: pointer; }
    .pw-error { color: #FF6B35; font-size: .82rem; }
    a { color: #FF6B35; }
  </style>
  {{ content_for_header }}
</head>
<body>
  <div class="pw-card">
    <div class="pw-logo">{{ shop.name }}</div>
    <h1>{{ 'general.password_page.coming_soon' | t }}</h1>
    <p>We're busy building something amazing. Enter the password to get early access!</p>

    {%- form 'storefront_password', id: 'login-form' -%}
      {%- if form.errors -%}
        <p class="pw-error">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="pw-form">
        <input type="password" name="password" class="pw-input" placeholder="Enter password..." autocomplete="current-password" required>
        <button type="submit" class="pw-btn">Enter</button>
      </div>
    {%- endform -%}

    <p style="font-size:.78rem;opacity:.5;">© {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
  </div>
  {{ content_for_layout }}
</body>
</html>
