{% comment %}StyleHub Header v7 - Custom Account Dashboard{% endcomment %}
<style>
.dh-announce{background:#1a1a2e;color:rgba(255,255,255,0.7);padding:6px 0;font-size:12px;overflow:hidden;white-space:nowrap}
.dh-announce-track{display:inline-block;animation:announceScroll 25s linear infinite}
@keyframes announceScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.dh-header{background:#1a1a2e;padding:14px 32px;display:flex;align-items:center;gap:24px;position:sticky;top:0;z-index:100;justify-content:center}
.dh-logo{font-size:22px;font-weight:800;color:#fff;white-space:nowrap;text-decoration:none;flex-shrink:0}
.dh-search-wrap{flex:1;max-width:720px;position:relative}
.dh-search-form{display:flex;border-radius:8px;overflow:hidden;background:#fff;height:42px}
.dh-search-cat{background:#f0f0f0;border:none;padding:0 14px;font-size:13px;color:#333;cursor:pointer;border-right:1px solid #ddd;white-space:nowrap;font-weight:500}
.dh-search-input{flex:1;border:none;padding:0 16px;font-size:14px;outline:none;min-width:0;background:#fff}
.dh-search-btn{background:#e53e3e;border:none;padding:0 28px;cursor:pointer;color:#fff;font-size:14px;font-weight:700;white-space:nowrap}
.dh-search-results{position:absolute;top:100%;left:0;right:0;background:#fff;border-radius:0 0 12px 12px;box-shadow:0 12px 40px rgba(0,0,0,.2);max-height:70vh;overflow-y:auto;z-index:200;display:none}
.dh-search-results.active{display:block}
.dh-sr-item{display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid #f0f0f0;transition:background .15s;cursor:pointer;text-decoration:none;color:inherit}
.dh-sr-item:hover{background:#f7f7f7}
.dh-sr-img{width:44px;height:44px;border-radius:6px;object-fit:contain;background:#fafafa;flex-shrink:0}
.dh-sr-info{flex:1;min-width:0}
.dh-sr-title{font-size:13px;color:#333;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.dh-sr-price{font-size:13px;font-weight:700;color:#e53e3e}
.dh-sr-orig{font-size:11px;color:#999;text-decoration:line-through;margin-left:4px}
.dh-sr-source{font-size:9px;background:#1a1a2e;color:#fff;padding:1px 6px;border-radius:3px;text-transform:uppercase}
.dh-nav{display:flex;align-items:center;gap:24px;flex-shrink:0}
.dh-nav-item{display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;color:rgba(255,255,255,0.8);font-size:11px;white-space:nowrap;transition:color .2s}
.dh-nav-item:hover{color:#fff}
.dh-nav-icon{font-size:20px}
.dh-cart-badge{position:relative}
.dh-cart-count{position:absolute;top:-6px;right:-8px;background:#e53e3e;color:#fff;font-size:9px;font-weight:700;border-radius:50%;width:16px;height:16px;display:flex;align-items:center;justify-content:center}
.dh-catbar{background:#fff;border-bottom:1px solid #eee;overflow-x:auto;scrollbar-width:none;-ms-overflow-style:none;white-space:nowrap;padding:0 32px}
.dh-catbar::-webkit-scrollbar{display:none}
.dh-catbar-inner{display:flex;gap:0;justify-content:center;max-width:1280px;margin:0 auto}
.dh-catbar-item{padding:10px 16px;font-size:13px;color:#666;text-decoration:none;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap;font-weight:500}
.dh-catbar-item:hover{color:#1a1a2e}
.dh-catbar-item.active{color:#e53e3e;border-bottom-color:#e53e3e;font-weight:600}
.dh-catbar-item.flash{color:#e53e3e;font-weight:600}
@media(max-width:768px){
  .dh-header{padding:10px 12px;gap:8px}
  .dh-search-cat{display:none}
  .dh-nav{gap:12px}
  .dh-nav-item span:last-child{display:none}
  .dh-logo{font-size:16px}
  .dh-catbar{padding:0 12px}
  .dh-catbar-item{padding:8px 12px;font-size:12px}
}
</style>

<!-- Announcement Bar -->
<div class="dh-announce">
  <div class="dh-announce-track">
    <span style="margin:0 32px">Free shipping on $50+</span>
    <span style="margin:0 32px">Secure checkout</span>
    <span style="margin:0 32px">24/7 support</span>
    <span style="margin:0 32px">Track your order</span>
    <span style="margin:0 32px">Free shipping on $50+</span>
    <span style="margin:0 32px">Secure checkout</span>
    <span style="margin:0 32px">24/7 support</span>
    <span style="margin:0 32px">Track your order</span>
  </div>
</div>

<!-- Main Header -->
<header class="dh-header">
  <a href="/" class="dh-logo">StyleHub</a>

  <div class="dh-search-wrap">
    <form class="dh-search-form" action="/pages/search-results" method="get" id="dh-search-form">
      <select class="dh-search-cat" name="category" id="dh-search-category">
        <option value="">All categories</option>
        <option value="women fashion">Women's fashion</option>
        <option value="men fashion">Men's fashion</option>
        <option value="beauty">Beauty</option>
        <option value="skincare">Skincare</option>
        <option value="electronics">Electronics</option>
        <option value="phones">Phones</option>
        <option value="home garden">Home & garden</option>
        <option value="sports">Sports</option>
        <option value="kids">Kids</option>
        <option value="shoes">Shoes</option>
        <option value="accessories">Accessories</option>
        <option value="bags">Bags</option>
        <option value="jewelry">Jewelry</option>
      </select>
      <input type="text" class="dh-search-input" name="q" placeholder="Search products, brands, deals..." autocomplete="off" id="dh-search-input">
      <button type="submit" class="dh-search-btn">Search</button>
    </form>
    <div class="dh-search-results" id="dh-search-results"></div>
  </div>

  <nav class="dh-nav">
    {%- if customer -%}
    <a href="/pages/my-account" class="dh-nav-item">
      <span class="dh-nav-icon">👤</span>
      <span>Account</span>
    </a>
    <a href="/pages/my-account" class="dh-nav-item">
      <span class="dh-nav-icon">📦</span>
      <span>Orders</span>
    </a>
    {%- else -%}
    <a href="/pages/my-account" class="dh-nav-item">
      <span class="dh-nav-icon">👤</span>
      <span>Account</span>
    </a>
    <a href="/pages/my-account" class="dh-nav-item">
      <span class="dh-nav-icon">📦</span>
      <span>Orders</span>
    </a>
    {%- endif -%}
    <a href="/pages/wishlist" class="dh-nav-item">
      <span class="dh-nav-icon">♡</span>
      <span>Wishlist</span>
    </a>
    <a href="/cart" class="dh-nav-item">
      <span class="dh-nav-icon dh-cart-badge">🛒<span class="dh-cart-count" id="dh-cart-count">{{ cart.item_count }}</span></span>
      <span>Cart</span>
    </a>
  </nav>
</header>

<!-- Category Bar -->
<div class="dh-catbar">
  <div class="dh-catbar-inner">
    <a href="/pages/search-results?q=trending" class="dh-catbar-item active">All</a>
    <a href="/pages/search-results?q=women+fashion" class="dh-catbar-item">Women's fashion</a>
    <a href="/pages/search-results?q=men+fashion" class="dh-catbar-item">Men's fashion</a>
    <a href="/pages/search-results?q=beauty" class="dh-catbar-item">Beauty</a>
    <a href="/pages/search-results?q=skincare" class="dh-catbar-item">Skincare</a>
    <a href="/pages/search-results?q=electronics" class="dh-catbar-item">Electronics</a>
    <a href="/pages/search-results?q=phones" class="dh-catbar-item">Phones</a>
    <a href="/pages/search-results?q=home+garden" class="dh-catbar-item">Home & garden</a>
    <a href="/pages/search-results?q=sports" class="dh-catbar-item">Sports</a>
    <a href="/pages/search-results?q=kids" class="dh-catbar-item">Kids</a>
    <a href="/pages/search-results?q=shoes" class="dh-catbar-item">Shoes</a>
    <a href="/pages/search-results?q=accessories" class="dh-catbar-item">Accessories</a>
    <a href="/pages/search-results?q=bags" class="dh-catbar-item">Bags</a>
    <a href="/pages/search-results?q=jewelry" class="dh-catbar-item">Jewelry</a>
    <a href="/pages/search-results?q=deals" class="dh-catbar-item flash">Flash deals</a>
  </div>
</div>

<script src="{{ 'header.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "StyleHub Header",
  "class": "dh-header-section",
  "settings": []
}
{% endschema %}

