{%- liquid
  assign collection_handle = section.settings.collection | default: 'all'
  assign coll = collections[collection_handle]
  assign limit = section.settings.limit | default: 8
  assign seen_titles = ''
-%}

<section class="product-grid-section" style="padding:40px 0;">
  <div style="max-width:1400px;margin:0 auto;padding:0 20px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:24px;">
      <div>
        <h2 style="font-size:28px;font-weight:800;margin:0;">{{ section.settings.title | default: 'Featured Products' }}</h2>
        <div style="width:40px;height:3px;background:#e74c3c;margin-top:8px;"></div>
        {% if section.settings.subtitle != blank %}
          <p style="color:#666;margin-top:8px;">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
      {% if section.settings.link_text != blank %}
        <a href="{{ section.settings.link_url | default: '/collections/all' }}" style="color:#e74c3c;font-weight:600;text-decoration:none;">{{ section.settings.link_text }} &rarr;</a>
      {% endif %}
    </div>

    {% if coll.products.size > 0 %}
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;">
        {%- assign rendered = 0 -%}
        {% for product in coll.products limit: 50 %}
          {%- if rendered >= limit -%}{%- break -%}{%- endif -%}

          {%- comment -%}Fix #8: skip test products{%- endcomment -%}
          {%- assign title_lower = product.title | downcase -%}
          {%- if title_lower contains 'test product' or title_lower contains 'checkout flow' -%}{%- continue -%}{%- endif -%}

          {%- comment -%}Fix #7: dedup by title{%- endcomment -%}
          {%- assign dedup_key = product.title | handleize -%}
          {%- if seen_titles contains dedup_key -%}{%- continue -%}{%- endif -%}
          {%- assign seen_titles = seen_titles | append: dedup_key | append: '|' -%}

          {%- assign rendered = rendered | plus: 1 -%}

          <div style="background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06);transition:transform .2s,box-shadow .2s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.12)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'">
            <a href="{{ product.url }}" style="display:block;text-decoration:none;color:inherit;">
              <div style="position:relative;padding-top:100%;background:#f5f5f5;overflow:hidden;">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;transition:transform .3s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform=''">
                {% else %}
                  <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:48px;">&#x1F6CD;</div>
                {% endif %}

                {%- comment -%}Fix #9: Discount badge{%- endcomment -%}
                {% if product.compare_at_price > product.price %}
                  {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                  <span style="position:absolute;top:10px;left:10px;background:#e74c3c;color:#fff;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;">-{{ discount }}%</span>
                {% endif %}

                {%- comment -%}Fix #9: Vendor/source badge{%- endcomment -%}
                {% if product.vendor != blank and product.vendor != shop.name %}
                  <span style="position:absolute;top:10px;right:10px;background:rgba(0,0,0,0.7);color:#fff;padding:3px 8px;border-radius:4px;font-size:10px;font-weight:600;">{{ product.vendor }}</span>
                {% endif %}

                {%- comment -%}Wishlist heart button{%- endcomment -%}
                <button onclick="event.preventDefault();event.stopPropagation();toggleWishlist('{{ product.id }}','{{ product.title | escape }}')" style="position:absolute;bottom:10px;right:10px;width:32px;height:32px;border-radius:50%;background:#fff;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 6px rgba(0,0,0,0.15);font-size:16px;opacity:0;transition:opacity .2s;" class="wishlist-btn">&#x2661;</button>
              </div>
            </a>
            <div style="padding:14px;">
              <h3 style="font-size:13px;font-weight:600;margin:0;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:34px;">
                <a href="{{ product.url }}" style="text-decoration:none;color:inherit;">{{ product.title }}</a>
              </h3>

              {%- comment -%}Fix #9: Price with compare_at{%- endcomment -%}
              <div style="margin-top:8px;display:flex;align-items:center;gap:8px;">
                <span style="font-size:17px;font-weight:700;color:#e74c3c;">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span style="font-size:12px;color:#999;text-decoration:line-through;">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>

              {%- comment -%}Fix #9: Add to Cart button{%- endcomment -%}
              <form action="/cart/add" method="post" style="margin-top:10px;">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                <input type="hidden" name="quantity" value="1">
                <button type="submit" style="width:100%;padding:10px;background:#000;color:#fff;border:none;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer;transition:background .2s;" onmouseover="this.style.background='#e74c3c'" onmouseout="this.style.background='#000'">Add to Cart</button>
              </form>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p style="text-align:center;color:#999;padding:40px 0;">No products found. Add products to "{{ collection_handle }}" to display them here.</p>
    {% endif %}
  </div>
</section>

<style>
  .product-grid-section div:hover .wishlist-btn { opacity:1 !important; }
  @media(max-width:768px) {
    .product-grid-section div[style*="grid-template-columns"] { grid-template-columns: repeat(2, 1fr) !important; gap: 12px !important; }
  }
</style>

<script>
function toggleWishlist(id, title) {
  try {
    var wl = JSON.parse(localStorage.getItem('stylehub_wishlist') || '[]');
    var idx = wl.findIndex(function(x){return x.id === id});
    if (idx > -1) { wl.splice(idx, 1); } else { wl.push({id:id, title:title}); }
    localStorage.setItem('stylehub_wishlist', JSON.stringify(wl));
    var badge = document.getElementById('wishlist-count');
    if (badge) { badge.style.display = wl.length > 0 ? 'flex' : 'none'; badge.textContent = wl.length; }
  } catch(e){}
}
</script>

{% schema %}
{
  "name": "Product Grid",
  "settings": [
    {"type":"text","id":"title","label":"Title","default":"Featured Products"},
    {"type":"text","id":"subtitle","label":"Subtitle"},
    {"type":"collection","id":"collection","label":"Collection"},
    {"type":"range","id":"limit","min":4,"max":16,"step":4,"default":8,"label":"Products to show"},
    {"type":"text","id":"link_text","label":"Link text"},
    {"type":"url","id":"link_url","label":"Link URL"}
  ],
  "presets": [
    {"name":"Fashion Grid","settings":{"title":"Fashion & Style","subtitle":"Trendy clothing, shoes & accessories","collection":"all","limit":8,"link_text":"View All Fashion"}},
    {"name":"Beauty Grid","settings":{"title":"Beauty & Health","subtitle":"Skincare, makeup & wellness deals","collection":"all","limit":8,"link_text":"View All Beauty"}},
    {"name":"Electronics Grid","settings":{"title":"Electronics & Gadgets","subtitle":"Latest tech at the best prices","collection":"all","limit":8,"link_text":"View All Electronics"}},
    {"name":"Home Grid","settings":{"title":"Home & Kitchen","subtitle":"Everything for your home","collection":"all","limit":8,"link_text":"View All Home"}}
  ]
}
{% endschema %}