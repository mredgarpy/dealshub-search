{% comment %}
  Renders a native Shopify product card (for Shopify collections/products)
  Parameters:
  - product: Shopify product object
  - show_badge: boolean (default true)
  - show_rating: boolean (default true)
  - show_source: boolean (default true)
{% endcomment %}

{%- liquid
  assign show_badge  = show_badge  | default: settings.card_show_badge,  allow_false: true
  assign show_rating = show_rating | default: settings.card_show_rating, allow_false: true
  assign show_source = show_source | default: settings.card_show_source, allow_false: true
  assign show_savings = show_savings | default: settings.card_show_savings, allow_false: true
  assign img_ratio   = settings.card_image_ratio | default: 'portrait'

  assign current_price    = product.price    | money
  assign compare_price    = product.compare_at_price | money
  assign has_discount     = false
  if product.compare_at_price > product.price
    assign has_discount = true
    assign savings_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | floor
  endif

  assign source = product.metafields.dealshub.source | default: ''
  assign source_name = product.metafields.dealshub.source_name | default: source
-%}

<article class="product-card" data-product-id="{{ product.id }}" data-source="{{ source }}">

  <!-- Image -->
  <div class="product-card__media ratio--{{ img_ratio }}">
    {%- if product.featured_image -%}
      <img class="product-card__img"
           src="{{ product.featured_image | image_url: width: 500 }}"
           alt="{{ product.featured_image.alt | escape | default: product.title }}"
           loading="lazy"
           width="500"
           height="{% if img_ratio == 'portrait' %}667{% elsif img_ratio == 'landscape' %}375{% else %}500{% endif %}">
    {%- else -%}
      <div class="product-card__img-placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    {%- endif -%}

    <!-- Badges -->
    {%- if show_badge -%}
    <div class="product-card__badges">
      {%- if has_discount -%}
        <span class="badge badge--sale">{{ savings_pct }}% OFF</span>
      {%- endif -%}
      {%- if product.tags contains 'flash-deal' or product.tags contains 'flash_deal' -%}
        <span class="badge badge--flash">⚡ FLASH</span>
      {%- endif -%}
      {%- if product.tags contains 'new' or product.tags contains 'new-arrival' -%}
        <span class="badge badge--new">NEW</span>
      {%- endif -%}
    </div>
    {%- endif -%}

    <!-- Action buttons -->
    <div class="product-card__actions">
      {%- if settings.card_wishlist_btn -%}
      <button class="product-card__action-btn wishlist-btn"
        data-id="{{ product.id }}"
        data-title="{{ product.title | escape }}"
        data-image="{{ product.featured_image | image_url: width: 300 }}"
        data-price="{{ product.price | divided_by: 100.0 }}"
        data-url="{{ product.url }}"
        data-source="{{ source }}"
        aria-label="Add to wishlist">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </button>
      {%- endif -%}

      {%- if settings.card_quick_view -%}
      <button class="product-card__action-btn"
        onclick="window.location.href='{{ product.url }}'"
        aria-label="Quick view">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </button>
      {%- endif -%}
    </div>

    <!-- Source badge -->
    {%- if show_source and source != blank -%}
    <div class="product-card__source-badge source-badge--{{ source }}">{{ source_name }}</div>
    {%- endif -%}
  </div>

  <!-- Body -->
  <div class="product-card__body">
    <h3 class="product-card__title">
      <a href="{{ product.url }}" title="{{ product.title | escape }}">{{ product.title | truncate: 80 }}</a>
    </h3>

    {%- if show_rating -%}
      {%- assign rating = product.metafields.reviews.rating.value -%}
      {%- assign rating_count = product.metafields.reviews.rating_count.value -%}
      {%- if rating -%}
      <div class="product-card__rating">
        <span class="stars" aria-label="{{ rating }} stars">
          {%- for i in (1..5) -%}
            {%- if i <= rating -%}★{%- else -%}☆{%- endif -%}
          {%- endfor -%}
        </span>
        {%- if rating_count -%}
        <span class="product-card__reviews">({{ rating_count }})</span>
        {%- endif -%}
      </div>
      {%- endif -%}
    {%- endif -%}

    <div class="product-card__pricing">
      <span class="product-card__price">{{ current_price }}</span>
      {%- if has_discount -%}
        <span class="product-card__original-price">{{ compare_price }}</span>
        {%- if show_savings -%}
          <span class="product-card__savings">-{{ savings_pct }}%</span>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  <!-- CTA -->
  <div class="product-card__footer">
    {%- if product.available -%}
      <a href="{{ product.url }}" class="product-card__cta btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        View Deal
      </a>
    {%- else -%}
      <button class="btn btn--ghost btn--full" disabled>Sold Out</button>
    {%- endif -%}
  </div>

</article>
