{% comment %}
  StyleHub Customer Account Dashboard
  URL: /pages/mi-cuenta
  Tabs: My Orders, Mi Wishlist, My Addresses, Seguridad
{% endcomment %}

<style>
.dh-account {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px 16px 60px;
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 24px;
  min-height: 60vh;
}
.dh-account-sidebar {
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  padding: 24px 0;
  height: fit-content;
  position: sticky;
  top: 20px;
}
.dh-account-avatar {
  text-align: center;
  padding: 0 20px 20px;
  border-bottom: 1px solid #f0f0f0;
}
.dh-account-avatar .avatar-circle {
  width: 72px;
  height: 72px;
  background: linear-gradient(135deg, #ff6b35, #ff8f65);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10px;
  font-size: 1.8rem;
  color: #fff;
  font-weight: 700;
}
.dh-account-avatar h3 {
  font-size: 1rem;
  color: #333;
  margin: 0;
}
.dh-account-avatar p {
  font-size: 0.8rem;
  color: #999;
  margin: 4px 0 0;
}
.dh-sidebar-nav {
  padding: 12px 0;
  list-style: none;
  margin: 0;
}
.dh-sidebar-nav li {
  padding: 0;
}
.dh-sidebar-nav a {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 24px;
  color: #555;
  text-decoration: none;
  font-size: 0.92rem;
  font-weight: 500;
  transition: all 0.2s;
  border-left: 3px solid transparent;
}
.dh-sidebar-nav a:hover {
  background: #fff5f0;
  color: #ff6b35;
}
.dh-sidebar-nav a.active {
  background: #fff5f0;
  color: #ff6b35;
  border-left-color: #ff6b35;
  font-weight: 600;
}
.dh-sidebar-nav .nav-icon {
  font-size: 1.1rem;
}
.dh-account-main {
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  padding: 28px;
}
.dh-tab-content { display: none; }
.dh-tab-content.active { display: block; }
.dh-tab-content h2 {
  font-size: 1.3rem;
  font-weight: 700;
  color: #111;
  margin: 0 0 20px;
}
/* Orders tab */
.dh-order-card {
  border: 1px solid #eee;
  border-radius: 10px;
  padding: 16px;
  margin-bottom: 12px;
  transition: box-shadow 0.2s;
}
.dh-order-card:hover {
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.dh-order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.dh-order-id {
  font-weight: 600;
  color: #333;
}
.dh-order-status {
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 0.75rem;
  font-weight: 600;
}
.dh-order-status.delivered { background: #e6f9e6; color: #1a8c1a; }
.dh-order-status.transit { background: #fff3e0; color: #e67e00; }
.dh-order-status.processing { background: #e3f2fd; color: #1565c0; }
.dh-order-items {
  display: flex;
  gap: 10px;
  align-items: center;
}
.dh-order-thumb {
  width: 50px;
  height: 50px;
  object-fit: cover;
  border-radius: 6px;
  background: #f5f5f5;
}
.dh-order-info {
  flex: 1;
}
.dh-order-info .title {
  font-weight: 500;
  font-size: 0.9rem;
  color: #333;
}
.dh-order-info .date {
  font-size: 0.8rem;
  color: #999;
}
.dh-order-price {
  font-weight: 700;
  color: #ff6b35;
  font-size: 1rem;
}
/* Wishlist tab */
.dh-wishlist-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}
.dh-wish-card {
  border: 1px solid #eee;
  border-radius: 10px;
  overflow: hidden;
  transition: box-shadow 0.2s;
}
.dh-wish-card:hover {
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.dh-wish-img {
  width: 100%;
  height: 140px;
  object-fit: cover;
  background: #f5f5f5;
}
.dh-wish-info {
  padding: 10px;
}
.dh-wish-info .title {
  font-size: 0.85rem;
  font-weight: 500;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.dh-wish-info .price {
  font-weight: 700;
  color: #ff6b35;
  margin-top: 4px;
}
.dh-wish-actions {
  display: flex;
  gap: 6px;
  padding: 0 10px 10px;
}
.dh-wish-actions button {
  flex: 1;
  padding: 6px;
  border-radius: 6px;
  font-size: 0.78rem;
  cursor: pointer;
  font-weight: 500;
  border: 1px solid #ddd;
  background: #fff;
  transition: all 0.2s;
}
.dh-wish-actions .view-btn {
  background: #ff6b35;
  color: #fff;
  border-color: #ff6b35;
}
.dh-wish-actions .remove-btn:hover {
  background: #fee;
  color: #c00;
  border-color: #c00;
}
/* Address tab */
.dh-address-card {
  border: 1px solid #eee;
  border-radius: 10px;
  padding: 16px;
  margin-bottom: 12px;
}
.dh-address-card h4 {
  font-size: 0.95rem;
  margin: 0 0 6px;
}
.dh-address-card p {
  font-size: 0.85rem;
  color: #666;
  margin: 2px 0;
}
.dh-add-btn {
  padding: 10px 24px;
  background: #ff6b35;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  margin-top: 12px;
}
/* Security tab */
.dh-form-group {
  margin-bottom: 16px;
}
.dh-form-group label {
  display: block;
  font-size: 0.85rem;
  font-weight: 600;
  color: #333;
  margin-bottom: 6px;
}
.dh-form-group input {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 0.9rem;
  box-sizing: border-box;
}
.dh-form-group input:focus {
  outline: none;
  border-color: #ff6b35;
}
.dh-save-btn {
  padding: 10px 30px;
  background: #ff6b35;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
}
.dh-empty-state {
  text-align: center;
  padding: 40px 20px;
  color: #999;
}
.dh-empty-state .icon {
  font-size: 2.5rem;
  margin-bottom: 10px;
}

@media (max-width: 768px) {
  .dh-account {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .dh-account-sidebar {
    position: static;
  }
  .dh-sidebar-nav {
    display: flex;
    overflow-x: auto;
    padding: 8px 12px;
    gap: 4px;
  }
  .dh-sidebar-nav a {
    padding: 8px 14px;
    white-space: nowrap;
    border-left: none;
    border-radius: 20px;
    font-size: 0.82rem;
  }
  .dh-sidebar-nav a.active {
    border-left: none;
    background: #ff6b35;
    color: #fff;
  }
  .dh-account-avatar {
    display: flex;
    align-items: center;
    gap: 12px;
    text-align: left;
    padding: 0 16px 12px;
  }
  .dh-account-avatar .avatar-circle {
    width: 48px;
    height: 48px;
    font-size: 1.2rem;
    margin: 0;
  }
  .dh-wishlist-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .dh-account-main {
    padding: 16px;
  }
}
</style>

<div class="dh-account">
  <aside class="dh-account-sidebar">
    <div class="dh-account-avatar">
      <div class="avatar-circle" id="acct-avatar">S</div>
      <div>
        <h3 id="acct-name">StyleHub User</h3>
        <p id="acct-email">usuario@email.com</p>
      </div>
    </div>
    <ul class="dh-sidebar-nav">
      <li><a href="#orders" class="active" data-tab="orders"><span class="nav-icon">📦</span> My Orders</a></li>
      <li><a href="#wishlist" data-tab="wishlist"><span class="nav-icon">❤️</span> Mi Wishlist</a></li>
      <li><a href="#addresses" data-tab="addresses"><span class="nav-icon">📍</span> My Addresses</a></li>
      <li><a href="#security" data-tab="security"><span class="nav-icon">🔒</span> Seguridad</a></li>
    </ul>
  </aside>

  <main class="dh-account-main">
    <!-- Orders Tab -->
    <div class="dh-tab-content active" id="tab-orders">
      <h2>📦 My Orders</h2>
      <div id="orders-list"></div>
    </div>
    
    <!-- Wishlist Tab -->
    <div class="dh-tab-content" id="tab-wishlist">
      <h2>❤️ Mi Wishlist</h2>
      <div id="wishlist-grid" class="dh-wishlist-grid"></div>
    </div>
    
    <!-- Addresses Tab -->
    <div class="dh-tab-content" id="tab-addresses">
      <h2>📍 My Addresses</h2>
      <div id="addresses-list"></div>
      <button class="dh-add-btn" onclick="document.getElementById('addr-form').style.display='block'">+ Add Dirección</button>
      <div id="addr-form" style="display:none;margin-top:16px;padding:16px;border:1px solid #eee;border-radius:10px;">
        <div class="dh-form-group"><label>Nombre completo</label><input type="text" id="addr-name" placeholder="Tu nombre"></div>
        <div class="dh-form-group"><label>Dirección</label><input type="text" id="addr-line" placeholder="Calle, número, apto"></div>
        <div class="dh-form-group"><label>Ciudad</label><input type="text" id="addr-city" placeholder="Ciudad"></div>
        <div class="dh-form-group"><label>País</label><input type="text" id="addr-country" placeholder="País"></div>
        <div class="dh-form-group"><label>Teléfono</label><input type="text" id="addr-phone" placeholder="+1 (555) 000-0000"></div>
        <button class="dh-save-btn" id="save-addr-btn">Guardar Dirección</button>
      </div>
    </div>
    
    <!-- Security Tab -->
    <div class="dh-tab-content" id="tab-security">
      <h2>🔒 Seguridad</h2>
      <div class="dh-form-group"><label>Email actual</label><input type="email" id="sec-email" placeholder="tu@email.com"></div>
      <div class="dh-form-group"><label>Contraseña actual</label><input type="password" id="sec-current-pw" placeholder="••••••••"></div>
      <div class="dh-form-group"><label>Nueva contraseña</label><input type="password" id="sec-new-pw" placeholder="Mínimo 8 caracteres"></div>
      <div class="dh-form-group"><label>Confirmar contraseña</label><input type="password" id="sec-confirm-pw" placeholder="Repite la contraseña"></div>
      <button class="dh-save-btn" id="save-security-btn">Actualizar Seguridad</button>
    </div>
  </main>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Tab navigation
  document.querySelectorAll('.dh-sidebar-nav a').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      document.querySelectorAll('.dh-sidebar-nav a').forEach(function(l) { l.classList.remove('active'); });
      document.querySelectorAll('.dh-tab-content').forEach(function(t) { t.classList.remove('active'); });
      link.classList.add('active');
      var tab = link.dataset.tab;
      document.getElementById('tab-' + tab).classList.add('active');
      if (tab === 'wishlist') loadWishlist();
    });
  });

  // Check hash
  var hash = window.location.hash.replace('#', '');
  if (hash && document.getElementById('tab-' + hash)) {
    document.querySelectorAll('.dh-sidebar-nav a').forEach(function(l) { l.classList.remove('active'); });
    document.querySelectorAll('.dh-tab-content').forEach(function(t) { t.classList.remove('active'); });
    document.querySelector('[data-tab="' + hash + '"]').classList.add('active');
    document.getElementById('tab-' + hash).classList.add('active');
  }

  // Load orders from localStorage
  function loadOrders() {
    var orders = JSON.parse(localStorage.getItem('dh_orders') || '[]');
    var container = document.getElementById('orders-list');
    if (orders.length === 0) {
      container.innerHTML = '<div class="dh-empty-state"><div class="icon">📦</div><p>No tienes pedidos aún</p><p style="font-size:0.85rem;">Cuando compres algo, aparecerá aquí</p><a href="/" style="color:#ff6b35;font-weight:600;">Explorar Deals</a></div>';
      return;
    }
    container.innerHTML = '';
    orders.forEach(function(o) {
      var statusClass = o.status === 'Entregado' ? 'delivered' : o.status === 'En Tránsito' ? 'transit' : 'processing';
      container.innerHTML += '<div class="dh-order-card"><div class="dh-order-top"><span class="dh-order-id">#' + o.id + '</span><span class="dh-order-status ' + statusClass + '">' + o.status + '</span></div><div class="dh-order-items"><img class="dh-order-thumb" src="' + (o.image || 'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2250%22 height=%2250%22><rect fill=%22%23f5f5f5%22 width=%2250%22 height=%2250%22/></svg>') + '" alt=""><div class="dh-order-info"><div class="title">' + o.title + '</div><div class="date">' + o.date + ' • ' + o.store + '</div></div><div class="dh-order-price">$' + o.price + '</div></div></div>';
    });
  }

  // Load wishlist from localStorage
  function loadWishlist() {
    var wishlist = JSON.parse(localStorage.getItem('dh_wishlist') || '[]');
    var container = document.getElementById('wishlist-grid');
    if (wishlist.length === 0) {
      container.innerHTML = '<div class="dh-empty-state" style="grid-column:1/-1;"><div class="icon">❤️</div><p>Tu wishlist está vacía</p><p style="font-size:0.85rem;">Guarda productos que te gusten para verlos después</p><a href="/" style="color:#ff6b35;font-weight:600;">Explorar Deals</a></div>';
      return;
    }
    container.innerHTML = '';
    wishlist.forEach(function(item, idx) {
      container.innerHTML += '<div class="dh-wish-card"><img class="dh-wish-img" src="' + (item.image || '') + '" alt="" onerror="this.style.background=\'#f5f5f5\'"><div class="dh-wish-info"><div class="title">' + item.title + '</div><div class="price">$' + item.price + '</div></div><div class="dh-wish-actions"><a href="/pages/product?id=' + item.id + '&store=' + (item.store || 'amazon') + '" class="view-btn" style="text-align:center;text-decoration:none;display:block;">Ver</a><button class="remove-btn" data-idx="' + idx + '">✖</button></div></div>';
    });
    container.querySelectorAll('.remove-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var i = parseInt(btn.dataset.idx);
        wishlist.splice(i, 1);
        localStorage.setItem('dh_wishlist', JSON.stringify(wishlist));
        loadWishlist();
      });
    });
  }

  // Load addresses
  function loadAddresses() {
    var addrs = JSON.parse(localStorage.getItem('dh_addresses') || '[]');
    var container = document.getElementById('addresses-list');
    if (addrs.length === 0) {
      container.innerHTML = '<div class="dh-empty-state"><div class="icon">📍</div><p>No tienes direcciones guardadas</p></div>';
      return;
    }
    container.innerHTML = '';
    addrs.forEach(function(a, idx) {
      container.innerHTML += '<div class="dh-address-card"><h4>' + a.name + '</h4><p>' + a.line + '</p><p>' + a.city + ', ' + a.country + '</p><p>' + a.phone + '</p><button onclick="removeAddr(' + idx + ')" style="margin-top:6px;padding:4px 12px;border:1px solid #ddd;border-radius:6px;background:#fff;cursor:pointer;font-size:0.8rem;">Eliminar</button></div>';
    });
  }

  window.removeAddr = function(idx) {
    var addrs = JSON.parse(localStorage.getItem('dh_addresses') || '[]');
    addrs.splice(idx, 1);
    localStorage.setItem('dh_addresses', JSON.stringify(addrs));
    loadAddresses();
  };

  // Save address
  document.getElementById('save-addr-btn').addEventListener('click', function() {
    var addr = {
      name: document.getElementById('addr-name').value,
      line: document.getElementById('addr-line').value,
      city: document.getElementById('addr-city').value,
      country: document.getElementById('addr-country').value,
      phone: document.getElementById('addr-phone').value
    };
    if (!addr.name || !addr.line) { alert('Completa los campos requeridos'); return; }
    var addrs = JSON.parse(localStorage.getItem('dh_addresses') || '[]');
    addrs.push(addr);
    localStorage.setItem('dh_addresses', JSON.stringify(addrs));
    document.getElementById('addr-form').style.display = 'none';
    ['addr-name','addr-line','addr-city','addr-country','addr-phone'].forEach(function(id) { document.getElementById(id).value = ''; });
    loadAddresses();
  });

  // Security save
  document.getElementById('save-security-btn').addEventListener('click', function() {
    var newPw = document.getElementById('sec-new-pw').value;
    var confirmPw = document.getElementById('sec-confirm-pw').value;
    if (newPw && newPw !== confirmPw) { alert('Las contraseñas no coinciden'); return; }
    alert('Configuración de seguridad actualizada');
  });

  loadOrders();
  loadAddresses();
});
</script>

{% schema %}
{
  "name": "Customer Dashboard",
  "settings": [],
  "presets": [{"name": "Customer Dashboard"}]
}
{% endschema %}