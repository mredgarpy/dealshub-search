(function() {
  'use strict';

  /* Navigation */
  var navItems = document.querySelectorAll('[data-sh-nav]');
  var sections = document.querySelectorAll('[data-sh-section]');
  var sidebar = document.querySelector('[data-sh-sidebar]');
  var overlay = document.querySelector('[data-sh-overlay]');
  var mobileToggle = document.querySelector('[data-sh-mobile-toggle]');

  function showSection(name) {
    sections.forEach(function(s) { s.classList.remove('active'); });
    navItems.forEach(function(n) { n.classList.remove('active'); });
    var target = document.querySelector('[data-sh-section="' + name + '"]');
    if (target) target.classList.add('active');
    navItems.forEach(function(n) {
      if (n.getAttribute('data-sh-nav') === name) n.classList.add('active');
    });
    closeSidebar();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  navItems.forEach(function(item) {
    item.addEventListener('click', function(e) {
      e.preventDefault();
      showSection(this.getAttribute('data-sh-nav'));
    });
  });

  /* Mobile sidebar */
  function closeSidebar() {
    if (sidebar) sidebar.classList.remove('open');
    if (overlay) overlay.classList.remove('open');
  }

  if (mobileToggle) {
    mobileToggle.addEventListener('click', function() {
      sidebar.classList.toggle('open');
      overlay.classList.toggle('open');
    });
  }
  if (overlay) overlay.addEventListener('click', closeSidebar);

  /* Copy coupon code */
  document.querySelectorAll('[data-sh-copy]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var code = this.getAttribute('data-sh-copy');
      if (navigator.clipboard) {
        navigator.clipboard.writeText(code);
        this.textContent = 'Copied!';
        var self = this;
        setTimeout(function() { self.textContent = 'Copy code'; }, 2000);
      }
    });
  });

  /* Dismiss alert */
  document.querySelectorAll('[data-sh-dismiss]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      this.closest('.sh-alert').style.display = 'none';
    });
  });

  /* Wishlist count from localStorage (key: dh_wishlist from PDP/API) */
  try {
    var wl = JSON.parse(localStorage.getItem('dh_wishlist') || '[]');
    var countEls = document.querySelectorAll('[data-sh-wishlist-count]');
    countEls.forEach(function(el) { el.textContent = wl.length; });
  } catch(e) {}

  /* ---- Recently Viewed from localStorage (key: dh_recent from PDP dealshub-product.js) ---- */
  try {
    var rvContainer = document.querySelector('[data-sh-recently-viewed]');
    if (rvContainer) {
      var rvItems = JSON.parse(localStorage.getItem('dh_recent') || '[]');
      if (rvItems.length > 0) {
        var rvProducts = rvItems.slice(0, 8);
        var rvHtml = '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px">';
        rvProducts.forEach(function(p) {
          var imgSrc = p.image || p.primaryImage || '';
          var rawPrice = typeof p.price === 'string' ? parseFloat(p.price.replace(/[^0-9.]/g, '')) : parseFloat(p.price);
          var priceStr = !isNaN(rawPrice) ? '$' + rawPrice.toFixed(2) : (p.price || '');
          var rawOrig = typeof p.originalPrice === 'string' ? parseFloat(p.originalPrice.replace(/[^0-9.]/g, '')) : parseFloat(p.originalPrice);
          var origStr = !isNaN(rawOrig) && rawOrig > 0 ? '<span style="text-decoration:line-through;color:#999;font-size:11px;margin-left:4px">$' + rawOrig.toFixed(2) + '</span>' : '';
          var sourceId = p.sourceId || p.id || '';
          var source = p.source || p.store || '';
          var link = '/pages/product?id=' + encodeURIComponent(sourceId) + '&store=' + encodeURIComponent(source);
          rvHtml += '<a href="' + link + '" style="display:block;background:#fff;border:1px solid #eee;border-radius:10px;overflow:hidden;text-decoration:none;color:inherit;transition:box-shadow 0.2s">'
            + '<div style="width:100%;aspect-ratio:1;background:#f5f5f5;overflow:hidden">'
            + (imgSrc ? '<img src="' + imgSrc + '" alt="" style="width:100%;height:100%;object-fit:cover" loading="lazy">' : '<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#ccc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="32" height="32"><rect x="3" y="3" width="18" height="18" rx="2"/></svg></div>')
            + '</div>'
            + '<div style="padding:10px">'
            + '<div style="font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + (p.title || 'Product') + '</div>'
            + '<div style="margin-top:4px"><span style="font-weight:700;color:#E53E3E;font-size:14px">' + priceStr + '</span>' + origStr + '</div>'
            + (source ? '<div style="font-size:10px;color:#888;margin-top:3px;text-transform:capitalize">' + source + '</div>' : '')
            + '</div></a>';
        });
        rvHtml += '</div>';
        rvContainer.innerHTML = rvHtml;
      }
    }
  } catch(rvErr) { console.error('Recently viewed error:', rvErr); }

  /* ---- Wishlist from localStorage (key: dh_wishlist from search results/PDP) ---- */
  try {
    var wlContainer = document.querySelector('[data-sh-wishlist-container]');
    if (wlContainer && wl.length > 0) {
      var wlHtml = '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px">';
      wl.forEach(function(p, idx) {
        var imgSrc = p.image || p.primaryImage || '';
        var rawPrice = typeof p.price === 'string' ? parseFloat(p.price.replace(/[^0-9.]/g, '')) : parseFloat(p.price);
        var priceStr = !isNaN(rawPrice) ? '$' + rawPrice.toFixed(2) : (p.price || '');
        var rawOrig = typeof p.originalPrice === 'string' ? parseFloat(p.originalPrice.replace(/[^0-9.]/g, '')) : parseFloat(p.originalPrice);
        var origStr = !isNaN(rawOrig) && rawOrig > 0 ? '<span style="text-decoration:line-through;color:#999;font-size:11px;margin-left:4px">$' + rawOrig.toFixed(2) + '</span>' : '';
        var sourceId = p.sourceId || p.id || '';
        var source = p.source || p.store || '';
        var link = '/pages/product?id=' + encodeURIComponent(sourceId) + '&store=' + encodeURIComponent(source);
        wlHtml += '<div style="position:relative;background:#fff;border:1px solid #eee;border-radius:10px;overflow:hidden">'
          + '<button onclick="(function(btn){var w=JSON.parse(localStorage.getItem(\'dh_wishlist\')||\'[]\');w=w.filter(function(x){return!(x.id===\'' + sourceId + '\'&&x.source===\'' + source + '\')});localStorage.setItem(\'dh_wishlist\',JSON.stringify(w));btn.closest(\'div[style]\').remove();document.querySelectorAll(\'[data-sh-wishlist-count]\').forEach(function(el){el.textContent=w.length})})(this)" style="position:absolute;top:8px;right:8px;width:28px;height:28px;border-radius:50%;background:rgba(0,0,0,0.05);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2;font-size:14px;color:#E53E3E" title="Remove from wishlist">&times;</button>'
          + '<a href="' + link + '" style="display:block;text-decoration:none;color:inherit">'
          + '<div style="width:100%;aspect-ratio:1;background:#f5f5f5;overflow:hidden">'
          + (imgSrc ? '<img src="' + imgSrc + '" alt="" style="width:100%;height:100%;object-fit:cover" loading="lazy">' : '<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#ccc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="32" height="32"><rect x="3" y="3" width="18" height="18" rx="2"/></svg></div>')
          + '</div>'
          + '<div style="padding:10px">'
          + '<div style="font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + (p.title || 'Product') + '</div>'
          + '<div style="margin-top:4px"><span style="font-weight:700;color:#E53E3E;font-size:14px">' + priceStr + '</span>' + origStr + '</div>'
          + (source ? '<div style="font-size:10px;color:#888;margin-top:3px;text-transform:capitalize">' + source + '</div>' : '')
          + '</div></a></div>';
      });
      wlHtml += '</div>';
      wlContainer.innerHTML = wlHtml;
    }
  } catch(wlErr) { console.error('Wishlist error:', wlErr); }

  /* Profile edit/cancel toggle */
  var profileView = document.getElementById('sh-profile-view');
  var profileForm = document.getElementById('sh-profile-form');
  var profileEditBtn = document.getElementById('sh-profile-edit-btn');
  var profileCancelBtn = document.getElementById('sh-profile-cancel-btn');
  var profileCancelBtn2 = document.getElementById('sh-profile-cancel-btn2');
  var profileSaveBtn = document.getElementById('sh-profile-save-btn');
  var profileMsg = document.getElementById('sh-profile-msg');
  var customerId = '{{ customer.id }}';

  function showProfileEdit() {
    if (profileMsg) { profileMsg.style.display = 'none'; }
    if (profileView) profileView.style.display = 'none';
    if (profileForm) profileForm.style.display = 'block';
  }
  function hideProfileEdit() {
    if (profileForm) profileForm.style.display = 'none';
    if (profileView) profileView.style.display = 'block';
  }

  if (profileEditBtn) profileEditBtn.addEventListener('click', showProfileEdit);
  if (profileCancelBtn) profileCancelBtn.addEventListener('click', hideProfileEdit);
  if (profileCancelBtn2) profileCancelBtn2.addEventListener('click', hideProfileEdit);

  /* Profile save via API (bypasses New Customer Accounts redirect) */
  if (profileSaveBtn) {
    profileSaveBtn.addEventListener('click', function() {
      var firstName = document.getElementById('sh-cust-first').value.trim();
      var lastName = document.getElementById('sh-cust-last').value.trim();
      profileSaveBtn.disabled = true;
      profileSaveBtn.textContent = 'Saving...';
      if (profileMsg) profileMsg.style.display = 'none';

      fetch('https://dealshub-search.onrender.com/api/update-customer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customer_id: customerId, first_name: firstName, last_name: lastName })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        profileSaveBtn.disabled = false;
        profileSaveBtn.textContent = 'Save changes';
        if (data.success) {
          if (profileMsg) {
            profileMsg.style.display = 'block';
            profileMsg.style.background = '#D1FAE5';
            profileMsg.style.color = '#065F46';
            profileMsg.innerHTML = '<strong>Profile updated!</strong> Your changes have been saved.';
          }
          /* Update displayed name across the page */
          var fullName = (data.customer.first_name || '') + ' ' + (data.customer.last_name || '');
          document.querySelectorAll('.sh-side-name').forEach(function(el) { el.textContent = fullName.trim(); });
          document.querySelectorAll('.sh-set-val').forEach(function(el) {
            if (el.closest('.sh-set-item') && el.closest('.sh-set-item').querySelector('.sh-set-key') &&
                el.closest('.sh-set-item').querySelector('.sh-set-key').textContent.trim() === 'Full name') {
              el.textContent = fullName.trim();
            }
          });
          /* Update initials */
          var i1 = (data.customer.first_name || '').charAt(0).toUpperCase();
          var i2 = (data.customer.last_name || '').charAt(0).toUpperCase();
          document.querySelectorAll('.sh-side-av').forEach(function(el) { el.textContent = i1 + i2; });
          /* Update welcome */
          var welcomeH1 = document.querySelector('.sh-welcome h1');
          if (welcomeH1) welcomeH1.textContent = 'Welcome back, ' + (data.customer.first_name || 'Member').toUpperCase();
          setTimeout(function() { hideProfileEdit(); }, 1500);
        } else {
          if (profileMsg) {
            profileMsg.style.display = 'block';
            profileMsg.style.background = '#FEE2E2';
            profileMsg.style.color = '#991B1B';
            profileMsg.innerHTML = '<strong>Error:</strong> ' + (data.error || 'Could not save changes. Please try again.');
          }
        }
      })
      .catch(function(err) {
        profileSaveBtn.disabled = false;
        profileSaveBtn.textContent = 'Save changes';
        if (profileMsg) {
          profileMsg.style.display = 'block';
          profileMsg.style.background = '#FEE2E2';
          profileMsg.style.color = '#991B1B';
          profileMsg.innerHTML = '<strong>Error:</strong> Connection failed. Please try again.';
        }
      });
    });
  }

  /* Address add form toggle */
  var addrFormWrap = document.getElementById('sh-addr-form-wrap');
  function showAddrForm() { if (addrFormWrap) addrFormWrap.style.display = 'block'; }
  function hideAddrForm() { if (addrFormWrap) addrFormWrap.style.display = 'none'; }

  var addrAddBtn = document.getElementById('sh-addr-add-btn');
  var addrAddBtn2 = document.getElementById('sh-addr-add-btn2');
  var addrCancelBtn = document.getElementById('sh-addr-cancel-btn');
  var addrCancelBtn2 = document.getElementById('sh-addr-cancel-btn2');

  if (addrAddBtn) addrAddBtn.addEventListener('click', showAddrForm);
  if (addrAddBtn2) addrAddBtn2.addEventListener('click', showAddrForm);
  if (addrCancelBtn) addrCancelBtn.addEventListener('click', hideAddrForm);
  if (addrCancelBtn2) addrCancelBtn2.addEventListener('click', hideAddrForm);

  /* Save address via API (bypasses New Customer Accounts form issue) */
  var addrSaveBtn = document.getElementById('sh-addr-save-btn');
  var addrMsg = document.getElementById('sh-addr-msg');
  if (addrSaveBtn) {
    addrSaveBtn.addEventListener('click', function() {
      var address = {
        firstName: (document.getElementById('sh-addr-first') || {}).value || '',
        lastName: (document.getElementById('sh-addr-last') || {}).value || '',
        company: (document.getElementById('sh-addr-company') || {}).value || '',
        address1: (document.getElementById('sh-addr-address1') || {}).value || '',
        address2: (document.getElementById('sh-addr-address2') || {}).value || '',
        city: (document.getElementById('sh-addr-city') || {}).value || '',
        province: (document.getElementById('sh-addr-province') || {}).value || '',
        zip: (document.getElementById('sh-addr-zip') || {}).value || '',
        country: (document.getElementById('sh-addr-country') || {}).value || 'United States',
        phone: (document.getElementById('sh-addr-phone') || {}).value || '',
        isDefault: (document.getElementById('sh-addr-default') || {}).checked || false
      };

      if (!address.address1 || !address.city || !address.zip) {
        if (addrMsg) {
          addrMsg.style.display = 'block';
          addrMsg.style.background = '#FEE2E2';
          addrMsg.style.color = '#991B1B';
          addrMsg.textContent = 'Please fill in address, city, and ZIP code.';
        }
        return;
      }

      addrSaveBtn.disabled = true;
      addrSaveBtn.textContent = 'Saving...';

      fetch('https://dealshub-search.onrender.com/api/customer/address/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customerId: customerId, address: address })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        addrSaveBtn.disabled = false;
        addrSaveBtn.textContent = 'Save address';
        if (data.success) {
          window.location.href = '/pages/my-account#addresses';
          window.location.reload();
        } else {
          if (addrMsg) {
            addrMsg.style.display = 'block';
            addrMsg.style.background = '#FEE2E2';
            addrMsg.style.color = '#991B1B';
            addrMsg.textContent = data.error || 'Could not save address. Please try again.';
          }
        }
      })
      .catch(function() {
        addrSaveBtn.disabled = false;
        addrSaveBtn.textContent = 'Save address';
        if (addrMsg) {
          addrMsg.style.display = 'block';
          addrMsg.style.background = '#FEE2E2';
          addrMsg.style.color = '#991B1B';
          addrMsg.textContent = 'Connection error. Please try again.';
        }
      });
    });
  }

  /* ---- Fetch orders via API (includes cancelled/refunded) ---- */
  var customerEmail = '{{ customer.email | escape }}';
  var liquidOrderCount = {{ cust_order_count | default: 0 }};

  function formatOrderDate(d) {
    var dt = new Date(d);
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return months[dt.getMonth()] + ' ' + dt.getDate() + ', ' + dt.getFullYear();
  }

  function orderStatusBadge(o) {
    if (o.cancelled_at) return '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:#FEE2E2;color:#991B1B">Cancelled</span>';
    if (o.financial_status === 'refunded') return '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:#FEF3C7;color:#92400E">Refunded</span>';
    if (o.financial_status === 'partially_refunded') return '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:#FEF3C7;color:#92400E">Partially refunded</span>';
    if (o.fulfillment_status === 'fulfilled') return '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:#D1FAE5;color:#065F46">Delivered</span>';
    if (o.fulfillment_status === 'partial') return '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:#DBEAFE;color:#1E40AF">Partially shipped</span>';
    if (o.financial_status === 'paid') return '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:#DBEAFE;color:#1E40AF">Processing</span>';
    if (o.financial_status === 'pending') return '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:#F3F4F6;color:#374151">Pending</span>';
    return '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:#F3F4F6;color:#374151">' + (o.financial_status || 'Unknown') + '</span>';
  }

  var _cardCounter = 0;
  function renderOrderCard(o, compact) {
    _cardCounter++;
    var itemsHtml = '';
    var items = o.line_items || [];
    var showItems = compact ? items.slice(0, 2) : items;
    showItems.forEach(function(item, idx) {
      var imgHtml = item.image
        ? '<img src="' + item.image + '" alt="" style="width:48px;height:48px;object-fit:cover;border-radius:6px" loading="lazy">'
        : '<div style="width:48px;height:48px;background:#f5f5f5;border-radius:6px;display:flex;align-items:center;justify-content:center"><svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1" width="20" height="20"><rect x="3" y="3" width="18" height="18" rx="2"/></svg></div>';
      itemsHtml += '<div style="display:flex;gap:10px;align-items:center;' + (idx > 0 ? 'margin-top:8px;' : '') + '">'
        + imgHtml
        + '<div style="flex:1;min-width:0">'
        + '<div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + item.title + '</div>'
        + (item.variant_title ? '<div style="font-size:11px;color:#888">' + item.variant_title + '</div>' : '')
        + '<div style="font-size:12px;color:#555">$' + parseFloat(item.price).toFixed(2) + ' &times; ' + item.quantity + '</div>'
        + '</div></div>';
    });
    if (compact && items.length > 2) {
      itemsHtml += '<div style="font-size:12px;color:#888;margin-top:6px">+ ' + (items.length - 2) + ' more item(s)</div>';
    }

    var orderId = 'sh-od-' + o.id + '-' + _cardCounter;
    var detailHtml = '<div id="' + orderId + '" style="display:none;margin-top:14px;padding-top:14px;border-top:1px solid #eee">'
      + '<div style="font-size:13px;font-weight:600;margin-bottom:10px">Order details</div>'
      + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:12px">'
      + '<div><span style="color:#888">Order number:</span> <strong>' + o.name + '</strong></div>'
      + '<div><span style="color:#888">Date:</span> ' + formatOrderDate(o.created_at) + '</div>'
      + '<div><span style="color:#888">Payment status:</span> <strong>' + (o.financial_status || 'N/A').replace('_', ' ') + '</strong></div>'
      + '<div><span style="color:#888">Fulfillment:</span> <strong>' + (o.fulfillment_status || 'unfulfilled').replace('_', ' ') + '</strong></div>'
      + (o.cancelled_at ? '<div><span style="color:#888">Cancelled:</span> ' + formatOrderDate(o.cancelled_at) + '</div>' : '')
      + (o.tracking_number ? '<div><span style="color:#888">Tracking:</span> ' + o.tracking_number + '</div>' : '')
      + '</div>'
      + '<div style="margin-top:12px;padding:12px;background:#f9f9f9;border-radius:8px;font-size:12px">'
      + '<div style="font-weight:600;margin-bottom:8px">Payment summary</div>'
      + '<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span>Subtotal</span><span>$' + parseFloat(o.subtotal_price).toFixed(2) + '</span></div>'
      + '<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span>Tax</span><span>$' + parseFloat(o.total_tax).toFixed(2) + '</span></div>'
      + '<div style="display:flex;justify-content:space-between;font-weight:700;padding-top:6px;border-top:1px solid #ddd"><span>Total</span><span>$' + parseFloat(o.total_price).toFixed(2) + ' ' + (o.currency || 'USD') + '</span></div>'
      + '</div>'
      + (o.order_status_url ? '<div style="margin-top:10px"><a href="' + o.order_status_url + '" target="_blank" rel="noopener" style="font-size:12px;color:var(--red,#e53e3e);font-weight:600;text-decoration:none">View order status page &rarr;</a></div>' : '')
      + (o.tracking_url ? '<div style="margin-top:6px"><a href="' + o.tracking_url + '" target="_blank" rel="noopener" style="font-size:12px;color:var(--red,#e53e3e);font-weight:600;text-decoration:none">Track shipment &rarr;</a></div>' : '')
      + '</div>';

    return '<div class="sh-order-card" style="border:1px solid #eee;border-radius:12px;padding:16px;margin-bottom:12px;cursor:pointer" onclick="(function(e){var d=document.getElementById(\'' + orderId + '\');if(d){d.style.display=d.style.display===\'none\'?\'block\':\'none\';}e.querySelector(\'.sh-order-toggle\').textContent=d&&d.style.display===\'block\'?\'Hide details\':\'View details\';})(this)">'
      + '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">'
      + '<div><span style="font-weight:700;font-size:14px">' + o.name + '</span> <span style="color:#888;font-size:12px">&middot; ' + formatOrderDate(o.created_at) + '</span></div>'
      + '<div style="display:flex;align-items:center;gap:8px">' + orderStatusBadge(o) + '<span style="font-weight:700;font-size:14px">$' + parseFloat(o.total_price).toFixed(2) + '</span></div>'
      + '</div>'
      + '<div>' + itemsHtml + '</div>'
      + '<div style="margin-top:10px;display:flex;justify-content:space-between;align-items:center">'
      + '<span class="sh-order-toggle" style="font-size:12px;color:var(--red,#e53e3e);font-weight:600">View details</span>'
      + '</div>'
      + detailHtml
      + '</div>';
  }

  /* Always fetch from API to get complete order history (Liquid excludes cancelled) */
  if (customerEmail) {
    fetch('https://dealshub-search.onrender.com/api/customer-orders?email=' + encodeURIComponent(customerEmail))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var orders = data.orders || [];
        /* Update metric card */
        var metricEl = document.getElementById('sh-metric-orders-num');
        if (metricEl) metricEl.textContent = orders.length;

        /* Update orders count in settings (by ID, reliable) */
        var dashSettingsOrders = document.getElementById('sh-dash-settings-orders');
        if (dashSettingsOrders) dashSettingsOrders.textContent = orders.length + ' total orders';
        var settingsOrdersCount = document.getElementById('sh-settings-orders-count');
        if (settingsOrdersCount) settingsOrdersCount.textContent = orders.length + ' orders';
        /* Also update nav badge */
        var navBadges = document.querySelectorAll('.sh-nav-badge');
        if (orders.length > 0) {
          var ordersNavItem = document.querySelector('[data-sh-nav="orders"]');
          if (ordersNavItem && !ordersNavItem.querySelector('.sh-nav-badge')) {
            ordersNavItem.insertAdjacentHTML('beforeend', '<span class="sh-nav-badge">' + orders.length + '</span>');
          }
        }

        /* Update dashboard preview */
        var dashCount = document.getElementById('sh-dash-orders-count');
        if (dashCount) dashCount.textContent = orders.length;
        var dashContainer = document.getElementById('sh-dash-orders-container');
        var dashEmpty = document.getElementById('sh-dash-orders-empty');
        if (orders.length > 0 && dashEmpty) {
          dashEmpty.remove();
          orders.slice(0, 3).forEach(function(o) {
            dashContainer.insertAdjacentHTML('beforeend', renderOrderCard(o));
          });
        } else if (orders.length === 0 && dashEmpty) {
          dashEmpty.querySelector('h3').textContent = 'No orders yet';
          dashEmpty.querySelector('p').innerHTML = 'Start shopping to see your orders here.';
          dashEmpty.insertAdjacentHTML('beforeend', '<a href="/" class="sh-empty-btn" style="margin-top:12px;display:inline-block">Start shopping &rarr;</a>');
        }

        /* Update full orders section */
        var apiCount = document.getElementById('sh-orders-api-count');
        var apiContainer = document.getElementById('sh-orders-api-container');
        if (apiCount) apiCount.textContent = orders.length;
        if (apiContainer) {
          if (orders.length > 0) {
            apiContainer.innerHTML = '';
            orders.forEach(function(o) {
              apiContainer.insertAdjacentHTML('beforeend', renderOrderCard(o));
            });
          } else {
            apiContainer.innerHTML = '<div class="sh-empty">'
              + '<svg viewBox="0 0 24 24" fill="none" stroke="var(--navy)" stroke-width="1.5" width="48" height="48"><path d="M20 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>'
              + '<h3>No orders yet</h3><p>Start shopping to see your orders here.</p>'
              + '<a href="/" class="sh-empty-btn">Start shopping &rarr;</a></div>';
          }
        }
      })
      .catch(function(err) {
        console.error('Failed to load orders:', err);
        var apiContainer = document.getElementById('sh-orders-api-container');
        if (apiContainer) {
          apiContainer.innerHTML = '<div class="sh-empty"><h3>No orders yet</h3><p>Start shopping to see your orders here.</p><a href="/" class="sh-empty-btn">Start shopping &rarr;</a></div>';
        }
        var dashEmpty = document.getElementById('sh-dash-orders-empty');
        if (dashEmpty) {
          dashEmpty.querySelector('h3').textContent = 'No orders yet';
          dashEmpty.querySelector('p').innerHTML = 'Start shopping to see your orders here.';
        }
      });
  }

  /* ---- RETURNS SECTION ---- */
  var returnFormSection = document.getElementById('sh-return-form-section');
  var returnNewBtn = document.getElementById('sh-return-new-btn');
  var returnCancelBtn = document.getElementById('sh-return-cancel-btn');
  var returnOrderSelect = document.getElementById('sh-return-order-select');
  var returnSubmitBtn = document.getElementById('sh-return-submit-btn');
  var returnMsg = document.getElementById('sh-return-msg');
  var returnsContainer = document.getElementById('sh-returns-container');
  var returnsEmpty = document.getElementById('sh-returns-empty');
  var returnsCount = document.getElementById('sh-returns-count');

  if (returnNewBtn) returnNewBtn.addEventListener('click', function() {
    returnFormSection.style.display = 'block';
    if (returnMsg) { returnMsg.style.display = 'none'; }
  });
  if (returnCancelBtn) returnCancelBtn.addEventListener('click', function() {
    returnFormSection.style.display = 'none';
  });

  /* Populate return order select from API orders */
  function populateReturnOrders(orders) {
    if (!returnOrderSelect) return;
    returnOrderSelect.innerHTML = '<option value="">Select an order...</option>';
    orders.forEach(function(o) {
      if (o.financial_status !== 'refunded' && !o.cancelled_at) {
        var opt = document.createElement('option');
        opt.value = o.id;
        opt.textContent = o.name + ' — $' + parseFloat(o.total_price).toFixed(2) + ' (' + formatOrderDate(o.created_at) + ')';
        returnOrderSelect.appendChild(opt);
      }
    });
  }

  /* Submit return */
  if (returnSubmitBtn) {
    returnSubmitBtn.addEventListener('click', function() {
      var orderId = returnOrderSelect.value;
      var reason = document.getElementById('sh-return-reason').value;
      var comment = document.getElementById('sh-return-comment').value;

      if (!orderId) { showReturnMsg('Please select an order.', true); return; }
      if (!reason) { showReturnMsg('Please select a reason.', true); return; }

      returnSubmitBtn.disabled = true;
      returnSubmitBtn.textContent = 'Submitting...';

      fetch('https://dealshub-search.onrender.com/api/crm/returns/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          orderId: orderId,
          customerId: customerId,
          reason: reason,
          comment: comment
        })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        returnSubmitBtn.disabled = false;
        returnSubmitBtn.textContent = 'Submit return request';
        if (data.success) {
          showReturnMsg('Return request submitted successfully! We will review it within 24-48 hours.', false);
          document.getElementById('sh-return-reason').value = '';
          document.getElementById('sh-return-comment').value = '';
          returnOrderSelect.value = '';
          loadCustomerReturns();
        } else {
          showReturnMsg(data.error || 'Something went wrong. Please try again.', true);
        }
      })
      .catch(function() {
        returnSubmitBtn.disabled = false;
        returnSubmitBtn.textContent = 'Submit return request';
        showReturnMsg('Connection error. Please try again.', true);
      });
    });
  }

  function showReturnMsg(msg, isError) {
    if (!returnMsg) return;
    returnMsg.style.display = 'block';
    returnMsg.style.background = isError ? '#FEE2E2' : '#D1FAE5';
    returnMsg.style.color = isError ? '#991B1B' : '#065F46';
    returnMsg.textContent = msg;
  }

  function renderReturnCard(r) {
    var statusColors = {
      pending: { bg: '#FEF3C7', color: '#92400E', label: 'Pending review' },
      approved: { bg: '#D1FAE5', color: '#065F46', label: 'Approved' },
      rejected: { bg: '#FEE2E2', color: '#991B1B', label: 'Rejected' },
      completed: { bg: '#DBEAFE', color: '#1E40AF', label: 'Completed' }
    };
    var st = statusColors[r.status] || statusColors.pending;
    var reasonLabels = {
      wrong_item: 'Wrong item received',
      damaged: 'Item arrived damaged',
      not_as_described: 'Not as described',
      doesnt_fit: "Doesn't fit",
      changed_mind: 'Changed my mind',
      quality: 'Quality issue',
      other: 'Other'
    };

    return '<div style="border:1px solid #eee;border-radius:12px;padding:16px;margin-bottom:12px">'
      + '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">'
      + '<div><span style="font-weight:700;font-size:14px">Return ' + r.id + '</span> <span style="color:#888;font-size:12px">&middot; ' + r.orderNumber + '</span></div>'
      + '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:' + st.bg + ';color:' + st.color + '">' + st.label + '</span>'
      + '</div>'
      + '<div style="font-size:13px;color:#555">'
      + '<div style="margin-bottom:4px"><strong>Reason:</strong> ' + (reasonLabels[r.reason] || r.reason || 'Not specified') + '</div>'
      + (r.comment ? '<div style="margin-bottom:4px"><strong>Details:</strong> ' + r.comment + '</div>' : '')
      + '<div style="color:#999;font-size:11px;margin-top:6px">Submitted ' + formatOrderDate(r.createdAt) + '</div>'
      + (r.adminNotes ? '<div style="margin-top:8px;padding:10px;background:#f9f9f9;border-radius:8px;font-size:12px"><strong>Staff note:</strong> ' + r.adminNotes + '</div>' : '')
      + (r.refundAmount > 0 ? '<div style="margin-top:6px;font-weight:600;color:var(--green)">Refund: $' + parseFloat(r.refundAmount).toFixed(2) + '</div>' : '')
      + '</div></div>';
  }

  function loadCustomerReturns() {
    if (!customerId) return;
    fetch('https://dealshub-search.onrender.com/api/crm/returns/customer/' + customerId)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var returns = data.returns || [];
        if (returnsCount) returnsCount.textContent = returns.length;
        if (returns.length > 0 && returnsContainer) {
          returnsContainer.innerHTML = '';
          returns.forEach(function(r) {
            returnsContainer.insertAdjacentHTML('beforeend', renderReturnCard(r));
          });
        }
      })
      .catch(function() {});
  }
  loadCustomerReturns();

  /* ---- REVIEWS SECTION ---- */
  var reviewFormSection = document.getElementById('sh-review-form-section');
  var reviewCancelBtn = document.getElementById('sh-review-cancel-btn');
  var reviewSubmitBtn = document.getElementById('sh-review-submit-btn');
  var reviewMsg = document.getElementById('sh-review-msg');
  var reviewableContainer = document.getElementById('sh-reviewable-container');
  var reviewsListContainer = document.getElementById('sh-reviews-list-container');
  var reviewsCount = document.getElementById('sh-reviews-count');
  var selectedRating = 0;

  if (reviewCancelBtn) reviewCancelBtn.addEventListener('click', function() {
    reviewFormSection.style.display = 'none';
  });

  /* Star rating */
  document.querySelectorAll('.sh-star-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      selectedRating = parseInt(this.getAttribute('data-star'));
      document.getElementById('sh-review-rating').value = selectedRating;
      document.querySelectorAll('.sh-star-btn').forEach(function(s) {
        var val = parseInt(s.getAttribute('data-star'));
        s.style.color = val <= selectedRating ? '#F59E0B' : '#ddd';
      });
    });
    btn.addEventListener('mouseenter', function() {
      var hoverVal = parseInt(this.getAttribute('data-star'));
      document.querySelectorAll('.sh-star-btn').forEach(function(s) {
        var val = parseInt(s.getAttribute('data-star'));
        s.style.color = val <= hoverVal ? '#F59E0B' : '#ddd';
      });
    });
    btn.addEventListener('mouseleave', function() {
      document.querySelectorAll('.sh-star-btn').forEach(function(s) {
        var val = parseInt(s.getAttribute('data-star'));
        s.style.color = val <= selectedRating ? '#F59E0B' : '#ddd';
      });
    });
  });

  function openReviewForm(productId, productTitle, productImage, orderId) {
    reviewFormSection.style.display = 'block';
    document.getElementById('sh-review-product-id').value = productId || '';
    document.getElementById('sh-review-product-title-val').value = productTitle || '';
    document.getElementById('sh-review-order-id').value = orderId || '';
    var info = document.getElementById('sh-review-product-info');
    if (info) {
      var imgHtml = productImage
        ? '<img src="' + productImage + '" style="width:48px;height:48px;object-fit:cover;border-radius:8px">'
        : '<div style="width:48px;height:48px;background:#eee;border-radius:8px"></div>';
      info.innerHTML = imgHtml + '<div><div style="font-weight:600;font-size:14px">' + (productTitle || 'Product') + '</div><div style="font-size:12px;color:#888">From order ' + (orderId || '') + '</div></div>';
    }
    /* Reset form */
    selectedRating = 0;
    document.getElementById('sh-review-rating').value = '0';
    document.getElementById('sh-review-title').value = '';
    document.getElementById('sh-review-text').value = '';
    document.querySelectorAll('.sh-star-btn').forEach(function(s) { s.style.color = '#ddd'; });
    if (reviewMsg) reviewMsg.style.display = 'none';
    reviewFormSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  window.shOpenReviewForm = openReviewForm;

  /* Submit review */
  if (reviewSubmitBtn) {
    reviewSubmitBtn.addEventListener('click', function() {
      var rating = parseInt(document.getElementById('sh-review-rating').value);
      var title = document.getElementById('sh-review-title').value.trim();
      var text = document.getElementById('sh-review-text').value.trim();
      var productId = document.getElementById('sh-review-product-id').value;
      var productTitle = document.getElementById('sh-review-product-title-val').value;
      var orderId = document.getElementById('sh-review-order-id').value;

      if (!rating || rating < 1) { showReviewMsg('Please select a star rating.', true); return; }
      if (!text) { showReviewMsg('Please write your review.', true); return; }

      reviewSubmitBtn.disabled = true;
      reviewSubmitBtn.textContent = 'Submitting...';

      fetch('https://dealshub-search.onrender.com/api/crm/reviews/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          productId: productId,
          productTitle: productTitle,
          customerId: customerId,
          customerName: '{{ customer.name | escape }}',
          rating: rating,
          title: title,
          text: text,
          orderId: orderId
        })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        reviewSubmitBtn.disabled = false;
        reviewSubmitBtn.textContent = 'Submit review';
        if (data.success) {
          showReviewMsg('Thank you! Your review has been submitted and is pending approval.', false);
          reviewFormSection.style.display = 'none';
        } else {
          showReviewMsg(data.error || 'Something went wrong. Please try again.', true);
        }
      })
      .catch(function() {
        reviewSubmitBtn.disabled = false;
        reviewSubmitBtn.textContent = 'Submit review';
        showReviewMsg('Connection error. Please try again.', true);
      });
    });
  }

  function showReviewMsg(msg, isError) {
    if (!reviewMsg) return;
    reviewMsg.style.display = 'block';
    reviewMsg.style.background = isError ? '#FEE2E2' : '#D1FAE5';
    reviewMsg.style.color = isError ? '#991B1B' : '#065F46';
    reviewMsg.textContent = msg;
  }

  function renderReviewableProducts(orders) {
    if (!reviewableContainer) return;
    var deliveredItems = [];
    orders.forEach(function(o) {
      if (o.fulfillment_status === 'fulfilled') {
        (o.line_items || []).forEach(function(item) {
          deliveredItems.push({
            productId: item.product_id,
            title: item.title,
            image: item.image,
            orderId: o.id,
            orderName: o.name
          });
        });
      }
    });

    if (deliveredItems.length === 0) {
      reviewableContainer.innerHTML = '<div style="text-align:center;padding:20px 0;color:var(--text2);font-size:13px">'
        + '<p>No delivered orders to review yet.</p>'
        + '<p style="font-size:12px;color:#999;margin-top:4px">Once your orders are delivered, you can leave reviews here.</p></div>';
      return;
    }

    reviewableContainer.innerHTML = '';
    deliveredItems.forEach(function(item) {
      var imgHtml = item.image
        ? '<img src="' + item.image + '" style="width:48px;height:48px;object-fit:cover;border-radius:8px" loading="lazy">'
        : '<div style="width:48px;height:48px;background:#f5f5f5;border-radius:8px"></div>';
      reviewableContainer.insertAdjacentHTML('beforeend',
        '<div style="display:flex;gap:12px;align-items:center;padding:12px;border:1px solid #eee;border-radius:10px;margin-bottom:8px">'
        + imgHtml
        + '<div style="flex:1;min-width:0">'
        + '<div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + item.title + '</div>'
        + '<div style="font-size:11px;color:#888">From ' + item.orderName + '</div>'
        + '</div>'
        + '<button onclick="shOpenReviewForm(\'' + (item.productId || '') + '\',\'' + (item.title || '').replace(/'/g, "\\'") + '\',\'' + (item.image || '') + '\',\'' + item.orderId + '\')" style="padding:6px 14px;background:var(--navy);color:#fff;border:none;border-radius:6px;font-size:12px;cursor:pointer;font-family:inherit;font-weight:600;white-space:nowrap">Write review</button>'
        + '</div>'
      );
    });
  }

  /* Load reviewable products from orders + populate return dropdown */
  if (customerEmail) {
    fetch('https://dealshub-search.onrender.com/api/customer-orders?email=' + encodeURIComponent(customerEmail))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var orders = data.orders || [];
        populateReturnOrders(orders);
        renderReviewableProducts(orders);
      })
      .catch(function() {
        if (reviewableContainer) reviewableContainer.innerHTML = '<div style="text-align:center;padding:16px 0;color:#999;font-size:12px">Could not load orders.</div>';
      });
  }

  /* Hash navigation on load */
  if (window.location.hash) {
    var hashSection = window.location.hash.replace('#', '');
    var validSections = ['dashboard','orders','addresses','coupons','messages','wishlist','recently-viewed','settings','returns','reviews'];
    if (validSections.indexOf(hashSection) !== -1) {
      showSection(hashSection);
    }
  }
})();
</script>

{% schema %}
{
  "name": "Account Dashboard",
  "class": "sh-account-dashboard-section",
  "settings": [],
  "presets": [
    {
      "name": "Account Dashboard"
    }
  ]
}
{% endschema %}
