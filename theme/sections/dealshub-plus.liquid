  <div class="dh-savings-example">
    <div class="dh-savings-row"><span>Amazon order shipping</span><span>$12.00</span></div>
    <div class="dh-savings-row"><span>SHEIN order shipping</span><span>$3.99</span></div>
    <div class="dh-savings-row"><span>Macy's order shipping</span><span>$10.95</span></div>
    <div class="dh-savings-row"><span><strong>Total shipping without Plus</strong></span><span><strong>$26.94</strong></span></div>
    <div class="dh-savings-row"><span>StyleHub Plus membership</span><span style="color:#e53e3e">−$7.99</span></div>
    <div class="dh-savings-total">You save $18.95/month with Plus</div>
  </div>
</div>

<div class="dh-plus-faq">
  <h2>Frequently Asked Questions</h2>
  <div class="dh-plus-faq-list">
    <div class="dh-plus-faq-item">
      <div class="dh-plus-faq-q" onclick="this.parentElement.classList.toggle('open')">How does the free trial work? <span class="dh-faq-arrow">▼</span></div>
      <div class="dh-plus-faq-a">Start your 7-day free trial with no commitment. You won't be charged during the trial period. After 7 days, you'll be billed $7.99/month. Cancel anytime before the trial ends and you won't be charged.</div>
    </div>
    <div class="dh-plus-faq-item">
      <div class="dh-plus-faq-q" onclick="this.parentElement.classList.toggle('open')">Does free shipping apply to all stores? <span class="dh-faq-arrow">▼</span></div>
      <div class="dh-plus-faq-a">Yes! With Plus, you get free shipping on every order regardless of the source store — Amazon, AliExpress, SHEIN, Macy's, Sephora, and any future stores we add.</div>
    </div>
    <div class="dh-plus-faq-item">
      <div class="dh-plus-faq-q" onclick="this.parentElement.classList.toggle('open')">Can I cancel anytime? <span class="dh-faq-arrow">▼</span></div>
      <div class="dh-plus-faq-a">Absolutely. There's no long-term commitment. Cancel your Plus membership anytime from your account settings. You'll continue to enjoy benefits until the end of your current billing period.</div>
    </div>
    <div class="dh-plus-faq-item">
      <div class="dh-plus-faq-q" onclick="this.parentElement.classList.toggle('open')">How do extended returns work? <span class="dh-faq-arrow">▼</span></div>
      <div class="dh-plus-faq-a">Plus members get a 60-day return window on all purchases, compared to the standard 15-45 days depending on the store. This gives you twice the time to decide if a product is right for you.</div>
    </div>
    <div class="dh-plus-faq-item">
      <div class="dh-plus-faq-q" onclick="this.parentElement.classList.toggle('open')">Is there a minimum order for free shipping? <span class="dh-faq-arrow">▼</span></div>
      <div class="dh-plus-faq-a">No minimum at all. Even a $1 order ships free with Plus. This is one of the biggest advantages — no need to add items to reach a free shipping threshold.</div>
    </div>
  </div>
</div>

<div class="dh-plus-bottom">
  <h2>Ready to Start Saving?</h2>
  <p>Join thousands of smart shoppers who save on every order.</p>
  <a href="#" class="dh-plus-cta-hero" onclick="event.preventDefault();activatePlusTrial()">Start Your Free 7-Day Trial</a>
  <span class="dh-plus-trial">$7.99/month after trial · Cancel anytime</span>
</div>

<script>
function activatePlusTrial(){
  var btns=document.querySelectorAll('.dh-plus-cta-hero');
  btns.forEach(function(b){
    b.textContent='Adding to cart...';
    b.style.opacity='0.7';
    b.style.pointerEvents='none';
  });

  /* ── Real Shopify cart add with selling_plan for Seal Subscriptions ── */
  /* First fetch the product to get the live selling_plan_id dynamically */
  fetch('/products/stylehub-plus-membership.js')
    .then(function(r){ return r.json(); })
    .then(function(product){
      var variant = product.variants[0];
      var sellingPlanId = null;
      if(variant.selling_plan_allocations && variant.selling_plan_allocations.length > 0){
        sellingPlanId = variant.selling_plan_allocations[0].selling_plan_id;
      }
      var payload = {
        items: [{
          id: variant.id,
          quantity: 1
        }]
      };
      /* Attach selling_plan so Shopify creates a subscription order */
      if(sellingPlanId){
        payload.items[0].selling_plan = sellingPlanId;
      }
      return fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(payload)
      });
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if(data.items || data.id){
        /* Set localStorage flags for immediate UI updates */
        try{
          localStorage.setItem('stylehub_plus','true');
          localStorage.setItem('stylehub_plus_since',new Date().toISOString());
        }catch(e){}
        btns.forEach(function(b){
          b.textContent='✓ Added! Redirecting to checkout...';
          b.style.background='#38a169';
          b.style.opacity='1';
        });
        /* Go straight to checkout */
        setTimeout(function(){ window.location.href='/checkout'; }, 800);
      } else {
        /* Cart add failed — show error */
        btns.forEach(function(b){
          b.textContent='Error — Try again';
          b.style.background='#e53e3e';
          b.style.opacity='1';
          b.style.pointerEvents='auto';
        });
        console.error('Plus cart add failed:', data);
      }
    })
    .catch(function(err){
      btns.forEach(function(b){
        b.textContent='Error — Try again';
        b.style.background='#e53e3e';
        b.style.opacity='1';
        b.style.pointerEvents='auto';
      });
      console.error('Plus subscription error:', err);
    });
}

/* If already Plus member (by Shopify customer tag), update buttons */
{%- assign is_plus_page = false -%}
{%- if customer -%}
  {%- for tag in customer.tags -%}
    {%- if tag == 'plus' -%}{%- assign is_plus_page = true -%}{%- endif -%}
  {%- endfor -%}
{%- endif -%}
{%- if is_plus_page -%}
(function(){
  var btns=document.querySelectorAll('.dh-plus-cta-hero');
  btns.forEach(function(b){
    b.textContent='✓ You\'re a Plus Member';
    b.style.background='#38a169';
    b.style.pointerEvents='none';
  });
})();
{%- endif -%}
</script>

