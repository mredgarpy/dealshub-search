{%- liquid
  assign collection_handle = section.settings.collection | default: 'all'
  assign coll = collections[collection_handle]
  assign seen_titles = ''
-%}

<section id="flash-deals" class="flash-deals" style="background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);padding:50px 0;color:#fff;">
  <div style="max-width:1400px;margin:0 auto;padding:0 20px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:30px;flex-wrap:wrap;gap:16px;">
      <div>
        <h2 style="font-size:28px;font-weight:800;margin:0;">{{ section.settings.title | default: 'Flash Deals' }}</h2>
        <div style="width:40px;height:3px;background:#e74c3c;margin-top:8px;"></div>
        <p style="color:rgba(255,255,255,0.7);margin-top:8px;">{{ section.settings.subtitle | default: 'Limited time offers' }}</p>
      </div>
      <div style="display:flex;align-items:center;gap:16px;">
        <span style="color:rgba(255,255,255,0.7);">Ends in</span>
        <div style="display:flex;gap:4px;" id="flash-countdown">
          <span style="background:#e74c3c;padding:6px 10px;border-radius:6px;font-weight:700;font-size:18px;min-width:40px;text-align:center;" id="cd-hrs">23</span>
          <span style="font-size:20px;font-weight:700;line-height:40px;">:</span>
          <span style="background:#e74c3c;padding:6px 10px;border-radius:6px;font-weight:700;font-size:18px;min-width:40px;text-align:center;" id="cd-min">59</span>
          <span style="font-size:20px;font-weight:700;line-height:40px;">:</span>
          <span style="background:#e74c3c;padding:6px 10px;border-radius:6px;font-weight:700;font-size:18px;min-width:40px;text-align:center;" id="cd-sec">59</span>
        </div>
        <a href="/collections/{{ collection_handle }}" style="color:#e74c3c;font-weight:600;text-decoration:none;">View All &rarr;</a>
      </div>
    </div>

    {% if coll.products.size > 0 %}
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;">
        {%- assign rendered = 0 -%}
        {% for product in coll.products limit: 20 %}
          {%- if rendered >= 4 -%}{%- break -%}{%- endif -%}
          {%- assign tl = product.title | downcase -%}
          {%- if tl contains 'test product' or tl contains 'checkout flow' -%}{%- continue -%}{%- endif -%}
          {%- assign dk = product.title | handleize -%}
          {%- if seen_titles contains dk -%}{%- continue -%}{%- endif -%}
          {%- assign seen_titles = seen_titles | append: dk | append: '|' -%}
          {%- assign rendered = rendered | plus: 1 -%}

          <div style="background:rgba(255,255,255,0.06);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.1);transition:transform .2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform=''">
            <a href="{{ product.url }}" style="display:block;text-decoration:none;color:#fff;">
              <div style="position:relative;padding-top:100%;background:rgba(255,255,255,0.03);overflow:hidden;">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;">
                {% endif %}
                {% if product.compare_at_price > product.price %}
                  {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                  <span style="position:absolute;top:10px;left:10px;background:#e74c3c;color:#fff;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;">-{{ discount }}%</span>
                {% endif %}
                <span style="position:absolute;bottom:10px;left:10px;background:rgba(231,76,60,0.9);color:#fff;padding:4px 10px;border-radius:4px;font-size:11px;font-weight:700;">&#x26A1; FLASH</span>
              </div>
            </a>
            <div style="padding:14px;">
              <h3 style="font-size:13px;font-weight:600;margin:0;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                <a href="{{ product.url }}" style="text-decoration:none;color:#fff;">{{ product.title }}</a>
              </h3>
              <div style="margin-top:8px;display:flex;align-items:center;gap:8px;">
                <span style="font-size:18px;font-weight:700;color:#e74c3c;">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span style="font-size:12px;color:rgba(255,255,255,0.5);text-decoration:line-through;">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
              <form action="/cart/add" method="post" style="margin-top:10px;">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                <input type="hidden" name="quantity" value="1">
                <button type="submit" style="width:100%;padding:10px;background:#e74c3c;color:#fff;border:none;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer;">&#x1F6D2; Grab Deal</button>
              </form>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p style="text-align:center;color:rgba(255,255,255,0.5);padding:40px 0;">No flash deal products yet.</p>
    {% endif %}
  </div>
</section>

<script>
(function(){
  var now=new Date(), end=new Date(now);
  end.setHours(23,59,59,999);
  function tick(){
    var diff=Math.max(0,end-new Date());
    var h=Math.floor(diff/3600000), m=Math.floor((diff%3600000)/60000), s=Math.floor((diff%60000)/1000);
    var hE=document.getElementById('cd-hrs'),mE=document.getElementById('cd-min'),sE=document.getElementById('cd-sec');
    if(hE)hE.textContent=String(h).padStart(2,'0');
    if(mE)mE.textContent=String(m).padStart(2,'0');
    if(sE)sE.textContent=String(s).padStart(2,'0');
  }
  tick(); setInterval(tick,1000);
})();
</script>

{% schema %}
{
  "name": "Flash Deals",
  "settings": [
    {"type":"text","id":"title","label":"Title","default":"Flash Deals"},
    {"type":"text","id":"subtitle","label":"Subtitle","default":"Limited time offers"},
    {"type":"collection","id":"collection","label":"Collection"}
  ],
  "presets": [{"name":"Flash Deals"}]
}
{% endschema %}