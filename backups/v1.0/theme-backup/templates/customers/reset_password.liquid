{% comment %} Reset Password Page {% endcomment %}
<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-card__title">Reset Your Password</h1>
    <p class="auth-card__subtitle">Enter your new password below</p>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div style="background:rgba(231,76,60,.08);border:1px solid var(--color-danger);border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:.875rem;color:var(--color-danger);">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <div class="form-group">
        <label class="form-label" for="Password">New Password</label>
        <input type="password" name="customer[password]" id="Password" class="form-input"
          autocomplete="new-password" placeholder="At least 5 characters" minlength="5" required>
      </div>

      <div class="form-group">
        <label class="form-label" for="PasswordConfirmation">Confirm Password</label>
        <input type="password" name="customer[password_confirmation]" id="PasswordConfirmation" class="form-input"
          autocomplete="new-password" placeholder="Repeat your new password" required>
      </div>

      <button type="submit" class="btn btn--primary btn--full btn--lg">Reset Password</button>
    {%- endform -%}

    <a href="{{ routes.account_login_url }}" class="btn btn--ghost btn--full" style="margin-top:12px;">Back to Login</a>
  </div>
</div>
