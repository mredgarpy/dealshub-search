{% comment %}
  DealsHub — Full-width Trust/Value Props Section
{% endcomment %}

<div class="dh-trust-section">
  <div class="page-width">
    <div class="dh-trust-grid">
      <div class="dh-trust-item">
        <div class="dh-trust-item__icon" style="background: #e8f5e9;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2ed573" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>100% Secure Checkout</h3>
        <p>Secure checkout powered by Shopify with bank-grade SSL encryption.</p>
      </div>
      <div class="dh-trust-item">
        <div class="dh-trust-item__icon" style="background: #e3f2fd;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#5352ed" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <h3>Tracked Shipping</h3>
        <p>All orders include tracking. Real-time tracking from the source store.</p>
      </div>
      <div class="dh-trust-item">
        <div class="dh-trust-item__icon" style="background: #fff3e0;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ffa502" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
        </div>
        <h3>Easy Returns</h3>
        <p>Simple return policy. If you're not satisfied, we'll help you with the process.</p>
      </div>
      <div class="dh-trust-item">
        <div class="dh-trust-item__icon" style="background: #fce4ec;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ff4757" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
        <h3>Customer Support</h3>
        <p>Dedicated customer support via email and WhatsApp. We're here to help you.</p>
      </div>
    </div>
  </div>
</div>

<style>
  .dh-trust-section {
    padding: 48px 0;
    background: #fafafa;
  }
  .dh-trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .dh-trust-item {
    text-align: center;
    padding: 24px 16px;
  }
  .dh-trust-item__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px; height: 56px;
    border-radius: 16px;
    margin-bottom: 14px;
  }
  .dh-trust-item h3 {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a2e;
    margin: 0 0 6px;
  }
  .dh-trust-item p {
    font-size: 13px;
    color: #888;
    line-height: 1.5;
    margin: 0;
  }
  @media (max-width: 768px) {
    .dh-trust-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }
  @media (max-width: 480px) {
    .dh-trust-grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "DealsHub Trust",
  "tag": "section",
  "presets": [{ "name": "DealsHub Trust" }]
}
{% endschema %}
