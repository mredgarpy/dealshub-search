{% comment %}
  StyleHub Miami — Customer Account Dashboard
  Design: DM Sans, Navy #1A1A2E, Red #E53E3E
  Requires: Classic Customer Accounts enabled in Shopify Admin
  CSS: account.css | JS: account.js
{% endcomment %}

{{ 'account.css' | asset_url | stylesheet_tag }}

<div class="page" data-account-section>

  {%- comment -%} ========== SIDEBAR ========== {%- endcomment -%}
  {% render 'account-sidebar', current_page: 'dashboard' %}

  {%- comment -%} ========== MAIN CONTENT ========== {%- endcomment -%}
  <div class="main">

    {%- comment -%} === DASHBOARD (default view) === {%- endcomment -%}
    <div data-account-content-section="dashboard" style="display:block">

      {%- comment -%} Welcome banner {%- endcomment -%}
      <div class="welcome">
        <div>
          <h1>Welcome back, {{ customer.first_name }}</h1>
          <div class="welcome-sub">Here's what's happening with your account today</div>
        </div>
        <div class="welcome-date">{{ 'now' | date: '%B %d, %Y' }}</div>
      </div>

      {%- comment -%} Alert bar — show if any order is fulfilled but not yet delivered {%- endcomment -%}
      {%- assign has_shipped_order = false -%}
      {%- for order in customer.orders limit: 5 -%}
        {%- if order.fulfillment_status == 'fulfilled' and order.cancelled_at == blank -%}
          {%- unless has_shipped_order -%}
            {%- assign has_shipped_order = true -%}
            <div class="alert" data-alert-banner="shipped-{{ order.name }}">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <div>Your order <b>{{ order.name }}</b> has been shipped and is on its way!</div>
              <span class="alert-close" data-close-alert>&times;</span>
            </div>
          {%- endunless -%}
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Stats cards {%- endcomment -%}
      {%- assign active_orders_count = 0 -%}
      {%- assign total_savings = 0 -%}
      {%- for order in customer.orders -%}
        {%- if order.fulfillment_status != 'fulfilled' and order.cancelled_at == blank -%}
          {%- assign active_orders_count = active_orders_count | plus: 1 -%}
        {%- endif -%}
        {%- for item in order.line_items -%}
          {%- if item.variant.compare_at_price > item.variant.price -%}
            {%- assign item_saving = item.variant.compare_at_price | minus: item.variant.price | times: item.quantity -%}
            {%- assign total_savings = total_savings | plus: item_saving -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}

      <div class="metrics">
        <div class="metric m-orders">
          <div class="metric-top">
            <div class="metric-icon" style="background:var(--navy)">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" width="16" height="16"><path d="M20 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/></svg>
            </div>
            {%- if active_orders_count > 0 -%}
              <span class="metric-change" style="background:#E8F5E9;color:#1B5E20">{{ active_orders_count }} active</span>
            {%- endif -%}
          </div>
          <div class="metric-num">{{ customer.orders_count }}</div>
          <div class="metric-label">Total orders</div>
        </div>

        <div class="metric m-wish">
          <div class="metric-top">
            <div class="metric-icon" style="background:var(--red)">
              <svg viewBox="0 0 24 24" fill="#fff" width="14" height="14"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
          </div>
          <div class="metric-num" id="sh-wishlist-count">0</div>
          <div class="metric-label">Wishlist items</div>
        </div>

        <div class="metric m-save">
          <div class="metric-top">
            <div class="metric-icon" style="background:var(--green)">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" width="14" height="14"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
          </div>
          <div class="metric-num" style="color:var(--green)">{{ total_savings | money }}</div>
          <div class="metric-label">Total savings</div>
        </div>

        <div class="metric m-points">
          <div class="metric-top">
            <div class="metric-icon" style="background:var(--amber)">
              <svg viewBox="0 0 24 24" fill="#fff" width="14" height="14"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <span class="metric-change" style="background:#FEF3C7;color:#92400E" id="sh-loyalty-tier-badge">Member</span>
          </div>
          <div class="metric-num" style="color:var(--amber)" id="sh-points-count">0</div>
          <div class="metric-label">Reward points</div>
        </div>
      </div>

      {%- comment -%} Active orders section {%- endcomment -%}
      <div class="section">
        <div class="section-head">
          <div class="section-title">Active orders <span class="count">{{ active_orders_count }}</span></div>
          <a href="/account#orders" class="section-action" data-account-nav-item="orders" style="text-decoration:none">View all orders &rarr;</a>
        </div>
        <div class="section-body">
          {%- assign shown_orders = 0 -%}
          {%- for order in customer.orders limit: 10 -%}
            {%- if order.cancelled_at != blank -%}{%- continue -%}{%- endif -%}
            {%- if shown_orders >= 3 -%}{%- break -%}{%- endif -%}

            <div class="order-card" data-order-card data-order-status="{%- if order.fulfillment_status == 'fulfilled' -%}shipped{%- elsif order.cancelled_at != blank -%}cancelled{%- else -%}processing{%- endif -%}">
              <div class="oc-top">
                <div>
                  <span class="oc-id">{{ order.name }}</span> &middot; {{ order.created_at | date: '%b %d, %Y' }}
                </div>
                {%- assign first_vendor = order.line_items.first.vendor | upcase -%}
                {%- case first_vendor -%}
                  {%- when 'AMAZON' -%}
                    <span class="oc-store" style="background:rgba(26,26,46,0.85)">AMAZON</span>
                  {%- when 'ALIEXPRESS' -%}
                    <span class="oc-store" style="background:#E53E3E">ALIEXPRESS</span>
                  {%- when 'SEPHORA' -%}
                    <span class="oc-store" style="background:#000">SEPHORA</span>
                  {%- when 'MACYS' or "MACY'S" -%}
                    <span class="oc-store" style="background:#E21A2C">MACY'S</span>
                  {%- when 'SHEIN' -%}
                    <span class="oc-store" style="background:#222">SHEIN</span>
                  {%- else -%}
                    <span class="oc-store" style="background:var(--navy)">{{ first_vendor | default: 'STYLEHUB' }}</span>
                {%- endcase -%}
              </div>

              {%- for item in order.line_items limit: 1 -%}
                <div class="oc-items">
                  <div class="oc-img">
                    {%- if item.image -%}
                      <img src="{{ item.image | image_url: width: 128 }}" alt="{{ item.title | escape }}" width="64" height="64" loading="lazy" style="width:100%;height:100%;object-fit:cover">
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1" width="24" height="24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                    {%- endif -%}
                  </div>
                  <div class="oc-info">
                    <div class="oc-name">{{ item.title }}</div>
                    {%- if item.variant.title != 'Default Title' -%}
                      <div class="oc-variant">{{ item.variant.title }}</div>
                    {%- endif -%}
                    <div class="oc-price-row">
                      <span class="oc-price">{{ item.final_price | money }}</span>
                      {%- if item.variant.compare_at_price > item.final_price -%}
                        <span style="font-size:11px;color:#aaa;text-decoration:line-through">{{ item.variant.compare_at_price | money }}</span>
                      {%- endif -%}
                      {%- if item.quantity > 1 -%}
                        <span class="oc-qty">&times; {{ item.quantity }}</span>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}

              {%- comment -%} Tracking timeline for shipped orders {%- endcomment -%}
              {%- if order.fulfillment_status == 'fulfilled' -%}
                <div class="oc-track">
                  <div class="track">
                    <div class="track-node"><div class="track-dot done"></div><div class="track-line done"></div><div class="track-label active">Confirmed<br><span class="track-date">{{ order.created_at | date: '%b %d' }}</span></div></div>
                    <div class="track-node"><div class="track-dot done"></div><div class="track-line done"></div><div class="track-label active">Shipped<br><span class="track-date">{{ order.fulfillments.first.created_at | date: '%b %d' | default: '—' }}</span></div></div>
                    <div class="track-node"><div class="track-dot now"></div><div class="track-line"></div><div class="track-label active">In transit</div></div>
                    <div class="track-node"><div class="track-dot"></div><div class="track-label">Delivered</div></div>
                  </div>
                </div>
              {%- endif -%}

              <div class="oc-bottom">
                {%- if order.fulfillment_status == 'fulfilled' -%}
                  <span class="oc-status st-shipped">In transit</span>
                {%- elsif order.cancelled_at != blank -%}
                  <span class="oc-status st-returned">Cancelled</span>
                {%- else -%}
                  <span class="oc-status st-processing">Processing</span>
                {%- endif -%}
                <div class="oc-actions">
                  <a href="{{ order.customer_url }}" class="oc-btn oc-btn-outline" style="text-decoration:none">View details</a>
                  {%- if order.fulfillment_status == 'fulfilled' -%}
                    <a href="/apps/parcelpanel" class="oc-btn oc-btn-primary" style="text-decoration:none">Track package</a>
                  {%- endif -%}
                </div>
              </div>
            </div>

            {%- assign shown_orders = shown_orders | plus: 1 -%}
          {%- endfor -%}

          {%- if shown_orders == 0 -%}
            <div style="text-align:center;padding:24px 0;color:var(--text2)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" style="margin:0 auto 8px;display:block;opacity:0.3"><path d="M20 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
              <div style="font-size:13px;font-weight:500">No orders yet</div>
              <div style="font-size:12px;margin-top:4px">Start shopping to see your orders here</div>
              <a href="/" style="display:inline-block;margin-top:12px;font-size:12px;color:var(--red);font-weight:500;text-decoration:none">Browse products &rarr;</a>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Two-column: Wishlist + Coupons/Points {%- endcomment -%}
      <div class="g2">
        {%- comment -%} Wishlist preview — placeholder for Growave widget {%- endcomment -%}
        <div class="section">
          <div class="section-head">
            <div class="section-title">Wishlist <span class="count" id="sh-wishlist-count-badge">0</span></div>
            <a href="/pages/wishlist" class="section-action" style="text-decoration:none">View all &rarr;</a>
          </div>
          <div class="section-body">
            <div id="growave-wishlist-widget">
              <div class="wish-list" id="sh-wishlist-preview">
                <div style="text-align:center;padding:20px 0;color:var(--text2);grid-column:1/-1">
                  <div style="font-size:12px">Your wishlist items will appear here</div>
                  <a href="/" style="font-size:11px;color:var(--red);text-decoration:none;margin-top:4px;display:inline-block">Start browsing &rarr;</a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:16px">
          {%- comment -%} Coupons {%- endcomment -%}
          <div class="section">
            <div class="section-head">
              <div class="section-title">My coupons</div>
              <a href="/account#coupons" class="section-action" style="text-decoration:none">View all &rarr;</a>
            </div>
            <div class="section-body">
              <div class="coupon-card">
                <div class="coupon-left">
                  <div class="coupon-val">10%</div>
                  <div class="coupon-type">OFF</div>
                </div>
                <div class="coupon-mid">
                  <div class="coupon-name">WELCOME10</div>
                  <div class="coupon-desc">First order discount</div>
                  <div class="coupon-exp">New customers only</div>
                </div>
                <button class="coupon-use" data-copy-coupon="WELCOME10">Copy code</button>
              </div>
              <div class="coupon-card" style="border-color:#a7d5c0;background:#F0FFF8">
                <div class="coupon-left">
                  <div class="coupon-val" style="color:var(--green)">FREE</div>
                  <div class="coupon-type" style="color:var(--green)">SHIP</div>
                </div>
                <div class="coupon-mid">
                  <div class="coupon-name">FREESHIP</div>
                  <div class="coupon-desc">Free shipping on orders $30+</div>
                  <div class="coupon-exp">No expiration</div>
                </div>
                <button class="coupon-use" data-copy-coupon="FREESHIP">Copy code</button>
              </div>
            </div>
          </div>

          {%- comment -%} Reward points — Growave widget placeholder {%- endcomment -%}
          <div class="section">
            <div class="section-head">
              <div class="section-title">Reward points</div>
              <a href="/pages/rewards" class="section-action" style="text-decoration:none">How it works &rarr;</a>
            </div>
            <div class="section-body">
              <div class="points-wrap" id="growave-points-widget">
                <div class="points-circle">
                  <div class="points-inner">
                    <div class="points-num" id="sh-points-num">0</div>
                    <div class="points-lbl">POINTS</div>
                  </div>
                </div>
                <div class="points-info">
                  <div class="points-tier" id="sh-points-tier">Member</div>
                  <div class="points-next" id="sh-points-next">Start earning points today!</div>
                  <div class="points-earn">
                    <span class="points-tag">1pt / $1 spent</span>
                    <span class="points-tag">200pts = $10 off</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {%- comment -%} Buy Again — horizontal scroll of past purchases {%- endcomment -%}
      {%- assign has_past_items = false -%}
      {%- for order in customer.orders limit: 10 -%}
        {%- if order.fulfillment_status == 'fulfilled' or order.financial_status == 'paid' -%}
          {%- assign has_past_items = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_past_items -%}
        <div class="section">
          <div class="section-head">
            <div class="section-title">Buy again</div>
            <a href="/account#orders" class="section-action" style="text-decoration:none">View order history &rarr;</a>
          </div>
          <div class="section-body">
            <div class="reorder">
              {%- assign reorder_shown = 0 -%}
              {%- for order in customer.orders limit: 10 -%}
                {%- for item in order.line_items -%}
                  {%- if reorder_shown >= 8 -%}{%- break -%}{%- endif -%}
                  <div class="reorder-item">
                    <div class="reorder-img">
                      {%- if item.image -%}
                        <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" width="80" height="80" loading="lazy" style="width:100%;height:100%;object-fit:cover;border-radius:8px">
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#ddd" stroke-width="1" width="20" height="20"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                      {%- endif -%}
                    </div>
                    <div class="reorder-name">{{ item.title | truncate: 30 }}</div>
                    {%- if item.variant_id -%}
                      <div class="reorder-btn" data-buy-again="{{ item.variant_id }}" data-quantity="1">Reorder &rarr;</div>
                    {%- endif -%}
                  </div>
                  {%- assign reorder_shown = reorder_shown | plus: 1 -%}
                {%- endfor -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Two-column: Addresses + Messages {%- endcomment -%}
      <div class="g2">
        {%- comment -%} Addresses {%- endcomment -%}
        <div class="section">
          <div class="section-head">
            <div class="section-title">Addresses</div>
            <a href="/account/addresses" class="section-action" style="text-decoration:none">Manage &rarr;</a>
          </div>
          <div class="section-body">
            <div class="addr-row">
              {%- for address in customer.addresses limit: 2 -%}
                <div class="addr-item{% if address == customer.default_address %} default{% endif %}">
                  {%- if address == customer.default_address -%}
                    <span class="addr-default-badge">Default</span>
                  {%- endif -%}
                  <div class="addr-type">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    {{ address.first_name }} {{ address.last_name }}
                  </div>
                  <div class="addr-text">
                    {{ address.address1 }}<br>
                    {%- if address.address2 != blank -%}{{ address.address2 }}<br>{%- endif -%}
                    {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
                    {%- if address.phone != blank -%}{{ address.phone }}{%- endif -%}
                  </div>
                  <div class="addr-actions">
                    <a href="/account/addresses" class="addr-btn" style="text-decoration:none">Edit</a>
                  </div>
                </div>
              {%- endfor -%}

              {%- if customer.addresses.size == 0 -%}
                <div style="text-align:center;padding:16px 0;color:var(--text2);width:100%">
                  <div style="font-size:12px">No addresses saved yet</div>
                  <a href="/account/addresses" style="font-size:11px;color:var(--red);text-decoration:none;margin-top:4px;display:inline-block">Add address &rarr;</a>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>

        {%- comment -%} Messages — Shopify Inbox placeholder {%- endcomment -%}
        <div class="section">
          <div class="section-head">
            <div class="section-title">Messages</div>
            <a href="/account#messages" class="section-action" style="text-decoration:none">View all &rarr;</a>
          </div>
          <div class="section-body">
            <div id="shopify-inbox-widget">
              <div class="msg-row">
                <div class="msg-dot"></div>
                <div class="msg-body">
                  <div class="msg-title">Welcome to StyleHub Miami!</div>
                  <div class="msg-text">Thank you for creating your account. Browse our latest deals and start saving today.</div>
                </div>
                <div class="msg-time">Welcome</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {%- comment -%} Account settings quick view {%- endcomment -%}
      <div class="section">
        <div class="section-head">
          <div class="section-title">Account settings</div>
          <a href="/account#settings" class="section-action" style="text-decoration:none">Edit profile &rarr;</a>
        </div>
        <div class="section-body">
          <div class="set-grid">
            <div class="set-item">
              <div class="set-left">
                <div class="set-key">Full name</div>
                <div class="set-val">{{ customer.first_name }} {{ customer.last_name }}</div>
              </div>
            </div>
            <div class="set-item">
              <div class="set-left">
                <div class="set-key">Email address</div>
                <div class="set-val">{{ customer.email }}</div>
              </div>
            </div>
            <div class="set-item">
              <div class="set-left">
                <div class="set-key">Phone number</div>
                <div class="set-val">{{ customer.phone | default: 'Not set' }}</div>
              </div>
            </div>
            <div class="set-item">
              <div class="set-left">
                <div class="set-key">Total orders</div>
                <div class="set-val">{{ customer.orders_count }} orders &middot; {{ customer.total_spent }}</div>
              </div>
            </div>
            <div class="set-item">
              <div class="set-left">
                <div class="set-key">Addresses</div>
                <div class="set-val">{{ customer.addresses.size }} saved</div>
              </div>
              <a href="/account/addresses" class="set-edit" style="text-decoration:none">Manage</a>
            </div>
            <div class="set-item">
              <div class="set-left">
                <div class="set-key">Language</div>
                <div class="set-val">English (US)</div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- end dashboard -->

    {%- comment -%} === ORDERS SECTION (via hash #orders) === {%- endcomment -%}
    <div data-account-content-section="orders" style="display:none">

      <div class="welcome">
        <div>
          <h1>My orders</h1>
          <div class="welcome-sub">{{ customer.orders_count }} total orders</div>
        </div>
      </div>

      {%- comment -%} Filter tabs {%- endcomment -%}
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px">
        <button class="oc-btn oc-btn-primary" data-order-filter-tab="all" style="cursor:pointer">All</button>
        <button class="oc-btn oc-btn-outline" data-order-filter-tab="processing" style="cursor:pointer">Pending</button>
        <button class="oc-btn oc-btn-outline" data-order-filter-tab="shipped" style="cursor:pointer">Shipped</button>
        <button class="oc-btn oc-btn-outline" data-order-filter-tab="delivered" style="cursor:pointer">Delivered</button>
        <button class="oc-btn oc-btn-outline" data-order-filter-tab="cancelled" style="cursor:pointer">Cancelled</button>
      </div>

      <div data-orders-list>
        {%- for order in customer.orders -%}
          {%- comment -%} Determine order status {%- endcomment -%}
          {%- assign order_status = 'processing' -%}
          {%- if order.cancelled_at != blank -%}
            {%- assign order_status = 'cancelled' -%}
          {%- elsif order.fulfillment_status == 'fulfilled' -%}
            {%- assign order_status = 'shipped' -%}
          {%- endif -%}

          <div class="order-card" data-order-card data-order-status="{{ order_status }}">
            <div class="oc-top">
              <div>
                <span class="oc-id">{{ order.name }}</span> &middot; {{ order.created_at | date: '%b %d, %Y' }} &middot; {{ order.line_items.size }} item{{ order.line_items.size | pluralize: '', 's' }}
              </div>
              {%- assign first_vendor = order.line_items.first.vendor | upcase -%}
              {%- case first_vendor -%}
                {%- when 'AMAZON' -%}
                  <span class="oc-store" style="background:rgba(26,26,46,0.85)">AMAZON</span>
                {%- when 'ALIEXPRESS' -%}
                  <span class="oc-store" style="background:#E53E3E">ALIEXPRESS</span>
                {%- when 'SEPHORA' -%}
                  <span class="oc-store" style="background:#000">SEPHORA</span>
                {%- when 'MACYS' or "MACY'S" -%}
                  <span class="oc-store" style="background:#E21A2C">MACY'S</span>
                {%- when 'SHEIN' -%}
                  <span class="oc-store" style="background:#222">SHEIN</span>
                {%- else -%}
                  <span class="oc-store" style="background:var(--navy)">{{ first_vendor | default: 'STYLEHUB' }}</span>
              {%- endcase -%}
            </div>

            {%- for item in order.line_items limit: 2 -%}
              <div class="oc-items" {% if forloop.index > 1 %}style="margin-top:10px"{% endif %}>
                <div class="oc-img">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 128 }}" alt="{{ item.title | escape }}" width="64" height="64" loading="lazy" style="width:100%;height:100%;object-fit:cover">
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1" width="24" height="24"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                  {%- endif -%}
                </div>
                <div class="oc-info">
                  <div class="oc-name">{{ item.title }}</div>
                  {%- if item.variant.title != 'Default Title' -%}
                    <div class="oc-variant">{{ item.variant.title }}</div>
                  {%- endif -%}
                  <div class="oc-price-row">
                    <span class="oc-price">{{ item.final_price | money }}</span>
                    {%- if item.quantity > 1 -%}
                      <span class="oc-qty">&times; {{ item.quantity }}</span>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endfor -%}
            {%- if order.line_items.size > 2 -%}
              <div style="font-size:11px;color:var(--text2);margin-top:8px;padding-left:76px">+ {{ order.line_items.size | minus: 2 }} more item{{ order.line_items.size | minus: 2 | pluralize: '', 's' }}</div>
            {%- endif -%}

            {%- if order_status == 'shipped' -%}
              <div class="oc-track">
                <div class="track">
                  <div class="track-node"><div class="track-dot done"></div><div class="track-line done"></div><div class="track-label active">Confirmed<br><span class="track-date">{{ order.created_at | date: '%b %d' }}</span></div></div>
                  <div class="track-node"><div class="track-dot done"></div><div class="track-line done"></div><div class="track-label active">Shipped<br><span class="track-date">{{ order.fulfillments.first.created_at | date: '%b %d' | default: '—' }}</span></div></div>
                  <div class="track-node"><div class="track-dot now"></div><div class="track-line"></div><div class="track-label active">In transit</div></div>
                  <div class="track-node"><div class="track-dot"></div><div class="track-label">Delivered</div></div>
                </div>
              </div>
            {%- endif -%}

            <div class="oc-bottom">
              {%- if order_status == 'shipped' -%}
                <span class="oc-status st-shipped">In transit</span>
              {%- elsif order_status == 'cancelled' -%}
                <span class="oc-status st-returned">Cancelled</span>
              {%- elsif order.financial_status == 'refunded' -%}
                <span class="oc-status st-returned">Refunded</span>
              {%- else -%}
                <span class="oc-status st-processing">Processing</span>
              {%- endif -%}
              <div class="oc-actions">
                <a href="{{ order.customer_url }}" class="oc-btn oc-btn-outline" style="text-decoration:none">View details</a>
                {%- if order_status == 'shipped' -%}
                  <a href="/apps/parcelpanel" class="oc-btn oc-btn-primary" style="text-decoration:none">Track package</a>
                {%- elsif order_status == 'processing' -%}
                  <a href="{{ order.customer_url }}" class="oc-btn oc-btn-outline" style="text-decoration:none">Contact support</a>
                {%- endif -%}
                {%- if order.fulfillment_status == 'fulfilled' -%}
                  {%- if order.line_items.first.variant_id -%}
                    <button class="oc-btn oc-btn-outline" data-buy-again="{{ order.line_items.first.variant_id }}" data-quantity="1">Buy again</button>
                  {%- endif -%}
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}

        <div data-no-orders-message style="display:none;text-align:center;padding:32px 0;color:var(--text2)">
          <div style="font-size:13px;font-weight:500">No orders found for this filter</div>
          <div style="font-size:12px;margin-top:4px">Try selecting a different tab</div>
        </div>

        {%- if customer.orders.size == 0 -%}
          <div style="text-align:center;padding:40px 0;color:var(--text2)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="margin:0 auto 12px;display:block;opacity:0.3"><path d="M20 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            <div style="font-size:14px;font-weight:500">No orders yet</div>
            <div style="font-size:12px;margin-top:4px">Your order history will appear here once you make a purchase</div>
            <a href="/" style="display:inline-block;margin-top:16px;padding:10px 24px;background:var(--navy);color:#fff;border-radius:8px;font-size:13px;font-weight:500;text-decoration:none">Start shopping</a>
          </div>
        {%- endif -%}
      </div>
    </div><!-- end orders -->

    {%- comment -%} === RECENTLY VIEWED === {%- endcomment -%}
    <div data-account-content-section="recently-viewed" style="display:none">
      <div class="welcome">
        <div>
          <h1>Recently viewed</h1>
          <div class="welcome-sub">Products you've browsed recently</div>
        </div>
      </div>
      <div class="section">
        <div class="section-body" data-recently-viewed-products>
          <p style="text-align:center;padding:24px 0;color:var(--text2);font-size:13px">Loading recently viewed products...</p>
        </div>
      </div>
    </div>

    {%- comment -%} === COUPONS === {%- endcomment -%}
    <div data-account-content-section="coupons" style="display:none">
      <div class="welcome">
        <div>
          <h1>My coupons</h1>
          <div class="welcome-sub">Available discount codes for your next order</div>
        </div>
      </div>
      <div class="section">
        <div class="section-body">
          <div class="coupon-card">
            <div class="coupon-left"><div class="coupon-val">10%</div><div class="coupon-type">OFF</div></div>
            <div class="coupon-mid"><div class="coupon-name">WELCOME10</div><div class="coupon-desc">First order discount &middot; New customers only</div><div class="coupon-exp">Min. order $15</div></div>
            <button class="coupon-use" data-copy-coupon="WELCOME10">Copy code</button>
          </div>
          <div class="coupon-card" style="border-color:#a7d5c0;background:#F0FFF8">
            <div class="coupon-left"><div class="coupon-val" style="color:var(--green)">FREE</div><div class="coupon-type" style="color:var(--green)">SHIP</div></div>
            <div class="coupon-mid"><div class="coupon-name">FREESHIP</div><div class="coupon-desc">Free shipping on orders $30+</div><div class="coupon-exp">No expiration</div></div>
            <button class="coupon-use" data-copy-coupon="FREESHIP">Copy code</button>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} === MESSAGES === {%- endcomment -%}
    <div data-account-content-section="messages" style="display:none">
      <div class="welcome">
        <div>
          <h1>Messages</h1>
          <div class="welcome-sub">Your conversations with StyleHub support</div>
        </div>
      </div>
      <div class="section">
        <div class="section-body">
          <div id="shopify-inbox-messages-widget">
            <div class="msg-row">
              <div class="msg-dot"></div>
              <div class="msg-body">
                <div class="msg-title">Welcome to StyleHub Miami!</div>
                <div class="msg-text">Thank you for creating your account. If you need help with anything, our support team is here for you.</div>
              </div>
              <div class="msg-time">Welcome</div>
            </div>
            <div style="text-align:center;padding:16px 0;color:var(--text2);font-size:12px">
              Need help? Use the chat widget in the bottom right corner to start a conversation.
            </div>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} === SETTINGS === {%- endcomment -%}
    <div data-account-content-section="settings" style="display:none">
      <div class="welcome">
        <div>
          <h1>Account settings</h1>
          <div class="welcome-sub">Manage your personal information and preferences</div>
        </div>
      </div>
      <div class="section">
        <div class="section-body">
          <div class="set-grid">
            <div class="set-item">
              <div class="set-left"><div class="set-key">Full name</div><div class="set-val">{{ customer.first_name }} {{ customer.last_name }}</div></div>
            </div>
            <div class="set-item">
              <div class="set-left"><div class="set-key">Email address</div><div class="set-val">{{ customer.email }}</div></div>
            </div>
            <div class="set-item">
              <div class="set-left"><div class="set-key">Phone number</div><div class="set-val">{{ customer.phone | default: 'Not set' }}</div></div>
            </div>
            <div class="set-item">
              <div class="set-left"><div class="set-key">Password</div><div class="set-val">••••••••</div></div>
            </div>
            <div class="set-item">
              <div class="set-left"><div class="set-key">Total spent</div><div class="set-val">{{ customer.total_spent }}</div></div>
            </div>
            <div class="set-item">
              <div class="set-left"><div class="set-key">Language</div><div class="set-val">English (US)</div></div>
            </div>
          </div>
          <div style="margin-top:20px;padding-top:16px;border-top:0.5px solid var(--border);display:flex;gap:12px">
            <a href="/account/addresses" class="oc-btn oc-btn-primary" style="text-decoration:none;display:inline-block">Manage addresses</a>
            <a href="/account/logout" class="oc-btn oc-btn-outline" style="text-decoration:none;display:inline-block;color:var(--red);border-color:var(--red)">Log out</a>
          </div>
        </div>
      </div>
    </div>

  </div><!-- end main -->
</div><!-- end page -->

<script src="{{ 'account.js' | asset_url }}" defer></script>
