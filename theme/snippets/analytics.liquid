{% comment %}
  DealsHub — Analytics & Tracking Snippet
  Include in theme.liquid head: {% render 'analytics' %}
{% endcomment %}

{% if section.settings.ga_id or settings.ga_id %}
<!-- Google Analytics 4 -->
<script async src="https://www.googletagmanager.com/gtag/js?id={{ section.settings.ga_id | default: settings.ga_id }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '{{ section.settings.ga_id | default: settings.ga_id }}');
</script>
{% endif %}

<!-- DealsHub Analytics -->
<script>
(function() {
  'use strict';
  window.DHAnalytics = {
    events: [],

    track: function(event, data) {
      data = data || {};
      data.timestamp = new Date().toISOString();
      data.page = window.location.pathname;
      data.referrer = document.referrer;
      this.events.push({ event: event, data: data });

      // Push to GA4 if available
      if (typeof gtag === 'function') {
        gtag('event', event, data);
      }

      // Push to dataLayer for GTM
      if (window.dataLayer) {
        window.dataLayer.push({ event: 'dh_' + event, ...data });
      }
    },

    trackSearch: function(query, resultCount, sources) {
      this.track('search', {
        search_term: query,
        result_count: resultCount,
        sources: sources
      });
    },

    trackProductView: function(product) {
      this.track('view_item', {
        item_id: product.id,
        item_name: product.title,
        item_brand: product.brand,
        item_category: product.category,
        price: product.price,
        source: product.source
      });
    },

    trackAddToCart: function(product, variant) {
      this.track('add_to_cart', {
        item_id: product.id,
        item_name: product.title,
        price: product.price,
        source: product.source,
        variant: variant
      });
    },

    trackBeginCheckout: function(product) {
      this.track('begin_checkout', {
        item_id: product.id,
        item_name: product.title,
        price: product.price,
        source: product.source
      });
    },

    trackWishlist: function(product, action) {
      this.track('wishlist_' + action, {
        item_id: product.id,
        item_name: product.title,
        source: product.source
      });
    }
  };

  // Auto-track page views
  window.DHAnalytics.track('page_view');
})();
</script>
