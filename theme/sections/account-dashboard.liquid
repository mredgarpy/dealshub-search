</div>

{%- comment -%} ========== MAIN CONTENT ========== {%- endcomment -%}
<div class="sh-main">

  {%- comment -%} === DASHBOARD === {%- endcomment -%}
  <div class="sh-content-section active" data-sh-section="dashboard">

    <div class="sh-welcome">
      <div>
        <h1>Welcome back, {{ cust_first }}</h1>
        <div class="sh-welcome-sub">Here's what's happening with your account today</div>
      </div>
      <div class="sh-welcome-date">{{ 'now' | date: '%B %d, %Y' }}</div>
    </div>

    {%- comment -%} Alert for latest order in transit {%- endcomment -%}
    {%- for order in cust_orders limit: 1 -%}
      {%- if order.fulfillment_status == "fulfilled" and order.financial_status == "paid" -%}
        <div class="sh-alert">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <div>Your order <b>{{ order.name }}</b> has been fulfilled and is on its way!</div>
          <button class="sh-alert-close" data-sh-dismiss>&times;</button>
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Metrics cards {%- endcomment -%}
    <div class="sh-metrics">
      <div class="sh-metric m-orders">
        <div class="sh-metric-top">
          <div class="sh-metric-icon" style="background:var(--navy)">
            <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" width="16" height="16"><path d="M20 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/></svg>
          </div>
          {%- if active_orders > 0 -%}
            <span class="sh-metric-change" style="background:#E8F5E9;color:#1B5E20">{{ active_orders }} active</span>
          {%- endif -%}
        </div>
        <div class="sh-metric-num">{{ cust_order_count }}</div>
        <div class="sh-metric-label">Total orders</div>
      </div>

      <div class="sh-metric m-wish">
        <div class="sh-metric-top">
          <div class="sh-metric-icon" style="background:var(--red)">
            <svg viewBox="0 0 24 24" fill="#fff" width="14" height="14"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
        </div>
        <div class="sh-metric-num" data-sh-wishlist-count>0</div>
        <div class="sh-metric-label">Wishlist items</div>
      </div>

      <div class="sh-metric m-save">
        <div class="sh-metric-top">
          <div class="sh-metric-icon" style="background:var(--green)">
            <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" width="14" height="14"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
        </div>
        <div class="sh-metric-num" style="color:var(--green)">{{ total_savings | money }}</div>
        <div class="sh-metric-label">Total savings</div>
      </div>

      <div class="sh-metric m-points">
        <div class="sh-metric-top">
          <div class="sh-metric-icon" style="background:var(--amber)">
            <svg viewBox="0 0 24 24" fill="#fff" width="14" height="14"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <span class="sh-metric-change" style="background:#FEF3C7;color:#92400E">Member</span>
        </div>
        <div class="sh-metric-num" style="color:var(--amber)">0</div>
        <div class="sh-metric-label">Reward points</div>
      </div>
    </div>

    {%- comment -%} Active orders section {%- endcomment -%}
    <div class="sh-section">
      <div class="sh-section-head">
        <div class="sh-section-title">Active orders <span class="sh-count">{{ cust_order_count }}</span></div>
        <button class="sh-section-action" data-sh-nav="orders" style="background:none;border:none;font-family:inherit;cursor:pointer">View all orders &rarr;</button>
      </div>
      <div class="sh-section-body">
        {%- if cust_order_count == 0 -%}
          <div class="sh-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--navy)" stroke-width="1.5" width="48" height="48"><path d="M20 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            <h3>No orders yet</h3>
            <p>Start shopping to see your orders here.</p>
            <a href="/" class="sh-empty-btn">Start shopping &rarr;</a>
          </div>
        {%- else -%}
          {%- for order in cust_orders limit: 3 -%}
            <div class="sh-order-card">
              <div class="sh-oc-top">
                <div>
                  <span class="sh-oc-id">{{ order.name }}</span> &middot; {{ order.created_at | date: '%b %d, %Y' }}
                </div>
              </div>
              <div class="sh-oc-items">
                {%- assign first_item = order.line_items | first -%}
                <div class="sh-oc-img">
                  {%- if first_item.image -%}
                    <img src="{{ first_item.image | image_url: width: 128 }}" alt="{{ first_item.title | escape }}" loading="lazy">
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1" width="24" height="24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                  {%- endif -%}
                </div>
                <div class="sh-oc-info">
                  <div class="sh-oc-name">{{ first_item.title }}</div>
                  {%- if first_item.variant_title != blank -%}
                    <div class="sh-oc-variant">{{ first_item.variant_title }}</div>
                  {%- endif -%}
                  <div class="sh-oc-price-row">
                    <span class="sh-oc-price">{{ order.total_price | money }}</span>
                    <span class="sh-oc-qty">{{ order.line_items.size }} item{%- if order.line_items.size > 1 -%}s{%- endif -%}</span>
                  </div>
                </div>
              </div>

              {%- comment -%} Tracking timeline {%- endcomment -%}
              {%- assign ff_status = order.fulfillment_status -%}
              {%- assign fn_status = order.financial_status -%}
              {%- if ff_status == "fulfilled" or ff_status == "partial" -%}
                <div class="sh-oc-track">
                  <div class="sh-track">
                    <div class="sh-track-node">
                      <div class="sh-track-dot done"></div>
                      <div class="sh-track-line done"></div>
                      <div class="sh-track-label active">Confirmed<br><span class="sh-track-date">{{ order.created_at | date: '%b %d' }}</span></div>
                    </div>
                    <div class="sh-track-node">
                      <div class="sh-track-dot done"></div>
                      <div class="sh-track-line {% if ff_status == 'fulfilled' %}done{% endif %}"></div>
                      <div class="sh-track-label active">Shipped</div>
                    </div>
                    <div class="sh-track-node">
                      <div class="sh-track-dot {% if ff_status == 'fulfilled' %}done{% else %}now{% endif %}"></div>
                      <div class="sh-track-line"></div>
                      <div class="sh-track-label {% if ff_status == 'fulfilled' %}active{% endif %}">In transit</div>
                    </div>
                    <div class="sh-track-node">
                      <div class="sh-track-dot"></div>
                      <div class="sh-track-label">Delivered</div>
                    </div>
                  </div>
                </div>
              {%- endif -%}

              <div class="sh-oc-bottom">
                {%- if ff_status == "fulfilled" -%}
                  <span class="sh-oc-status sh-st-shipped">Shipped</span>
                {%- elsif ff_status == "partial" -%}
                  <span class="sh-oc-status sh-st-processing">Partially fulfilled</span>
                {%- elsif order.cancelled_at != blank -%}
                  <span class="sh-oc-status sh-st-cancelled">Cancelled</span>
                {%- else -%}
                  <span class="sh-oc-status sh-st-processing">Processing</span>
                {%- endif -%}
                <div class="sh-oc-actions">
                  <a href="{{ order.customer_url }}" class="sh-oc-btn sh-oc-btn-outline" target="_blank" rel="noopener">View details</a>
                  {%- if ff_status == "fulfilled" -%}
                    <a href="/pages/tracking" class="sh-oc-btn sh-oc-btn-primary">Track package</a>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Quick actions {%- endcomment -%}
    <div class="sh-section">
      <div class="sh-section-head">
        <div class="sh-section-title">Quick actions</div>
      </div>
      <div class="sh-section-body">
        <div class="sh-quick-grid">
          <button class="sh-quick-item" data-sh-nav="orders">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><path d="M20 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1z"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            My orders
          </button>
          <a class="sh-quick-item" href="/pages/tracking">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Track package
          </a>
          <a class="sh-quick-item" href="/pages/wishlist">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            Wishlist
          </a>
          <a class="sh-quick-item" href="/pages/rewards">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Rewards
          </a>
          <a class="sh-quick-item" href="/pages/help-center">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            Returns
          </a>
          <a class="sh-quick-item" href="/pages/help-center">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Help center
          </a>
        </div>
      </div>
    </div>

    {%- comment -%} Two columns: Coupons + Reward points {%- endcomment -%}
    <div class="sh-g2">
      <div class="sh-section">
        <div class="sh-section-head">
          <div class="sh-section-title">My coupons</div>
        </div>
        <div class="sh-section-body">
          <div class="sh-coupon-card">
            <div class="sh-coupon-left"><div class="sh-coupon-val">10%</div><div class="sh-coupon-type">OFF</div></div>
            <div class="sh-coupon-mid"><div class="sh-coupon-name">WELCOME10</div><div class="sh-coupon-desc">First order discount</div><div class="sh-coupon-exp">New customers only</div></div>
            <button class="sh-coupon-use" data-sh-copy="WELCOME10">Copy code</button>
          </div>
          <div class="sh-coupon-card" style="border-color:#a7d5c0;background:#F0FFF8">
            <div class="sh-coupon-left"><div class="sh-coupon-val" style="color:var(--green)">FREE</div><div class="sh-coupon-type" style="color:var(--green)">SHIP</div></div>
            <div class="sh-coupon-mid"><div class="sh-coupon-name">FREESHIP</div><div class="sh-coupon-desc">Free shipping on orders $30+</div><div class="sh-coupon-exp">No expiration</div></div>
            <button class="sh-coupon-use" data-sh-copy="FREESHIP">Copy code</button>
          </div>
        </div>
      </div>

      <div class="sh-section">
        <div class="sh-section-head">
          <div class="sh-section-title">Reward points</div>
          <a href="/pages/rewards" class="sh-section-action">How it works &rarr;</a>
        </div>
        <div class="sh-section-body">
          <div class="sh-points-wrap">
            <div class="sh-points-circle">
              <div class="sh-points-inner">
                <div class="sh-points-num">0</div>
                <div class="sh-points-lbl">POINTS</div>
              </div>
            </div>
            <div class="sh-points-info">
              <div class="sh-points-tier">Member</div>
              <div class="sh-points-next">Start earning points today!</div>
              <div class="sh-points-earn">
                <span class="sh-points-tag">1pt / $1 spent</span>
                <span class="sh-points-tag">200pts = $10 off</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} Buy again — from past orders {%- endcomment -%}
    {%- if cust_order_count > 0 -%}
    <div class="sh-section">
      <div class="sh-section-head">
        <div class="sh-section-title">Buy again</div>
        <button class="sh-section-action" data-sh-nav="orders" style="background:none;border:none;font-family:inherit;cursor:pointer">View order history &rarr;</button>
      </div>
      <div class="sh-section-body">
        <div class="sh-reorder">
          {%- for order in cust_orders limit: 6 -%}
            {%- for item in order.line_items limit: 1 -%}
              <div class="sh-reorder-item">
                <div class="sh-reorder-img">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" loading="lazy">
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1" width="24" height="24"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                  {%- endif -%}
                </div>
                <div class="sh-reorder-name">{{ item.title | truncate: 30 }}</div>
                <a href="{{ item.url }}" class="sh-reorder-btn">Reorder &rarr;</a>
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
    {%- endif -%}

    {%- comment -%} Two columns: Addresses + Messages {%- endcomment -%}
    <div class="sh-g2">
      <div class="sh-section">
        <div class="sh-section-head">
          <div class="sh-section-title">Addresses</div>
          <button class="sh-section-action" data-sh-nav="addresses" style="background:none;border:none;font-family:inherit;cursor:pointer;color:var(--red);font-weight:600;font-size:12px">Manage &rarr;</button>
        </div>
        <div class="sh-section-body">
          {%- if cust_addresses.size == 0 -%}
            <div style="text-align:center;padding:16px 0;color:var(--text2);font-size:12px">
              No addresses saved yet. <button data-sh-nav="addresses" style="background:none;border:none;font-family:inherit;cursor:pointer;color:var(--red);font-weight:600;font-size:12px">Add one &rarr;</button>
            </div>
          {%- else -%}
            <div class="sh-addr-row">
              {%- for address in cust_addresses limit: 2 -%}
                <div class="sh-addr-item{% if address == cust_default_address %} default{% endif %}">
                  {%- if address == cust_default_address -%}
                    <span class="sh-addr-default-badge">Default</span>
                  {%- endif -%}
                  <div class="sh-addr-type">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {%- if address.company != blank -%}{{ address.company }}{%- else -%}Address{%- endif -%}
                  </div>
                  <div class="sh-addr-text">
                    {{ address.first_name }} {{ address.last_name }}<br>
                    {{ address.address1 }}{%- if address.address2 != blank -%}, {{ address.address2 }}{%- endif -%}<br>
                    {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
                    {%- if address.phone != blank -%}{{ address.phone }}{%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="sh-section">
        <div class="sh-section-head">
          <div class="sh-section-title">Messages</div>
        </div>
        <div class="sh-section-body">
          <div class="sh-msg-row">
            <div class="sh-msg-dot"></div>
            <div class="sh-msg-body">
              <div class="sh-msg-title">Welcome to StyleHub Miami!</div>
              <div class="sh-msg-text">Thank you for being a member. Browse our latest deals and start saving today. Need help? Contact our support team.</div>
            </div>
            <div class="sh-msg-time">Welcome</div>
          </div>
