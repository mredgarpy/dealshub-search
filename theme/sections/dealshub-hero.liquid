    <span class="dh-hero__badge">{{ section.settings.badge }}</span>

    <h1 class="dh-hero__title">{{ section.settings.heading | default: 'StyleHub Miami' }}</h1>

    <p class="dh-hero__subtitle">{{ section.settings.subheading }}</p>
  
