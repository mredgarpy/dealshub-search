{% comment %}
  StyleHub Miami — Account Dashboard (Liquid-powered)
  Uses Shopify customer object for real data.
  If customer is nil, redirects to login.
  Design reference: stylehub_account_pro_v2 mockup
{% endcomment %}

{%- unless customer -%}
  <script>
    window.location.href = "{{ routes.account_login_url | default: '/account/login' }}";
  </script>
  <meta http-equiv="refresh" content="0;url={{ routes.account_login_url | default: '/account/login' }}">
  <div style="text-align:center;padding:80px 20px;font-family:'DM Sans',sans-serif">
    <p>Redirecting to login...</p>
    <a href="{{ routes.account_login_url | default: '/account/login' }}">Click here if not redirected</a>
  </div>
  {%- break -%}
{%- endunless -%}

{%- comment -%} Compute customer data from Liquid {%- endcomment -%}
{%- assign cust_first = customer.first_name | default: "Member" -%}
{%- assign cust_last = customer.last_name | default: "" -%}
{%- assign cust_name = customer.name | default: "StyleHub Member" -%}
{%- assign cust_email = customer.email | default: "" -%}
{%- assign cust_orders = customer.orders -%}
{%- assign cust_order_count = customer.orders_count | default: 0 -%}
{%- assign cust_addresses = customer.addresses -%}
{%- assign cust_default_address = customer.default_address -%}

{%- comment -%} Build initials {%- endcomment -%}
{%- assign initial1 = cust_first | slice: 0 | upcase -%}
{%- assign initial2 = cust_last | slice: 0 | upcase -%}
{%- if initial2 == blank -%}
  {%- assign initials = initial1 -%}
{%- else -%}
  {%- assign initials = initial1 | append: initial2 -%}
{%- endif -%}

{%- comment -%} Count active orders (unfulfilled/partial) {%- endcomment -%}
{%- assign active_orders = 0 -%}
{%- assign total_savings = 0 -%}
{%- for order in cust_orders -%}
  {%- if order.fulfillment_status == null or order.fulfillment_status == "partial" -%}
    {%- assign active_orders = active_orders | plus: 1 -%}
  {%- endif -%}
  {%- comment -%} Calculate savings from compare_at vs price {%- endcomment -%}
  {%- for item in order.line_items -%}
    {%- if item.variant.compare_at_price > item.variant.price -%}
      {%- assign item_saving = item.variant.compare_at_price | minus: item.variant.price | times: item.quantity -%}
      {%- assign total_savings = total_savings | plus: item_saving -%}
    {%- endif -%}
  {%- endfor -%}
{%- endfor -%}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap" rel="stylesheet">

<style>
/* ========== ACCOUNT DASHBOARD CSS ========== */
.sh-acct *{margin:0;padding:0;box-sizing:border-box}
.sh-acct{--red:#E53E3E;--navy:#1A1A2E;--gray:#F7F7F8;--border:#f0f0f0;--text2:#888;--text3:#bbb;--green:#1D9E75;--amber:#D97706;--radius:10px;font-family:'DM Sans',sans-serif;background:var(--gray);color:var(--navy);font-size:13px;-webkit-font-smoothing:antialiased}
.sh-acct a{text-decoration:none;color:inherit}

/* Layout */
.sh-page{max-width:1140px;margin:0 auto;padding:24px 20px;display:grid;grid-template-columns:240px minmax(0,1fr);gap:24px}

/* Sidebar */
.sh-side{display:flex;flex-direction:column;gap:0;position:sticky;top:20px;align-self:start}
.sh-side-profile{background:#fff;border-radius:14px;padding:20px;margin-bottom:12px;text-align:center;border:0.5px solid var(--border)}
.sh-side-av{width:56px;height:56px;border-radius:50%;background:var(--navy);margin:0 auto 10px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:18px;font-weight:600;letter-spacing:-0.5px}
.sh-side-name{font-size:15px;font-weight:600}
.sh-side-email{font-size:11px;color:var(--text2);margin-top:2px}
.sh-side-tier{display:inline-flex;align-items:center;gap:4px;margin-top:8px;font-size:10px;font-weight:600;color:var(--amber);background:#FEF3C7;padding:3px 10px;border-radius:20px}
.sh-side-tier svg{width:12px;height:12px}

.sh-side-nav{background:#fff;border-radius:14px;padding:8px;border:0.5px solid var(--border)}
.sh-nav-group{padding:4px 0}
.sh-nav-label{font-size:10px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:0.8px;padding:10px 12px 4px}
.sh-nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;color:#666;font-size:13px;cursor:pointer;transition:all 0.15s;position:relative;border:none;background:none;width:100%;text-align:left;font-family:inherit}
.sh-nav-item:hover{background:var(--gray);color:var(--navy)}
.sh-nav-item.active{background:var(--navy);color:#fff;font-weight:500}
.sh-nav-item svg{width:18px;height:18px;opacity:0.5;flex-shrink:0}
.sh-nav-item.active svg{opacity:1}
.sh-nav-badge{position:absolute;right:10px;font-size:10px;font-weight:600;background:var(--red);color:#fff;min-width:18px;height:18px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 5px}
.sh-nav-sep{height:0.5px;background:var(--border);margin:4px 8px}

/* Mobile toggle */
.sh-mobile-toggle{display:none;position:fixed;bottom:20px;right:20px;z-index:100;width:48px;height:48px;border-radius:50%;background:var(--navy);color:#fff;border:none;cursor:pointer;box-shadow:0 4px 16px rgba(0,0,0,0.2);align-items:center;justify-content:center}

/* Main content */
.sh-main{display:flex;flex-direction:column;gap:16px}
.sh-welcome{display:flex;justify-content:space-between;align-items:flex-end}
.sh-welcome h1{font-size:22px;font-weight:700;letter-spacing:-0.5px}
.sh-welcome-sub{font-size:13px;color:var(--text2);margin-top:2px}
.sh-welcome-date{font-size:12px;color:var(--text2)}

/* Alert bar */
.sh-alert{background:#FEF3C7;border-radius:var(--radius);padding:12px 16px;display:flex;align-items:center;gap:12px;font-size:12px;color:#92400E}
.sh-alert svg{width:18px;height:18px;flex-shrink:0;color:var(--amber)}
.sh-alert b{font-weight:600}
.sh-alert-close{margin-left:auto;opacity:0.5;cursor:pointer;font-size:16px;background:none;border:none;color:#92400E}

/* Metrics */
.sh-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.sh-metric{background:#fff;border-radius:var(--radius);padding:16px;border:0.5px solid var(--border);position:relative;overflow:hidden}
.sh-metric::after{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.sh-metric.m-orders::after{background:var(--navy)}
.sh-metric.m-wish::after{background:var(--red)}
.sh-metric.m-save::after{background:var(--green)}
.sh-metric.m-points::after{background:var(--amber)}
.sh-metric-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.sh-metric-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;color:#fff}
.sh-metric-change{font-size:10px;padding:2px 6px;border-radius:4px;font-weight:500}
.sh-metric-num{font-size:26px;font-weight:700;letter-spacing:-1px;line-height:1}
.sh-metric-label{font-size:11px;color:var(--text2);margin-top:4px}

/* Sections / Cards */
.sh-section{background:#fff;border-radius:14px;padding:0;border:0.5px solid var(--border);overflow:hidden}
.sh-section-head{display:flex;justify-content:space-between;align-items:center;padding:18px 20px 0}
.sh-section-title{font-size:15px;font-weight:600;display:flex;align-items:center;gap:8px}
.sh-section-title .sh-count{font-size:11px;background:var(--gray);padding:2px 8px;border-radius:10px;color:var(--text2);font-weight:500}
.sh-section-action{font-size:12px;color:var(--red);font-weight:500;cursor:pointer;display:flex;align-items:center;gap:4px;text-decoration:none}
.sh-section-body{padding:16px 20px 20px}

/* Order cards */
.sh-order-card{border:0.5px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:12px;transition:box-shadow 0.2s}
.sh-order-card:hover{box-shadow:0 2px 12px rgba(0,0,0,0.04)}
.sh-order-card:last-child{margin-bottom:0}
.sh-oc-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;font-size:11px;color:var(--text2)}
.sh-oc-id{font-weight:600;color:var(--navy);font-size:12px}
.sh-oc-items{display:flex;gap:12px;align-items:center}
.sh-oc-img{width:64px;height:64px;border-radius:8px;background:var(--gray);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:9px;color:#ccc;overflow:hidden}
.sh-oc-img img{width:100%;height:100%;object-fit:cover}
.sh-oc-info{flex:1;min-width:0}
.sh-oc-name{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sh-oc-variant{font-size:11px;color:var(--text2);margin-top:2px}
.sh-oc-price-row{display:flex;align-items:baseline;gap:6px;margin-top:4px}
.sh-oc-price{font-size:15px;font-weight:700;color:var(--red)}
.sh-oc-qty{font-size:11px;color:var(--text2)}

/* Tracking timeline */
.sh-oc-track{margin-top:14px;padding-top:14px;border-top:0.5px solid var(--border)}
.sh-track{display:flex;align-items:center;gap:0}
.sh-track-node{display:flex;flex-direction:column;align-items:center;flex:1;position:relative}
.sh-track-dot{width:12px;height:12px;border-radius:50%;background:#eee;border:2px solid #eee;z-index:1;transition:all 0.3s}
.sh-track-dot.done{background:var(--green);border-color:var(--green)}
.sh-track-dot.now{background:#fff;border-color:var(--green);box-shadow:0 0 0 3px rgba(29,158,117,0.2)}
.sh-track-line{position:absolute;top:5px;left:50%;width:100%;height:2px;background:#eee}
.sh-track-node:last-child .sh-track-line{display:none}
.sh-track-line.done{background:var(--green)}
.sh-track-label{font-size:10px;color:var(--text2);margin-top:6px;text-align:center;line-height:1.2}
.sh-track-label.active{color:var(--green);font-weight:500}
.sh-track-date{font-size:9px;color:var(--text3)}

.sh-oc-bottom{display:flex;justify-content:space-between;align-items:center;margin-top:12px}
.sh-oc-status{font-size:11px;font-weight:500;padding:4px 10px;border-radius:6px}
.sh-st-shipped{background:#E8F5E9;color:#1B5E20}
.sh-st-processing{background:#FEF3C7;color:#92400E}
.sh-st-delivered{background:#E6F1FB;color:#0C447C}
.sh-st-cancelled{background:#FEE2E2;color:#991B1B}
.sh-oc-actions{display:flex;gap:6px}
.sh-oc-btn{font-size:11px;padding:6px 14px;border-radius:6px;font-weight:500;cursor:pointer;border:none;font-family:inherit}
.sh-oc-btn-primary{background:var(--navy);color:#fff}
.sh-oc-btn-outline{background:#fff;color:var(--navy);border:1px solid #ddd}

/* Two-column grid */
.sh-g2{display:grid;grid-template-columns:1fr 1fr;gap:16px}

/* Wishlist */
.sh-wish-list{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.sh-wish-item{display:flex;gap:10px;background:var(--gray);border-radius:8px;padding:10px;position:relative}
.sh-wish-img{width:60px;height:60px;border-radius:6px;background:#fff;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:8px;color:#ddd;overflow:hidden;position:relative}
.sh-wish-img img{width:100%;height:100%;object-fit:cover}
.sh-wish-body{flex:1;min-width:0;display:flex;flex-direction:column;justify-content:center}
.sh-wish-name{font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sh-wish-pr{font-size:14px;font-weight:700;color:var(--red);margin-top:2px}
.sh-wish-pr .orig{font-size:10px;color:var(--text3);text-decoration:line-through;font-weight:400;margin-left:4px}
.sh-wish-cart{font-size:10px;color:var(--navy);font-weight:500;margin-top:3px;cursor:pointer}
.sh-wish-cart:hover{color:var(--red)}
.sh-wish-x{position:absolute;top:6px;right:6px;width:16px;height:16px;border-radius:50%;background:rgba(0,0,0,0.05);display:flex;align-items:center;justify-content:center;font-size:10px;color:#999;cursor:pointer;border:none}

/* Coupons */
.sh-coupon-card{display:flex;align-items:center;gap:12px;border:1px dashed #e5c77e;background:#FFFDF5;border-radius:8px;padding:12px;margin-bottom:8px}
.sh-coupon-card:last-child{margin-bottom:0}
.sh-coupon-left{text-align:center;min-width:60px}
.sh-coupon-val{font-size:20px;font-weight:700;color:var(--amber);line-height:1}
.sh-coupon-type{font-size:9px;color:var(--amber);font-weight:500}
.sh-coupon-mid{flex:1}
.sh-coupon-name{font-size:12px;font-weight:600;color:var(--navy)}
.sh-coupon-desc{font-size:11px;color:var(--text2);margin-top:1px}
.sh-coupon-exp{font-size:10px;color:var(--text3);margin-top:3px}
.sh-coupon-use{font-size:11px;background:var(--navy);color:#fff;padding:6px 14px;border-radius:6px;font-weight:500;cursor:pointer;white-space:nowrap;border:none;font-family:inherit}

/* Points */
.sh-points-wrap{display:flex;align-items:center;gap:16px}
.sh-points-circle{width:72px;height:72px;border-radius:50%;background:conic-gradient(var(--red) 0% 60%, #eee 60% 100%);display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative}
.sh-points-inner{width:58px;height:58px;border-radius:50%;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center}
.sh-points-num{font-size:18px;font-weight:700;color:var(--red);line-height:1}
.sh-points-lbl{font-size:8px;color:var(--text2);font-weight:500}
.sh-points-info{flex:1}
.sh-points-tier{font-size:14px;font-weight:600}
.sh-points-next{font-size:11px;color:var(--text2);margin-top:2px}
.sh-points-earn{display:flex;gap:6px;margin-top:8px}
.sh-points-tag{font-size:10px;background:var(--gray);padding:3px 8px;border-radius:4px;color:#666}

/* Addresses */
.sh-addr-row{display:flex;gap:10px}
.sh-addr-item{flex:1;border:0.5px solid var(--border);border-radius:8px;padding:14px;position:relative}
.sh-addr-item.default{border-color:var(--green)}
.sh-addr-default-badge{position:absolute;top:10px;right:10px;font-size:9px;background:#E8F5E9;color:#1B5E20;padding:2px 8px;border-radius:4px;font-weight:500}
.sh-addr-type{font-size:12px;font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:6px}
.sh-addr-type svg{width:14px;height:14px;color:var(--text2)}
.sh-addr-text{font-size:11px;color:var(--text2);line-height:1.6}
.sh-addr-actions{display:flex;gap:8px;margin-top:8px}
.sh-addr-btn{font-size:10px;color:var(--red);font-weight:500;cursor:pointer}

/* Messages */
.sh-msg-row{display:flex;gap:12px;padding:12px 0;border-bottom:0.5px solid var(--border);align-items:start}
.sh-msg-row:last-child{border-bottom:none}
.sh-msg-dot{width:6px;height:6px;border-radius:50%;background:var(--red);margin-top:6px;flex-shrink:0}
.sh-msg-dot.read{background:#ddd}
.sh-msg-body{flex:1}
.sh-msg-title{font-size:12px;font-weight:600}
.sh-msg-text{font-size:11px;color:var(--text2);margin-top:2px;line-height:1.4}
.sh-msg-time{font-size:10px;color:var(--text3);flex-shrink:0;margin-top:2px}

/* Settings grid */
.sh-set-grid{display:grid;grid-template-columns:1fr 1fr;gap:0}
.sh-set-item{display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:0.5px solid var(--border)}
.sh-set-item:nth-child(odd){padding-right:20px;border-right:0.5px solid var(--border)}
.sh-set-item:nth-child(even){padding-left:20px}
.sh-set-left{display:flex;flex-direction:column;gap:1px}
.sh-set-key{font-size:12px;font-weight:500}
.sh-set-val{font-size:11px;color:var(--text2)}
.sh-set-edit{font-size:11px;color:var(--red);font-weight:500;cursor:pointer}

/* Buy again / Reorder */
.sh-reorder{display:flex;gap:10px;overflow-x:auto;padding-bottom:4px}
.sh-reorder-item{min-width:80px;text-align:center;flex-shrink:0}
.sh-reorder-img{width:80px;height:80px;border-radius:8px;background:var(--gray);margin-bottom:6px;display:flex;align-items:center;justify-content:center;font-size:8px;color:#ddd;overflow:hidden}
.sh-reorder-img img{width:100%;height:100%;object-fit:cover}
.sh-reorder-name{font-size:10px;color:#666;height:26px;overflow:hidden}
.sh-reorder-btn{font-size:10px;color:var(--red);font-weight:500;margin-top:2px;cursor:pointer;text-decoration:none;display:block}

/* Quick actions */
.sh-quick-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px}
.sh-quick-item{display:flex;flex-direction:column;align-items:center;gap:8px;padding:16px;background:var(--gray);border-radius:10px;text-decoration:none;color:var(--navy);font-size:12px;font-weight:500;transition:box-shadow 0.2s;cursor:pointer;border:none;font-family:inherit}
.sh-quick-item:hover{box-shadow:0 2px 8px rgba(0,0,0,0.06)}

/* Tab bar for orders */
.sh-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:16px}
.sh-tab{padding:10px 16px;font-size:12px;font-weight:500;color:var(--text2);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;background:none;border-top:none;border-left:none;border-right:none;font-family:inherit}
.sh-tab.active{color:var(--navy);border-bottom-color:var(--red);font-weight:600}
.sh-tab:hover{color:var(--navy)}

/* Empty state */
.sh-empty{text-align:center;padding:40px 20px}
.sh-empty svg{margin:0 auto 16px;display:block;opacity:0.4}
.sh-empty h3{font-size:1.1rem;color:var(--navy);margin:0 0 8px}
.sh-empty p{color:var(--text2);font-size:0.9rem;margin:0 0 20px;max-width:400px;margin-left:auto;margin-right:auto}
.sh-empty-btn{display:inline-block;background:var(--navy);color:#fff;padding:12px 28px;border-radius:8px;font-size:0.9rem;font-weight:600;text-decoration:none;transition:opacity 0.2s}
.sh-empty-btn:hover{opacity:0.9}

/* Content sections toggling */
.sh-content-section{display:none}
.sh-content-section.active{display:block}

/* ========== RESPONSIVE ========== */
@media(max-width:900px){
  .sh-page{grid-template-columns:1fr;padding:16px 12px}
  .sh-side{position:fixed;top:0;left:-280px;width:270px;height:100vh;z-index:200;background:var(--gray);padding:16px;overflow-y:auto;transition:left 0.3s ease;box-shadow:4px 0 24px rgba(0,0,0,0.1)}
  .sh-side.open{left:0}
  .sh-mobile-toggle{display:flex}
  .sh-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);z-index:199}
  .sh-overlay.open{display:block}
  .sh-metrics{grid-template-columns:repeat(2,1fr)}
  .sh-g2{grid-template-columns:1fr}
  .sh-wish-list{grid-template-columns:1fr}
  .sh-set-grid{grid-template-columns:1fr}
  .sh-set-item:nth-child(odd){padding-right:0;border-right:none}
  .sh-set-item:nth-child(even){padding-left:0}
  .sh-addr-row{flex-direction:column}
  .sh-welcome{flex-direction:column;gap:4px;align-items:flex-start}
}
@media(max-width:480px){
  .sh-metrics{grid-template-columns:1fr 1fr}
  .sh-oc-items{flex-direction:column;align-items:flex-start}
  .sh-oc-bottom{flex-direction:column;gap:8px;align-items:flex-start}
}
</style>

<div class="sh-acct">
<div class="sh-overlay" data-sh-overlay></div>

<div class="sh-page">

{%- comment -%} ========== SIDEBAR ========== {%- endcomment -%}
<div class="sh-side" data-sh-sidebar>

  <button class="sh-mobile-toggle" data-sh-mobile-toggle aria-label="Toggle menu">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>

  <div class="sh-side-profile">
    <div class="sh-side-av">{{ initials }}</div>
    <div class="sh-side-name">{{ cust_name }}</div>
    <div class="sh-side-email">{{ cust_email }}</div>
    <div class="sh-side-tier">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <span>Member</span>
    </div>
  </div>

  <div class="sh-side-nav">
    <div class="sh-nav-group">
      <button class="sh-nav-item active" data-sh-nav="dashboard">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </button>
      <button class="sh-nav-item" data-sh-nav="orders">
