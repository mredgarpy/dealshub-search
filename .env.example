# DealsHub — Environment Variables
# Copy this to .env and fill in your values

# Shopify Store
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx
SHOPIFY_LOCATION_ID=84042121347

# RapidAPI
RAPIDAPI_KEY=your-rapidapi-key

# Seal Subscriptions API
SEAL_API_TOKEN=seal_token_xxxxxxxxxxxxxxxxxxxxx
SEAL_API_SECRET=seal_secret_xxxxxxxxxxxxxxxxxxxxx

# Server
PORT=3000
NODE_ENV=production
