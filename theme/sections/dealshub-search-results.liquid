 $('#dh-result-count');
  const sortSelect = $('#dh-sort');

  let allResults = [];
  let filteredResults = [];
  let displayedCount = 0;
  let currentQuery = '';
  let currentSource = 'all';
  const PAGE_SIZE = 24;

  // Init from URL params
  function init() {
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q') || params.get('query') || '';
    const source = params.get('source') || 'all';

    if (q) {
      input.value = q;
      currentQuery = q;
      currentSource = source;
      setActiveChip(source);
      doSearch(q, source);
    }
  }

  // Search
  async function doSearch(query, source) {
    if (!query.trim()) return;

    showSkeleton();
    hideEmpty();
    hideGrid();
    hideLoadMore();

    try {
      const sources = source === 'all'
        ? ['amazon', 'aliexpress', 'sephora', 'macys', 'shein']
        : [source];

      // Parallel search across sources
      const promises = sources.map(s =>
        API.search(query, { source: s, limit: 20 })
          .then(results => results || [])
          .catch(() => [])
      );

      const arrays = await Promise.all(promises);
      allResults = arrays.flat();

      // Update URL
      const url = new URL(window.location);
      url.searchParams.set('q', query);
      if (source !== 'all') url.searchParams.set('source', source);
      else url.searchParams.delete('source');
      history.replaceState(null, '', url);

      applySort();
      displayedCount = 0;
      showResults();
    } catch (err) {
      console.error('Search error:', err);
      showEmpty();
    } finally {
      hideSkeleton();
    }
  }

  // Sort
  function applySort() {
    const sort = sortSelect.value;
    filteredResults = [...allResults];

    if (sort === 'price_asc') {
      filteredResults.sort((a, b) => parseNum(a.price) - parseNum(b.price));
    } else if (sort === 'price_desc') {
      filteredResults.sort((a, b) => parseNum(b.price) - parseNum(a.price));
    } else if (sort === 'rating') {
      filteredResults.sort((a, b) => (b.rating || 0) - (a.rating || 0));
    }
  }

  function parseNum(s) {
    if (!s) return 999999;
    return parseFloat(String(s).replace(/[^0-9.]/g, '')) || 999999;
  }

  // Display results
  function showResults() {
    if (filteredResults.length === 0) {
      showEmpty();
      resultCount.textContent = '';
      return;
    }

    const next = filteredResults.slice(displayedCount, displayedCount + PAGE_SIZE);
    const html = next.map((p, i) => renderCard(p, displayedCount + i)).join('');

    if (displayedCount === 0) {
      grid.innerHTML = html;
    } else {
      grid.insertAdjacentHTML('beforeend', html);
    }

    displayedCount += next.length;
    resultCount.textContent = `${filteredResults.length} resultado${filteredResults.length !== 1 ? 's' : ''}`;

    showGrid();

    if (displayedCount < filteredResults.length) {
      showLoadMore();
    } else {
      hideLoadMore();
    }

    bindCardActions();
  }

  // Render a single card
  function renderCard(p, idx) {
    const badgeHTML = p.badge
      ? `<span class="dh-card__badge dh-card__badge--${(p.badge || '').toLowerCase().replace(/\s/g,'-')}">${p.badge}</span>`
      : '';
    const ratingHTML = p.rating
      ? `<div class="dh-card__rating">
           <span class="dh-card__stars" style="--rating:${p.rating}"></span>
           ${p.reviews ? `<span class="dh-card__reviews">(${formatNum(p.reviews)})</span>` : ''}
         </div>`
      : '';
    const origHTML = p.originalPrice
      ? `<span class="dh-card__price-orig">${p.originalPrice}</span>`
      : '';

    return `
      <div class="dh-card" data-product-id="${p.id}" data-source="${p.source}">
        ${badgeHTML}
        <a href="/pages/product?id=${p.id}&store=${p.source}" class="dh-card__link">
          <div class="dh-card__img-wrap">
            <img src="${p.image || ''}" alt="${esc(p.title)}" loading="${idx < 8 ? 'eager' : 'lazy'}" width="300" height="300" class="dh-card__img"
              onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22%3E%3Crect fill=%22%23f0f0f0%22 width=%22300%22 height=%22300%22/%3E%3C/svg%3E'">
          </div>
          <div class="dh-card__body">
            ${p.brand ? `<span class="dh-card__brand">${esc(p.brand)}</span>` : ''}
            <h3 class="dh-card__title">${esc(p.title)}</h3>
            ${ratingHTML}
            <div class="dh-card__price-row">
              ${p.price ? `<span class="dh-card__price">${p.price}</span>` : ''}
              ${origHTML}
            </div>
            <span class="dh-card__source">${esc(p.sourceName || p.source)}</span>
          </div>
        </a>
        <div class="dh-card__actions">
          <button class="dh-card__btn-cart" data-id="${p.id}" data-src="${p.source}" aria-label="Agregar al carrito">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
          </button>
          <button class="dh-card__btn-wish js-wish" data-id="${p.id}" data-src="${p.source}" aria-label="Wishlist">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          </button>
        </div>
      </div>`;
  }

  function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
  function formatNum(n) { return n >= 1000 ? (n/1000).toFixed(1) + 'k' : n; }

  // Card action bindings
  function bindCardActions() {
    grid.querySelectorAll('.dh-card__btn-cart').forEach(btn => {
      btn.onclick = async (e) => {
        e.preventDefault();
        const id = btn.dataset.id;
        const src = btn.dataset.src;
        btn.disabled = true;
        btn.innerHTML = '<span class="dh-spinner-sm"></span>';
        try {
          await API.buyNow(id, src);
        } catch (err) {
          console.error('Cart error:', err);
          alert('Error agregando al carrito');
        } finally {
          btn.disabled = false;
          btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>';
        }
      };
    });

    grid.querySelectorAll('.js-wish').forEach(btn => {
      btn.onclick = (e) => {
        e.preventDefault();
        btn.classList.toggle('active');
        const id = btn.dataset.id;
        const src = btn.dataset.src;
        const product = allResults.find(p => p.id === id && p.source === src);
        if (product) API.wishlist.toggle(product);
      };
    });
  }

  // Source filter chips
  $$('#dh-source-filters .dh-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      currentSource = chip.dataset.source;
      setActiveChip(currentSource);
      if (currentQuery) doSearch(currentQuery, currentSource);
    });
  });

  function setActiveChip(source) {
    $$('#dh-source-filters .dh-chip').forEach(c => {
      c.classList.toggle('dh-chip--active', c.dataset.source === source);
    });
  }

  // Sort change
  sortSelect.addEventListener('change', () => {
    applySort();
    displayedCount = 0;
    showResults();
  });

  // Form submit
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    currentQuery = input.value.trim();
    if (currentQuery) doSearch(currentQuery, currentSource);
  });

  // Load more
  loadMoreBtn.addEventListener('click', () => showResults());

  // Show/hide helpers
  function showSkeleton() { skeleton.classList.remove('dh-grid--hidden'); }
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
